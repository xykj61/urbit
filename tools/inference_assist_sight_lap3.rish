# inference_assist_sight_lap3.rish — Assist sight: plain fences + journal on carriage fold.
#
# Run from the repository root:
#   rishi/bin/rishi run tools/inference_assist_sight_lap3.rish

let bin = "pond/bin/drawn-terminal"

say "build: inference assist sight lap 3 — drawn-terminal compile"
let build = run ["sh" "tools/fixtures/pond_build_drawn_terminal.sh"]
assert build.ok else "drawn_terminal build failed for assist sight lap 3"
assert build.out contains "GREEN:" else "drawn_terminal build did not reach GREEN"

let assist = run ["sh" "-c" "${bin} assistviewsighttest 2>&1"]
assert assist.ok else "drawn terminal assistviewsighttest exited non-zero"
assert assist.out contains "assist sight" else "assist sight missing expected output"
assert assist.out contains "plain=1" else "assist sight missing plain fence count"
assert assist.out contains "journal=2" else "assist sight missing journal entry count"
assert assist.out contains "rye=2" else "assist sight missing rye snippet count"
assert assist.out contains "GREEN" else "Inference assist sight lap 3 not GREEN"
assert assist.out contains "lines=8" else "assist sight missing eight-line frame"

say "GREEN: Inference assist sight lap 3 — plain fences and journal memos on the carriage fold."
