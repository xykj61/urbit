# lane_kvm_onpath_host.rish — Framework host one-shot (A-narrow · Claude 125200/130300).
#
# Run OUTSIDE ai-jail on a host with /dev/kvm. Does not edit enclosure.conf —
# exports LANE_KVM=true for the boot only, then re-proves refuse with lane off.
#
#   rishi/bin/rishi run tools/lane_kvm_onpath_host.rish
#   rishi/bin/rishi run tools/lane_kvm_onpath_host.rish --parity
#
# Paired refuse floor: tools/lane_kvm_refuse.rish

say "lane_kvm on-path host: verify-commit (sandbox key)…"
let ver = run ["sh" "-c" "git verify-commit HEAD"]
assert ver.ok else "git verify-commit HEAD failed — pull a Good nib first"

say "lane_kvm on-path host: require /dev/kvm…"
let kvm = run ["sh" "-c" "test -e /dev/kvm"]
assert kvm.ok else "REFUSE: /dev/kvm absent — this script is host-only; ai-sandbox cannot grant kvm"

say "lane_kvm on-path host: image pin…"
let img = "tools/.cache/proven-seat/sculpt-26-04.img"
let expected = "241b916ab9e3ed25a089c27119aac98f80fe4d3e67101936b4e69d7f1c708f14"
let have = run ["sh" "-c" "test -f ${img}"]
assert have.ok else "missing ${img} — stage the pinned Sculpt image first"
let hash = run ["sh" "-c" "sha256sum ${img} | cut -d' ' -f1"]
assert hash.ok else "sha256sum failed"
assert hash.out contains expected else "sculpt-26-04.img sha256 mismatch (want ${expected})"

say "lane_kvm on-path host: image pin ok (${hash.out})"
say "lane_kvm on-path host: G0-complete — two phases, ~2–3 min (A nographic GRUB · B display-none glass)."
say "lane_kvm on-path host: live pulse in another terminal:"
say "  tail -f tools/.cache/proven-seat/g0c-lane-meta.txt"
say "lane_kvm on-path host: starting boot with LANE_KVM=true (env one-shot; conf stays off)…"
let boot = run ["bash" "-c" "LANE_KVM=true stdbuf -oL -eL ./tools/run_with_lane_kvm.sh -- ./tools/proven_seat_g0c_lane_kvm.sh"]
say "lane_kvm on-path host: boot finished — ok=${boot.ok}"
say "${boot.out}"
assert boot.ok else "G0-complete boot failed — see tools/.cache/proven-seat/g0c-lane-meta.txt"
assert boot.out contains "GREEN" else "G0-complete missing GREEN"
say "lane_kvm on-path host: G0-complete GREEN"

if (args contains "--parity") then say "lane_kvm on-path host: same-sitting parity re-pin…"
if (args contains "--parity") then let par = run ["sh" "-c" "rishi/bin/rishi run tools/parity.rish"]
if (args contains "--parity") then say "lane_kvm on-path host: parity ok=${par.ok} — pin printed composition; red twice parks"
if (args contains "--parity") then assert par.ok
if (args contains "--parity") then say "lane_kvm on-path host: parity exit 0 — pin the printed composition count"

say "lane_kvm on-path host: restore refuse floor (conf still off)…"
let refuse = run ["sh" "-c" "./tools/lane_kvm.sh refuse-probe"]
assert refuse.ok else "refuse-probe failed after on-path — leave the sitting parked"
say "lane_kvm on-path host: ${refuse.out}"

say "lane_kvm on-path host: run artifacts must stay gitignored…"
let leak = run ["sh" "-c" "git status --porcelain | rg 'tools/\\.cache' || true"]
assert leak.out == "" else "tools/.cache leaked into git status — check .gitignore"
let porc = run ["sh" "-c" "git status --porcelain"]
say "lane_kvm on-path host: porcelain (pre-existing dirt ok; cache must not appear):\n${porc.out}"

say "GREEN: lane_kvm on-path host — permit green + refuse restored; human-in-loop sitting closed."
