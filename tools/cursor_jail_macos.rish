# cursor_jail_macos.rish — start Cursor (native macOS .app) inside a
# sandbox-exec (Seatbelt) enclosure, with project-local state.
#
# The Rish-native primary launcher, reviving tools/cursor-jail-macos.sh (its
# bash elder, kept beside this one for reference and for anyone without
# Rishi built yet). Same profile, same fence -- built with Rish's own string
# joins instead of a heredoc.
#
#   rishi/bin/rishi run tools/cursor_jail_macos.rish
#   rishi/bin/rishi run tools/cursor_jail_macos.rish --no-network
#   rishi/bin/rishi run tools/cursor_jail_macos.rish --harden-home
#   rishi/bin/rishi run tools/cursor_jail_macos.rish --print-profile
#
# --harden-home closes the read side of the "no private-$HOME yet" gap
# for the credentials that actually matter: it denies reads to a named
# list of real credential stores under $HOME (~/.ssh, ~/.gnupg, ~/.aws,
# ~/.codeberg-token, and the rest -- see the harden_* lines below),
# leaving every other read exactly as open as the default profile.
# Before launching with this flag, generate and register dedicated
# jail-local keys with tools/generate_jail_local_keys_macos.rish, run
# from an ordinary terminal outside any jail -- see
# manual/guides/macos-ai-jail-setup.md.
# Three hard-won launch facts, each proven on this host 20260714 (the full
# forensic trail lives in the session logs and the guide):
#
#   1. Exec the app binary directly, never the `cursor` CLI wrapper. The
#      wrapper (ELECTRON_RUN_AS_NODE + cli.js) spawns the real app in a
#      detached dance that dies silently under Seatbelt (bootstrap_check_in
#      "Permission denied"), exits 0, and launches nothing.
#   2. Pass --no-sandbox. Chromium's own internal sandbox cannot nest
#      inside Seatbelt -- the GPU and network helpers abort and take the
#      app down ("GPU process isn't usable. Goodbye."). This is the same
#      law SOURCE.md Step 9 already names for Linux, where Chromium's
#      sandbox cannot nest inside bwrap either. Seatbelt is the boundary.
#   3. The Mach/IPC/pty allowances below follow the static profile section
#      of upstream ai-jail's own macOS seatbelt backend (see
#      gratitude/ai-jail/) -- Electron aborts at bootstrap_check_in of its
#      MachPortRendezvousServer without mach-register.
#
# What this gives you, and what it does not:
#   - Writes are fenced to the project directory and its own state dirs.
#   - Reads stay open everywhere (the write fence is the real boundary),
#     unless --harden-home is passed, which denies reads to the named
#     real credential stores (~/.ssh, ~/.gnupg, ~/.aws, and the rest)
#     while leaving every other read exactly as open.
#   - Network is allowed by default; --no-network denies it outright.
#   - There is no full macOS equivalent of --private-home: outside the
#     --harden-home credential-store list, reads of your real $HOME stay
#     open inside the sandbox.
#   - First launch opens signed out: your normal login lives in the
#     default profile (~/Library/Application Support/Cursor), outside this
#     fence. Sign in once inside the jail; that state persists in
#     .cursor-state/ (gitignored), inside the fence.
#
# See: manual/guides/macos-ai-jail-setup.md, SOURCE.md Step 6/9.

let sandbox_check = run ["sh" "-c" "command -v sandbox-exec"]
assert sandbox_check.ok else "sandbox-exec not found -- this script is macOS-only."

let app_bin = "/Applications/Cursor.app/Contents/MacOS/Cursor"
let app_check = run ["test" "-x" app_bin]
assert app_check.ok else "Cursor.app not found at /Applications/Cursor.app -- install Cursor, or launch via the bash elder with CURSOR_BIN set in tools/enclosure.conf."

let pwd_run = run ["pwd"]
let repo = trim pwd_run.out

let state_mk = run ["mkdir" "-p" "${repo}/.cursor-state/user-data" "${repo}/.cursor-state/extensions" "${repo}/tools/.build"]
assert state_mk.ok else "could not create .cursor-state/ or tools/.build/"

let print_only = args contains "--print-profile"
let no_network = args contains "--no-network"
let harden_home = args contains "--harden-home"

if no_network then let net_line = "(deny network*)" else let net_line = "(allow network*)"

let home = env "HOME"

# A literal double quote, from a one-byte fixture -- Rish string literals
# have no \" escape (named as a real language gap, same shape as the
# newline fixture the WireGuard client script already relies on), so SBPL's
# own quoted path syntax is built by joining fragments around this fixture
# rather than by escaping inside a string literal.
let dq = read-file "tools/fixtures/dquote.txt"
let nl = read-file "tools/fixtures/newline.txt"

# Apple's Seatbelt resolves an overlapping allow/deny pair to deny,
# regardless of which rule is written first or which is more specific
# (proven on this host: an (allow file-read* (literal ...)) placed
# *before* an overlapping (deny file-read* (regex ...)) still denies).
# So this list names only the specific credential stores themselves --
# no blanket dotfile deny, no allow-back needed, no risk of silently
# also denying non-secret dotfiles (~/.gitconfig, shell rc) that a
# normal terminal and git identity depend on.
if harden_home then let harden_b = "; --harden-home: deny reads on the specific real credential stores" else let harden_b = ""
if harden_home then let harden_c = "; under $HOME -- SSH/GPG private keys, cloud and forge tokens. Deny" else let harden_c = ""
if harden_home then let harden_d = "; always wins an overlap on this host, so the list stays a deny-only," else let harden_d = ""
if harden_home then let harden_e = "; named set rather than a blanket dotfile deny with an allow-back." else let harden_e = ""
if harden_home then let harden_f = join ["(deny file-read* (subpath " dq home "/.ssh" dq "))"] "" else let harden_f = ""
if harden_home then let harden_g = join ["(deny file-read* (subpath " dq home "/.gnupg" dq "))"] "" else let harden_g = ""
if harden_home then let harden_h = join ["(deny file-read* (subpath " dq home "/.aws" dq "))"] "" else let harden_h = ""
if harden_home then let harden_i = join ["(deny file-read* (subpath " dq home "/.config/gh" dq "))"] "" else let harden_i = ""
if harden_home then let harden_j = join ["(deny file-read* (subpath " dq home "/.terraform.d" dq "))"] "" else let harden_j = ""
if harden_home then let harden_k = join ["(deny file-read* (subpath " dq home "/.docker" dq "))"] "" else let harden_k = ""
if harden_home then let harden_l = join ["(deny file-read* (subpath " dq home "/.kube" dq "))"] "" else let harden_l = ""
if harden_home then let harden_m = join ["(deny file-read* (subpath " dq home "/.azure" dq "))"] "" else let harden_m = ""
if harden_home then let harden_n = join ["(deny file-read* (subpath " dq home "/.gcloud" dq "))"] "" else let harden_n = ""
if harden_home then let harden_o = join ["(deny file-read* (literal " dq home "/.codeberg-token" dq "))"] "" else let harden_o = ""
if harden_home then let harden_p = join ["(deny file-read* (literal " dq home "/.netrc" dq "))"] "" else let harden_p = ""
if harden_home then let harden_q = join ["(deny file-read* (literal " dq home "/.git-credentials" dq "))"] "" else let harden_q = ""
if harden_home then let harden_r = join ["(deny file-read* (literal " dq home "/.npmrc" dq "))"] "" else let harden_r = ""

let line_a = "(version 1)"
let line_b = "(deny default)"
let line_c = ""
let line_d = "; Reads stay open everywhere -- enumerating every toolchain read path"
let line_e = "; is a maintenance trap; the write fence below is the real boundary."
let line_f = "(allow file-read*)"
let line_g = ""
let line_h = "; Writes fenced to the project directory and its own state."
let line_i = "(allow file-write*"
let line_j = join ["  (subpath " dq repo dq ")"] ""
let line_k = join ["  (subpath " dq "/tmp" dq ")"] ""
let line_l = join ["  (subpath " dq "/private/tmp" dq ")"] ""
let line_m = join ["  (subpath " dq "/private/var/folders" dq "))"] ""
let line_n = ""
let line_o = "; Process operations."
let line_p = "(allow process-exec)"
let line_q = "(allow process-fork)"
let line_r = "(allow process-info* (target same-sandbox))"
let line_s = "(allow signal)"
let line_t = "(allow sysctl-read)"
let line_u = ""
let line_v = "; Mach and POSIX IPC -- Electron registers a MachPortRendezvousServer at"
let line_w = "; startup (bootstrap_check_in), aborting outright without mach-register;"
let line_x = "; the rest follows upstream ai-jail's own proven macOS static section."
let line_y = "(allow mach-lookup)"
let line_z = "(allow mach-register)"
let line_aa = "(allow mach-host*)"
let line_ab = "(allow mach-task-name)"
let line_ac = "(allow ipc-posix-shm-read-data)"
let line_ad = "(allow ipc-posix-shm-write-data)"
let line_ae = "(allow ipc-posix-shm-read-metadata)"
let line_af = "(allow ipc-posix-shm-write-create)"
let line_ag = "(allow ipc-posix-sem)"
let line_ah = ""
let line_ai = "; Pseudo-terminals (integrated terminal) and standard devices."
let line_aj = "(allow pseudo-tty)"
let line_ak = "(allow file-ioctl)"
let line_al = join ["(allow file-read* file-write* (literal " dq "/dev/ptmx" dq "))"] ""
let line_am = join ["(allow file-read* file-write* (regex #" dq "^/dev/ttys[0-9]+" dq "))"] ""
let line_an = join ["(allow file-write* (literal " dq "/dev/null" dq "))"] ""
let line_ao = join ["(allow file-write* (literal " dq "/dev/zero" dq "))"] ""
let line_ap = join ["(allow file-write* (literal " dq "/dev/random" dq "))"] ""
let line_aq = join ["(allow file-write* (literal " dq "/dev/urandom" dq "))"] ""
let line_ar = ""
let line_as = "(allow iokit-open)"
let line_at = ""

let profile_lines = [line_a line_b line_c line_d line_e line_f harden_b harden_c harden_d harden_e harden_f harden_g harden_h harden_i harden_j harden_k harden_l harden_m harden_n harden_o harden_p harden_q harden_r line_g line_h line_i line_j line_k line_l line_m line_n line_o line_p line_q line_r line_s line_t line_u line_v line_w line_x line_y line_z line_aa line_ab line_ac line_ad line_ae line_af line_ag line_ah line_ai line_aj line_ak line_al line_am line_an line_ao line_ap line_aq line_ar line_as line_at net_line]
let profile = join profile_lines nl

if print_only then say profile
if print_only then exit exit-ok

let profile_path = "tools/.build/cursor_jail_macos_profile.sbpl"
write-file profile_path profile

# --new-window stays as belt-and-suspenders: with a distinct user-data-dir
# the app is its own instance anyway, but this guards against any future
# wrapper-style forwarding to an already-running unsandboxed Cursor.
#
# The one-line host seam below exists for stdio survival: a spawned child
# inherits pipes for stdout/stderr that die when this script exits, and
# Electron logs constantly -- the app boots, then takes a SIGPIPE a few
# seconds in and dies (observed on this host: alive at 12s, gone by 20s).
# exec + /dev/null redirects + nohup make the jailed app independent of
# both this script's lifetime and the launching terminal's.
let launch = spawn ["sh" "-c" "exec nohup sandbox-exec -f ${profile_path} -- ${app_bin} --no-sandbox --user-data-dir=${repo}/.cursor-state/user-data --extensions-dir=${repo}/.cursor-state/extensions --new-window ${repo} >/dev/null 2>&1 </dev/null"]

say "cursor-jail-macos: launched inside the sandbox-exec enclosure."
say "  project: ${repo}"
say "  state:   ${repo}/.cursor-state/"
if no_network then say "  network: denied" else say "  network: allowed"
if harden_home then say "  home:    hardened -- real ~/.ssh, ~/.gnupg, ~/.aws, and the other"
if harden_home then say "           named credential stores are unreadable inside this window"
say "First run opens signed out (your normal login lives outside the fence);"
say "sign in once inside the jail and it persists in .cursor-state/."
say "This script returns immediately; Cursor keeps running on its own."
