# chrono_version_scan_chunk.rish — scan one roster chunk (≤256 paths).
#
# Reads tools/.cache/chrono-chunk.txt (one path per line). Driver:
#   tools/fixtures/chrono_version_scan.rish
# Run from the repository root.

let files = where (lines (read-file "tools/.cache/chrono-chunk.txt")) as f: f != ""

let scans = map files as f: { path: f, hits: length (where (where (lines (read-file f)) as ln: ln starts-with "**Version:") as ln2: ln2 contains "`v0.") + length (where (where (lines (read-file f)) as ln: ln starts-with "**Version:") as ln2: ln2 contains "`v1.") + length (where (where (lines (read-file f)) as ln: ln starts-with "**Version:") as ln2: ln2 contains "`v2.") + length (where (where (lines (read-file f)) as ln: ln starts-with "**Version:") as ln2: ln2 contains "`v3.") + length (where (where (lines (read-file f)) as ln: ln starts-with "**Version:") as ln2: ln2 contains "`v4.") + length (where (where (lines (read-file f)) as ln: ln starts-with "**Version:") as ln2: ln2 contains "`v5.") + length (where (where (lines (read-file f)) as ln: ln starts-with "**Version:") as ln2: ln2 contains "`v6.") + length (where (where (lines (read-file f)) as ln: ln starts-with "**Version:") as ln2: ln2 contains "`v7.") + length (where (where (lines (read-file f)) as ln: ln starts-with "**Version:") as ln2: ln2 contains "`v8.") + length (where (where (lines (read-file f)) as ln: ln starts-with "**Version:") as ln2: ln2 contains "`v9.") + length (where (where (lines (read-file f)) as ln: ln starts-with "**Version:") as ln2: ln2 contains "`0.") + length (where (where (lines (read-file f)) as ln: ln starts-with "**Version:") as ln2: ln2 contains "`1.") + length (where (where (lines (read-file f)) as ln: ln starts-with "**Version:") as ln2: ln2 contains "`2.") + length (where (where (lines (read-file f)) as ln: ln starts-with "**Version:") as ln2: ln2 contains "`3.") + length (where (where (lines (read-file f)) as ln: ln starts-with "**Version:") as ln2: ln2 contains "`4.") + length (where (where (lines (read-file f)) as ln: ln starts-with "**Version:") as ln2: ln2 contains "`5.") + length (where (where (lines (read-file f)) as ln: ln starts-with "**Version:") as ln2: ln2 contains "`6.") + length (where (where (lines (read-file f)) as ln: ln starts-with "**Version:") as ln2: ln2 c