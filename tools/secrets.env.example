# secrets.env — API keys and other credentials for launch scripts.
#
# Copy to tools/secrets.env and fill in YOUR values. The real file is gitignored;
# only this .example is committed.
#
#   cp tools/secrets.env.example tools/secrets.env
#   chmod 600 tools/secrets.env
#   $EDITOR tools/secrets.env
#
# launch-zed.sh sources this automatically before starting Zed in ai-jail.
#
# Create an Anthropic API key:
#   https://console.anthropic.com/settings/keys
#   → Create Key → copy the sk-ant-... value once (it is shown only at creation).
#
# WARNING: ai-jail mounts the whole project read-write. Any file here is visible
# to agents running inside the jail. Prefer a dedicated project key with spend
# limits; rotate if the sandbox ever leaks a log or screenshot.

ANTHROPIC_API_KEY="sk-ant-api03-REPLACE_ME"
