//! Bounded string builder helpers for markdown output.

const std = @import("std");

pub fn append_fmt(a: std.mem.Allocator, out: *std.ArrayListUnmanaged(u8), comptime fmt: []const u8, args: anytype) !void {
    const s = try std.fmt.allocPrint(a, fmt, args);
    defer a.free(s);
    try out.appendSlice(a, s);
}
