let xact_flip_rye = "glow/.cache/gate_xact_flip_welcome.rye"
let xact_flip_bin = "glow/bin/gate_xact_flip_welcome"
let build_xf = run ["sh" "-c" "env RYE_ZIG=${zig} rye/bin/rye build ${xact_flip_rye} -femit-bin=${xact_flip_bin}"]
