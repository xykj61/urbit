let xfer_flip_bin = "glow/bin/gate_xfer_flip_welcome"
let build_xff = run ["sh" "-c" "env RYE_ZIG=${zig} rye/bin/rye build ${xfer_flip_rye} -femit-bin=${xfer_flip_bin}"]
