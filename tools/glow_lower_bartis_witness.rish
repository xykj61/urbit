let kind_flip_rye = "glow/.cache/gate_kind_flip_welcome.rye"
let kind_flip_bin = "glow/bin/gate_kind_flip_welcome"
let build_kf = run ["sh" "-c" "env RYE_ZIG=${zig} rye/bin/rye build ${kind_flip_rye} -femit-bin=${kind_flip_bin}"]
