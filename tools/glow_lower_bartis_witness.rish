let xact_rye = "glow/.cache/gate_xact_welcome.rye"
let xact_bin = "glow/bin/gate_xact_welcome"
let build_xact = run ["sh" "-c" "env RYE_ZIG=${zig} rye/bin/rye build ${xact_rye} -femit-bin=${xact_bin}"]
assert build_xact.ok else "bartis xact-mold welcome .rye build failed"
