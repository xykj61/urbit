# glow_lower_bartis_witness.rish — `|=` bartis lowers to Rye; emitted program runs.
#
# Proves rune_bartis parses the identity gate, lower_bartis emits correct Rye,
# and the welcome binary exits 0 with baked sample 5.
#
#   rishi/bin/rishi run tools/glow_lower_bartis_witness.rish

let zig = "vendor/zig-toolchain/zig"
let bin = "glow/bin/lower_bartis_witness"
let welcome_rye = "glow/.cache/gate_sample_welcome.rye"
let welcome_bin = "glow/bin/gate_sample_welcome"

let build = run ["sh" "-c" "mkdir -p glow/bin glow/.cache && env RYE_ZIG=${zig} rye/bin/rye build glow/lower_bartis_witness.rye -femit-bin=${bin}"]
assert build.ok else "lower_bartis_witness build failed: ${build.err}${build.out}"

let selftest = run ["sh" "-c" "${bin} 2>&1"]
assert selftest.ok else "lower_bartis_witness exited non-zero"
assert selftest.out contains "GREEN" else "lower_bartis_witness not GREEN"
assert selftest.out contains "identity gate" else "lower_bartis_witness missing identity claim"
assert selftest.out contains "comment line" else "lower_bartis_witness missing comment-line claim"
assert selftest.out contains "SampleDoesNotNest" else "lower_bartis_witness missing nest-refuse claim"
assert selftest.out contains "BodyFaceMismatch" else "lower_bartis_witness missing mismatch-refuse claim"
assert selftest.out contains "gate-sample.glow" else "lower_bartis_witness missing gen desk claim"
assert selftest.out contains "argv-sample" else "lower_bartis_witness missing argv-sample claim"
assert selftest.out contains "gate-sample-u32.glow" else "lower_bartis_witness missing argv gen desk claim"
assert selftest.out contains "call-body double" else "lower_bartis_witness missing call-body claim"
assert selftest.out contains "gate-double.glow" else "lower_bartis_witness missing gate-double desk claim"
assert selftest.out contains "call-body inc" else "lower_bartis_witness missing call-body inc claim"
assert selftest.out contains "call-body dec" else "lower_bartis_witness missing call-body dec claim"
assert selftest.out contains "gate-inc.glow" else "lower_bartis_witness missing gate-inc desk claim"
assert selftest.out contains "gate-dec.glow" else "lower_bartis_witness missing gate-dec desk claim"
assert selftest.out contains "BodyGateNotYetLowered" else "lower_bartis_witness missing unknown-gate refuse"
assert selftest.out contains "BodySampleMismatch" else "lower_bartis_witness missing sample-mismatch refuse"
assert selftest.out contains "amount-shape" else "lower_bartis_witness missing amount-shape claim"
assert selftest.out contains "gate-amount.glow" else "lower_bartis_witness missing gate-amount desk"
assert selftest.out contains "count-shape" else "lower_bartis_witness missing count-shape claim"
assert selftest.out contains "gate-count.glow" else "lower_bartis_witness missing gate-count desk"
assert selftest.out contains "KindShape" else "lower_bartis_witness missing KindShape claim"
assert selftest.out contains "gate-kind.glow" else "lower_bartis_witness missing gate-kind desk"
assert selftest.out contains "XactShape" else "lower_bartis_witness missing XactShape claim"
assert selftest.out contains "gate-xact.glow" else "lower_bartis_witness missing gate-xact desk"
assert selftest.out contains "XferShape" else "lower_bartis_witness missing XferShape claim"
assert selftest.out contains "gate-xfer.glow" else "lower_bartis_witness missing gate-xfer desk"
assert selftest.out contains "PairShape" else "lower_bartis_witness missing PairShape claim"
assert selftest.out contains "gate-pair.glow" else "lower_bartis_witness missing gate-pair desk"
assert selftest.out contains "gate-triple.glow" else "lower_bartis_witness missing gate-triple desk"
assert selftest.out contains "gate-quad.glow" else "lower_bartis_witness missing gate-quad desk"
assert selftest.out contains "QuadShape" else "lower_bartis_witness missing QuadShape claim"
assert selftest.out contains "gate-penta.glow" else "lower_bartis_witness missing gate-penta desk"
assert selftest.out contains "PentaShape" else "lower_bartis_witness missing PentaShape claim"
assert selftest.out contains "gate-hexa.glow" else "lower_bartis_witness missing gate-hexa desk"
assert selftest.out contains "HexaShape" else "lower_bartis_witness missing HexaShape claim"
assert selftest.out contains "gate-hepta.glow" else "lower_bartis_witness missing gate-hepta desk"
assert selftest.out contains "HeptaShape" else "lower_bartis_witness missing HeptaShape claim"
assert selftest.out contains "gate-octa.glow" else "lower_bartis_witness missing gate-octa desk"
assert selftest.out contains "OctaShape" else "lower_bartis_witness missing OctaShape claim"
assert selftest.out contains "gate-nona.glow" else "lower_bartis_witness missing gate-nona desk"
assert selftest.out contains "NonaShape" else "lower_bartis_witness missing NonaShape claim"
assert selftest.out contains "deca-shape" else "lower_bartis_witness missing deca-shape refuse"
assert selftest.out contains "hepta-shape argv refused" else "lower_bartis_witness missing hepta argv refuse"
assert selftest.out contains "octa-shape argv refused" else "lower_bartis_witness missing octa argv refuse"
assert selftest.out contains "nona-shape argv refused" else "lower_bartis_witness missing nona argv refuse"
assert selftest.out contains "gate-nona-flip.glow" else "lower_bartis_witness missing nona-flip desk"
assert selftest.out contains "nona-shape call-body flip" else "lower_bartis_witness missing nona flip claim"
assert selftest.out contains "nona-shape double call-body refused" else "lower_bartis_witness missing nona double refuse"
assert selftest.out contains "gate-octa-flip.glow" else "lower_bartis_witness missing octa-flip desk"
assert selftest.out contains "octa-shape call-body flip" else "lower_bartis_witness missing octa flip claim"
assert selftest.out contains "octa-shape double call-body refused" else "lower_bartis_witness missing octa double refuse"
assert selftest.out contains "gate-hepta-flip.glow" else "lower_bartis_witness missing hepta-flip desk"
assert selftest.out contains "hepta-shape call-body flip" else "lower_bartis_witness missing hepta flip claim"
assert selftest.out contains "hepta-shape double call-body refused" else "lower_bartis_witness missing hepta double refuse"
assert selftest.out contains "hexa-shape argv refused" else "lower_bartis_witness missing hexa argv refuse"
assert selftest.out contains "gate-hexa-flip.glow" else "lower_bartis_witness missing hexa-flip desk"
assert selftest.out contains "hexa-shape call-body flip" else "lower_bartis_witness missing hexa flip claim"
assert selftest.out contains "hexa-shape double call-body refused" else "lower_bartis_witness missing hexa double refuse"
assert selftest.out contains "quad-shape argv refused" else "lower_bartis_witness missing quad argv refuse"
assert selftest.out contains "penta-shape argv refused" else "lower_bartis_witness missing penta argv refuse"
assert selftest.out contains "gate-penta-flip.glow" else "lower_bartis_witness missing penta-flip desk"
assert selftest.out contains "penta-shape call-body flip" else "lower_bartis_witness missing penta flip claim"
assert selftest.out contains "penta-shape double call-body refused" else "lower_bartis_witness missing penta double refuse"
assert selftest.out contains "gate-triple-flip.glow" else "lower_bartis_witness missing triple-flip desk"
assert selftest.out contains "triple-shape call-body flip" else "lower_bartis_witness missing triple flip claim"
assert selftest.out contains "triple-shape double call-body refused" else "lower_bartis_witness missing triple double refuse"
assert selftest.out contains "gate-quad-flip.glow" else "lower_bartis_witness missing quad-flip desk"
assert selftest.out contains "quad-shape call-body flip" else "lower_bartis_witness missing quad flip claim"
assert selftest.out contains "quad-shape double call-body refused" else "lower_bartis_witness missing quad double refuse"
assert selftest.out contains "call-body flip" else "lower_bartis_witness missing kind flip claim"
assert selftest.out contains "gate-kind-flip.glow" else "lower_bartis_witness missing kind-flip desk"
assert selftest.out contains "gate-xact-flip.glow" else "lower_bartis_witness missing xact-flip desk"
assert selftest.out contains "xact-shape call-body flip" else "lower_bartis_witness missing xact flip claim"
assert selftest.out contains "gate-xfer-flip.glow" else "lower_bartis_witness missing xfer-flip desk"
assert selftest.out contains "xfer-shape call-body flip" else "lower_bartis_witness missing xfer flip claim"
assert selftest.out contains "gate-pair-flip.glow" else "lower_bartis_witness missing pair-flip desk"
assert selftest.out contains "pair-shape call-body flip" else "lower_bartis_witness missing pair flip claim"
assert selftest.out contains "gate-amount-u32.glow" else "lower_bartis_witness missing amount argv desk"
assert selftest.out contains "amount-shape argv" else "lower_bartis_witness missing amount argv claim"
assert selftest.out contains "gate-pair-fields.glow" else "lower_bartis_witness missing pair argv desk"
assert selftest.out contains "pair-shape argv emit" else "lower_bartis_witness missing pair argv claim"
assert selftest.out contains "gate-triple-fields.glow" else "lower_bartis_witness missing triple argv desk"
assert selftest.out contains "triple-shape argv emit" else "lower_bartis_witness missing triple argv claim"
assert selftest.out contains "gate-count-u32.glow" else "lower_bartis_witness missing count argv desk"
assert selftest.out contains "count-shape argv" else "lower_bartis_witness missing count argv claim"
assert selftest.out contains "gate-kind-tag.glow" else "lower_bartis_witness missing kind argv desk"
assert selftest.out contains "kind-shape argv emit" else "lower_bartis_witness missing kind argv claim"
assert selftest.out contains "gate-xact-tag.glow" else "lower_bartis_witness missing xact argv desk"
assert selftest.out contains "xact-shape argv emit" else "lower_bartis_witness missing xact argv claim"
assert selftest.out contains "gate-xfer-tag.glow" else "lower_bartis_witness missing xfer argv desk"
assert selftest.out contains "xfer-shape argv emit" else "lower_bartis_witness missing xfer argv claim"

let build_welcome = run ["sh" "-c" "env RYE_ZIG=${zig} rye/bin/rye build ${welcome_rye} -femit-bin=${welcome_bin}"]
assert build_welcome.ok else "bartis welcome .rye build failed"

let run_welcome = run ["sh" "-c" "${welcome_bin}; echo EXIT:$?"]
assert run_welcome.ok else "bartis welcome binary failed to launch"
assert run_welcome.out contains "EXIT:0" else "bartis welcome binary did not exit 0"

let argv_rye = "glow/.cache/gate_sample_argv.rye"
let argv_bin = "glow/bin/gate_sample_argv"
let build_argv = run ["sh" "-c" "env RYE_ZIG=${zig} rye/bin/rye build ${argv_rye} -femit-bin=${argv_bin}"]
assert build_argv.ok else "bartis argv .rye build failed"

let run_argv = run ["sh" "-c" "${argv_bin} 9; echo EXIT:$?"]
assert run_argv.ok else "bartis argv binary failed to launch"
assert run_argv.out contains "EXIT:0" else "bartis argv binary did not exit 0 with sample 9"

let call_rye = "glow/.cache/gate_double_welcome.rye"
let call_bin = "glow/bin/gate_double_welcome"
let build_call = run ["sh" "-c" "env RYE_ZIG=${zig} rye/bin/rye build ${call_rye} -femit-bin=${call_bin}"]
assert build_call.ok else "bartis call-body welcome .rye build failed"

let run_call = run ["sh" "-c" "${call_bin}; echo EXIT:$?"]
assert run_call.ok else "bartis call-body welcome binary failed to launch"
assert run_call.out contains "EXIT:0" else "bartis call-body welcome binary did not exit 0"

