let pair_flip_rye = "glow/.cache/gate_pair_flip_welcome.rye"
let pair_flip_bin = "glow/bin/gate_pair_flip_welcome"
let build_pf = run ["sh" "-c" "env RYE_ZIG=${zig} rye/bin/rye build ${pair_flip_rye} -femit-bin=${pair_flip_bin}"]
