assert run_call_argv.out contains "EXIT:0" else "bartis call-body argv binary did not exit 0 with sample 7"

let inc_rye = "glow/.cache/gate_inc_welcome.rye"
let inc_bin = "glow/bin/gate_inc_welcome"
let build_inc = run ["sh" "-c" "env RYE_ZIG=${zig} rye/bin/rye build ${inc_rye} -femit-bin=${inc_bin}"]
assert build_inc.ok else "bartis inc welcome .rye build failed"
let run_inc = run ["sh" "-c" "${inc_bin}; echo EXIT:$?"]
assert run_inc.ok else "bartis inc welcome binary failed to launch"
assert run_inc.out contains "EXIT:0" else "bartis inc welcome binary did not exit 0"

let dec_rye = "glow/.cache/gate_dec_welcome.rye"
let dec_bin = "glow/bin/gate_dec_welcome"
let build_dec = run ["sh" "-c" "env RYE_ZIG=${zig} rye/bin/rye build ${dec_rye} -femit-bin=${dec_bin}"]
assert build_dec.ok else "bartis dec welcome .rye build failed"
