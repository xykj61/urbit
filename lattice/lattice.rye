pub fn main(init: std.process.Init) !u8 {
    const args = try init.minimal.args.toSlice(init.arena.allocator());
    if (args.len >= 2 and std.mem.eql(u8, args[1], "selftest")) {
        try welcome_matmul();
        try welcome_add();
        try welcome_reshape();
        try welcome_reduce_sum();
        try welcome_reduce_mean();
        try welcome_scale();
        try welcome_transpose();
        try welcome_mul();
        try welcome_fill();
        try welcome_copy();
        try welcome_sub();
        try welcome_neg();
        try welcome_div();
        try welcome_abs();
        try welcome_clamp();
        try welcome_reduce_max();
        try welcome_reduce_min();
        try welcome_sqrt();
        try welcome_exp();
        try welcome_log();
        try welcome_pow();
        try welcome_relu();
        try welcome_sigmoid();
        try welcome_softmax();
        try welcome_tanh();
        try welcome_gelu();
        try welcome_silu();
        try welcome_leaky_relu();
        try welcome_softplus();
        try welcome_maximum();
        try welcome_minimum();
        try welcome_elu();
        try welcome_softsign();
        try welcome_square();
        try welcome_sign();
        try welcome_reciprocal();
        try welcome_hard_sigmoid();
        try welcome_rsqrt();
        try welcome_hardtanh();
        try welcome_cube();
        try unwelcome_shape_mismatch();
        try unwelcome_reshape_count();
        try unwelcome_reduce_shape();
        try unwelcome_reduce_mean_shape();
        try unwelcome_reduce_max_shape();
        try unwelcome_reduce_min_shape();
        try unwelcome_scale_shape();
        try unwelcome_transpose_shape();
        try unwelcome_mul_shape();
        try unwelcome_copy_shape();
        try unwelcome_sub_shape();
        try unwelcome_neg_shape();
        try unwelcome_div_shape();
        try unwelcome_div_zero();
        try unwelcome_abs_shape();
        try unwelcome_clamp_shape();
        try unwelcome_sqrt_shape();
        try unwelcome_sqrt_negative();
        try unwelcome_exp_shape();
        try unwelcome_log_shape();
        try unwelcome_log_nonpositive();
        try unwelcome_pow_shape();
        try unwelcome_pow_negative();
        try unwelcome_relu_shape();
        try unwelcome_sigmoid_shape();
        try unwelcome_softmax_shape();
        try unwelcome_tanh_shape();
        try unwelcome_gelu_shape();
        try unwelcome_silu_shape();
        try unwelcome_leaky_relu_shape();
        try unwelcome_softplus_shape();
        try unwelcome_maximum_shape();
        try unwelcome_minimum_shape();
        try unwelcome_elu_shape();
        try unwelcome_softsign_shape();
        try unwelcome_square_shape();
        try unwelcome_sign_shape();
        try unwelcome_reciprocal_shape();
        try unwelcome_reciprocal_zero();
        try unwelcome_hard_sigmoid_shape();
        try unwelcome_rsqrt_shape();
        try unwelcome_rsqrt_nonpositive();
        try unwelcome_hardtanh_shape();
        try unwelcome_cube_shape();
        try unwelcome_dim_overflow();
        print("lattice lap39: version {s} — GREEN\n", .{lattice_version});
        return 0;
    }
    print("usage: lattice selftest\n", .{});
    return 1;
}
