fn welcome_sqrt() !void {
    var src = try lc.Matrix.init(2, 2);
    src.set(0, 0, 4);
    src.set(0, 1, 9);
    src.set(1, 0, 0);
    src.set(1, 1, 16);
    var out = try lc.Matrix.init(2, 2);
    try lc.sqrt(&src, &out);
    assert(out.at(0, 0) == 2);
    assert(out.at(0, 1) == 3);
    assert(out.at(1, 0) == 0);
    assert(out.at(1, 1) == 4);
    print("lattice: sqrt 2x2 green — o00={d} o01={d}\n", .{ out.at(0, 0), out.at(0, 1) });
}

