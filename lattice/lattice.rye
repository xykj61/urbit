fn welcome_sign() !void {
    var src = try lc.Matrix.init(2, 2);
    src.set(0, 0, 3);
    src.set(0, 1, -2);
    src.set(1, 0, 0);
    src.set(1, 1, 1);
    var out = try lc.Matrix.init(2, 2);
    try lc.sign(&src, &out);
    assert(out.at(0, 0) == 1);
    assert(out.at(0, 1) == -1);
    assert(out.at(1, 0) == 0);
    assert(out.at(1, 1) == 1);
    print("lattice: sign 2x2 green — o00={d}\n", .{out.at(0, 0)});
}

fn welcome_reciprocal() !void {
    var src = try lc.Matrix.init(2, 2);
    src.set(0, 0, 2);
    src.set(0, 1, -4);
    src.set(1, 0, 1);
    src.set(1, 1, 0.5);
    var out = try lc.Matrix.init(2, 2);
    try lc.reciprocal(&src, &out);
    assert(out.at(0, 0) == 0.5);
    assert(out.at(0, 1) == -0.25);
    assert(out.at(1, 0) == 1);
    assert(out.at(1, 1) == 2);
    print("lattice: reciprocal 2x2 green — o00={d}\n", .{out.at(0, 0)});
}

fn welcome_hard_sigmoid() !void {
    var src = try lc.Matrix.init(2, 2);
