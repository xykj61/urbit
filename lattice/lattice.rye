fn welcome_cube() !void {
    var src = try lc.Matrix.init(2, 2);
    src.set(0, 0, 2);
    src.set(0, 1, -2);
    src.set(1, 0, 1);
    src.set(1, 1, 0);
    var out = try lc.Matrix.init(2, 2);
    try lc.cube(&src, &out);
    assert(out.at(0, 0) == 8);
    assert(out.at(0, 1) == -8);
    assert(out.at(1, 0) == 1);
    assert(out.at(1, 1) == 0);
    print("lattice: cube 2x2 green — o00={d}\n", .{out.at(0, 0)});
}


