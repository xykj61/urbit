fn welcome_square() !void {
    var src = try lc.Matrix.init(2, 2);
    src.set(0, 0, 2);
    src.set(0, 1, -3);
    src.set(1, 0, 0);
    src.set(1, 1, 4);
    var out = try lc.Matrix.init(2, 2);
    try lc.square(&src, &out);
    assert(out.at(0, 0) == 4);
    assert(out.at(0, 1) == 9);
    assert(out.at(1, 0) == 0);
    assert(out.at(1, 1) == 16);
    print("lattice: square 2x2 green — o00={d}\n", .{out.at(0, 0)});
