fn welcome_leaky_relu() !void {
    var src = try lc.Matrix.init(2, 2);
    src.set(0, 0, 1);
    src.set(0, 1, -1);
    src.set(1, 0, 2);
    src.set(1, 1, -2);
    var out = try lc.Matrix.init(2, 2);
    try lc.leaky_relu(&src, 0.01, &out);
    assert(out.at(0, 0) == 1);
    assert(out.at(0, 1) == -0.01);
    assert(out.at(1, 0) == 2);
    assert(out.at(1, 1) == -0.02);
    print("lattice: leaky_relu 2x2 green — o01={d}\n", .{out.at(0, 1)});
}

fn welcome_softplus() !void {
    var src = try lc.Matrix.init(2, 2);
    src.set(0, 0, 0);
    src.set(0, 1, 0);
    src.set(1, 0, 0);
    src.set(1, 1, 0);
    var out = try lc.Matrix.init(2, 2);
    try lc.softplus(&src, &out);
    assert(out.at(0, 0) > 0.69);
    assert(out.at(0, 0) < 0.70);
    assert(out.at(1, 1) > 0.69);
    assert(out.at(1, 1) < 0.70);
    print("lattice: softplus 2x2 green — o00={d}\n", .{out.at(0, 0)});
}

fn welcome_maximum() !void {
    var a = try lc.Matrix.init(2, 2);
    a.set(0, 0, 1);
    a.set(0, 1, 4);
    a.set(1, 0, 2);
    a.set(1, 1, 0);
    var b = try lc.Matrix.init(2, 2);
    b.set(0, 0, 3);
    b.set(0, 1, 1);
    b.set(1, 0, 2);
    b.set(1, 1, 5);
    var out = try lc.Matrix.init(2, 2);
    try lc.maximum(&a, &b, &out);
    assert(out.at(0, 0) == 3);
    assert(out.at(0, 1) == 4);
    assert(out.at(1, 0) == 2);
    assert(out.at(1, 1) == 5);
    print("lattice: maximum 2x2 green — o00={d}\n", .{out.at(0, 0)});
}


