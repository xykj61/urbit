fn welcome_pow() !void {
    var src = try lc.Matrix.init(2, 2);
    src.set(0, 0, 2);
    src.set(0, 1, 3);
    src.set(1, 0, 4);
    src.set(1, 1, 1);
    var out = try lc.Matrix.init(2, 2);
    try lc.pow(&src, 2.0, &out);
    assert(out.at(0, 0) == 4);
    assert(out.at(0, 1) == 9);
    assert(out.at(1, 0) == 16);
    assert(out.at(1, 1) == 1);
    print("lattice: pow 2x2 green — o00={d} o01={d}\n", .{ out.at(0, 0), out.at(0, 1) });
}

fn welcome_relu() !void {
    var src = try lc.Matrix.init(2, 2);
    src.set(0, 0, -3);
    src.set(0, 1, 4);
    src.set(1, 0, -5);
    src.set(1, 1, 0);
    var out = try lc.Matrix.init(2, 2);
    try lc.relu(&src, &out);
    assert(out.at(0, 0) == 0);
    assert(out.at(0, 1) == 4);
    assert(out.at(1, 0) == 0);
    assert(out.at(1, 1) == 0);
    print("lattice: relu 2x2 green — o00={d} o01={d}\n", .{ out.at(0, 0), out.at(0, 1) });
}

