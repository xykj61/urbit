fn welcome_softmax() !void {
    var src = try lc.Matrix.init(1, 4);
    src.set(0, 0, 0);
    src.set(0, 1, 0);
    src.set(0, 2, 0);
    src.set(0, 3, 0);
    var out = try lc.Matrix.init(1, 4);
