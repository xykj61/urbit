fn bound_status(garden: std.mem.Allocator, text: []const u8) ![]const u8 {
    if (text.len <= status_max_len) return text;
    return try garden.dupe(u8, text[0..status_max_len]);
}

fn format_prompt_status(
    garden: std.mem.Allocator,
    editor: *const window_input.LineEditor,
    transcript_full: bool,
) ![]const u8 {
    if (transcript_full) return bound_status(garden, status_full_text);
    var buf: [status_max_len + 16]u8 = undefined;
    const prompt = editor.prompt_slice();
    const msg = if (prompt.len == 0)
        try std.fmt.bufPrint(&buf, "rishi> ", .{})
    else
        try std.fmt.bufPrint(&buf, "rishi> {s}", .{prompt});
    return try garden.dupe(u8, msg);
}

fn compose_frame_lines(
    garden: std.mem.Allocator,
    transcript: *const rishi.Transcript,
    status: []const u8,
) ![]surface.SkateLine {
    const body_rows = surface.viewer_max_lines - 1;
    assert(body_rows > 0);
    const session = try rishi.session_lines(transcript, garden, body_rows);
    defer garden.free(session);
    const status_line = try bound_status(garden, status);
    const total: u32 = @intCast(session.len + 1);
    assert(total <= surface.viewer_max_lines);
    const lines = try garden.alloc(surface.SkateLine, total);
    var i: u32 = 0;
    while (i < session.len) : (i += 1) {
        lines[i] = .{ .text = session[i] };
    }
    lines[session.len] = .{ .text = status_line };
    return lines;
}

fn lines_equal(expected: []const []const u8, actual: []const surface.SkateLine) bool {
    if (expected.len != actual.len) return false;
    var i: u32 = 0;
    while (i < expected.len) : (i += 1) {
        if (!std.mem.eql(u8, expected[i], actual[i].text)) return false;
    }
    return true;
}

fn surface_action_to_editor(action: surface.KeyAction) ?window_input.Action {
    return switch (action) {
        .none => null,
        .char_ => |ch| .{ .char_ = ch },
        .backspace => .backspace,
        .submit => .submit,
    };
}

fn feed_line_through_editor(
    editor: *window_input.LineEditor,
    line: []const u8,
) void {
    for (line) |ch| {
        editor.push_char(ch);
    }
    editor.submit();
}

fn field_value(text: []const u8, key: []const u8) ?[]const u8 {
    var lines = std.mem.splitScalar(u8, text, '\n');
    while (lines.next()) |raw| {
        const line = std.mem.trim(u8, raw, " \t\r\n");
        if (line.len == 0 or line[0] == '#') continue;
        if (!std.mem.startsWith(u8, line, key)) continue;
        if (line.len == key.len) return "";
        if (line[key.len] != ' ') continue;
        return std.mem.trim(u8, line[key.len + 1 ..], " \t\r\n");
    }
    return null;
}

fn first_non_comment_line(text: []const u8) ?[]const u8 {
    var lines = std.mem.splitScalar(u8, text, '\n');
    while (lines.next()) |raw| {
        const line = std.mem.trim(u8, raw, " \t\r\n");
        if (line.len == 0 or line[0] == '#') continue;
        return line;
    }
    return null;
}

/// Compose a Skate frame from local MALA mint + WOV exit-bundle fixtures.
/// No network, no new input, no Pond policy — Realidream thin-view exception.
fn compose_thin_view_lines(garden: std.mem.Allocator, io: std.Io) ![]surface.SkateLine {
    const cwd = std.Io.Dir.cwd();
    var mint_buf: [512]u8 = undefined;
    const mint = try cwd.readFile(io, mala_mint_fixture, &mint_buf);
    var wov_buf: [1024]u8 = undefined;
    const wov = try cwd.readFile(io, wov_bundle_fixture, &wov_buf);

    const amount = field_value(mint, "amount") orelse return error.BadMintFixture;
    const stamp = field_value(mint, "stamp") orelse return error.BadMintFixture;
    const memo = field_value(mint, "memo") orelse return error.BadMintFixture;
    if (!std.mem.eql(u8, memo, "mala:mint")) return error.BadMintFixture;

    const header = first_non_comment_line(wov) orelse return error.BadWovFixture;
    if (!std.mem.eql(u8, header, "wov-exit-bundle/v1")) return error.BadWovFixture;
    const seq = field_value(wov, "seq") orelse return error.BadWovFixture;
    const conservation = blk: {
        var lines = std.mem.splitScalar(u8, wov, '\n');
        while (lines.next()) |raw| {
            const line = std.mem.trim(u8, raw, " \t\r\n");
            if (std.mem.startsWith(u8, line, "conservation ")) break :blk line;
        }
        return error.BadWovFixture;
    };

    const lines = try garden.alloc(surface.SkateLine, thin_view_max_lines);
    lines[0] = .{ .text = try garden.dupe(u8, "realidream thin view") };
    lines[1] = .{ .text = try std.fmt.allocPrint(garden, "mala:mint amount {s}", .{amount}) };
    lines[2] = .{ .text = try std.fmt.allocPrint(garden, "stamp {s}", .{stamp}) };
    lines[3] = .{ .text = try std.fmt.allocPrint(garden, "wov-exit-bundle/v1 seq {s}", .{seq}) };
    lines[4] = .{ .text = try garden.dupe(u8, conservation) };
    return lines;
}

fn run_thin_view_witness(garden: std.mem.Allocator, io: std.Io) !u8 {
    const empty = try garden.alloc(surface.SkateLine, 1);
    empty[0] = .{ .text = "" };
    const sig_empty = try surface.content_signature(garden, empty);

    const frame = try compose_thin_view_lines(garden, io);
    defer {
        var i: u32 = 0;
        while (i < frame.len) : (i += 1) garden.free(frame[i].text);
        garden.free(frame);
    }
    assert(frame.len == thin_view_max_lines);
    const sig = try surface.content_signature(garden, frame);
    assert(sig != sig_empty);

    const golden = [_][]const u8{
        "realidream thin view",
        "mala:mint amount 1000",
        "stamp 20260709.182354",
        "wov-exit-bundle/v1 seq 1",
        "conservation 1000 issued 1000 redeemed 0",
    };
    assert(lines_equal(&golden, frame));

    // Unwelcome — missing fixture path refuses.
    const cwd = std.Io.Dir.cwd();
    var probe: [8]u8 = undefined;
    if (cwd.readFile(io, "tools/fixtures/does_not_exist_thin_view.bron", &probe)) |_| {
        return error.UnwelcomePassed;
    } else |_| {}

    var out: [160]u8 = undefined;
    const msg = try std.fmt.bufPrint(
        &out,
        "drawn terminal thin view: sig={x} lines={d} — GREEN\n",
        .{ sig, frame.len },
    );
    try std.Io.File.stdout().writeStreamingAll(io, msg);
    return 0;
}

/// Fold Greencandy journal fixture into debit-positive nets (cash, revenue, expense, equity).
fn fold_greencandy_fixture(text: []const u8, nets: *[4]i64) !void {
    nets.* = .{ 0, 0, 0, 0 };
    var blocks = std.mem.splitSequence(u8, text, "---");
    while (blocks.next()) |raw| {
        const block = std.mem.trim(u8, raw, " \t\r\n");
        if (block.len == 0) continue;
        var debit_i: ?u32 = null;
        var credit_i: ?u32 = null;
        var amount: i64 = 0;
        var lines = std.mem.splitScalar(u8, block, '\n');
        while (lines.next()) |line_raw| {
            const line = std.mem.trim(u8, line_raw, " \t\r\n");
            if (line.len == 0 or line[0] == '#') continue;
            const space = std.mem.indexOfScalar(u8, line, ' ') orelse return error.BadJournal;
            const key = line[0..space];
            const value = std.mem.trim(u8, line[space + 1 ..], " \t\r\n");
            if (std.mem.eql(u8, key, "debit")) {
                debit_i = account_index(value) orelse return error.BadJournal;
            } else if (std.mem.eql(u8, key, "credit")) {
                credit_i = account_index(value) orelse return error.BadJournal;
            } else if (std.mem.eql(u8, key, "amount")) {
                amount = tally_parse_int.parse_int(i64, value, .{ .base = 10, .allow_leading_zero = true }) catch return error.BadJournal;
            }
        }
        const debit = debit_i orelse return error.BadJournal;
        const credit = credit_i orelse return error.BadJournal;
        if (amount <= 0 or debit == credit) return error.BadJournal;
        nets[debit] += amount;
        nets[credit] -= amount;
    }
    var sum: i64 = 0;
    var i: u32 = 0;
    while (i < 4) : (i += 1) sum += nets[i];
    if (sum != 0) return error.BadJournal;
}

fn account_index(name: []const u8) ?u32 {
    if (std.mem.eql(u8, name, "cash")) return 0;
    if (std.mem.eql(u8, name, "revenue")) return 1;
    if (std.mem.eql(u8, name, "expense")) return 2;
    if (std.mem.eql(u8, name, "equity")) return 3;
    return null;
}

fn income_from_nets(nets: *const [4]i64) struct { revenue: i64, expense: i64, net: i64 } {
    const revenue = -nets[1];
    const expense = nets[2];
    return .{ .revenue = revenue, .expense = expense, .net = revenue - expense };
}

fn balance_from_nets(nets: *const [4]i64) struct { cash: i64, equity: i64, retained: i64 } {
    const pl = income_from_nets(nets);
    return .{
        .cash = nets[0],
        .equity = -nets[3],
        .retained = pl.net,
    };
}

fn compose_books_view_lines(garden: std.mem.Allocator, io: std.Io) ![]surface.SkateLine {
    const cwd = std.Io.Dir.cwd();
    var buf: [2048]u8 = undefined;
    const text = try cwd.readFile(io, greencandy_journal_fixture, &buf);
    var nets: [4]i64 = undefined;
    try fold_greencandy_fixture(text, &nets);
    const pl = income_from_nets(&nets);
    const bs = balance_from_nets(&nets);
    assert(bs.cash == bs.equity + bs.retained);

    const lines = try garden.alloc(surface.SkateLine, books_view_max_lines);
    lines[0] = .{ .text = try garden.dupe(u8, "greencandy books view") };
    lines[1] = .{ .text = try std.fmt.allocPrint(garden, "cash {d}", .{nets[0]}) };
    lines[2] = .{ .text = try std.fmt.allocPrint(garden, "revenue {d}", .{nets[1]}) };
    lines[3] = .{ .text = try std.fmt.allocPrint(garden, "expense {d}", .{nets[2]}) };
    lines[4] = .{ .text = try std.fmt.allocPrint(garden, "equity {d}", .{nets[3]}) };
    lines[5] = .{ .text = try std.fmt.allocPrint(garden, "P&L net {d}", .{pl.net}) };
    lines[6] = .{ .text = try std.fmt.allocPrint(garden, "BS cash {d} retained {d}", .{ bs.cash, bs.retained }) };
    lines[7] = .{ .text = try garden.dupe(u8, "conservation 0") };
    return lines;
}

fn run_books_view_witness(garden: std.mem.Allocator, io: std.Io) !u8 {
    const empty = try garden.alloc(surface.SkateLine, 1);
    empty[0] = .{ .text = "" };
    const sig_empty = try surface.content_signature(garden, empty);

    const frame = try compose_books_view_lines(garden, io);
    defer {
        var i: u32 = 0;
        while (i < frame.len) : (i += 1) garden.free(frame[i].text);
        garden.free(frame);
    }
    assert(frame.len == books_view_max_lines);
    const sig = try surface.content_signature(garden, frame);
    assert(sig != sig_empty);

    const golden = [_][]const u8{
        "greencandy books view",
        "cash 800",
        "revenue -1000",
        "expense 200",
        "equity 0",
        "P&L net 800",
        "BS cash 800 retained 800",
        "conservation 0",
    };
    assert(lines_equal(&golden, frame));

    var out: [160]u8 = undefined;
    const msg = try std.fmt.bufPrint(
        &out,
        "drawn terminal books view: sig={x} lines={d} — GREEN\n",
        .{ sig, frame.len },
    );
    try std.Io.File.stdout().writeStreamingAll(io, msg);
    return 0;
}

/// Unified sight — carriage facts (MALA/WOV) + books fold (Greencandy) on one Skate frame.
fn compose_sight_view_lines(garden: std.mem.Allocator, io: std.Io) ![]surface.SkateLine {
    const cwd = std.Io.Dir.cwd();
    var mint_buf: [512]u8 = undefined;
    const mint = try cwd.readFile(io, mala_mint_fixture, &mint_buf);
    var wov_buf: [1024]u8 = undefined;
    const wov = try cwd.readFile(io, wov_bundle_fixture, &wov_buf);
    var journal_buf: [2048]u8 = undefined;
    const journal = try cwd.readFile(io, greencandy_journal_fixture, &journal_buf);

    const amount = field_value(mint, "amount") orelse return error.BadMintFixture;
    const seq = field_value(wov, "seq") orelse return error.BadWovFixture;
    const conservation = blk: {
        var wov_lines = std.mem.splitScalar(u8, wov, '\n');
        while (wov_lines.next()) |raw| {
            const line = std.mem.trim(u8, raw, " \t\r\n");
            if (std.mem.startsWith(u8, line, "conservation ")) break :blk line;
        }
        return error.BadWovFixture;
    };

    var nets: [4]i64 = undefined;
    try fold_greencandy_fixture(journal, &nets);
    const pl = income_from_nets(&nets);
    const bs = balance_from_nets(&nets);
    assert(bs.cash == bs.equity + bs.retained);

    var entries: [greencandy.max_entries]greencandy.Entry = undefined;
    var entry_count: u32 = 0;
    try greencandy.parse_journal(journal, &entries, &entry_count);
    if (entry_count != 2) return error.BadJournal;

    var tb_sum: i64 = 0;
    {
        var ti: u32 = 0;
        while (ti < 4) : (ti += 1) tb_sum += nets[ti];
    }

    const lines = try garden.alloc(surface.SkateLine, sight_view_max_lines);
    lines[0] = .{ .text = try garden.dupe(u8, "linengrow sight view") };
    lines[1] = .{ .text = try std.fmt.allocPrint(garden, "carriage mala:mint amount {s}", .{amount}) };
    lines[2] = .{ .text = try std.fmt.allocPrint(garden, "carriage wov seq {s}", .{seq}) };
    lines[3] = .{ .text = try garden.dupe(u8, conservation) };
    lines[4] = .{ .text = try std.fmt.allocPrint(garden, "books cash {d} retained {d} · pnl net {d} · bs equity {d} · tb {d}", .{ nets[0], bs.retained, pl.net, bs.equity, tb_sum }) };
        const ex = try greencandy_exception_summary();
    lines[5] = .{ .text = try std.fmt.allocPrint(garden, "journal entries {d} {s} · exceptions {d} · ex {s} · ex2 {s} · unk {d} bad {d} · kinds {d}", .{ entry_count, entries[0].memo, ex.count, ex.first_reason, ex.second_reason, ex.unknown_n, ex.bad_n, ex.kinds_n }) };
    lines[6] = .{ .text = try std.fmt.allocPrint(garden, "chart {s} {s} {s} {s}", .{
        greencandy.Account.cash.name(),
        greencandy.Account.revenue.name(),
        greencandy.Account.expense.name(),
        greencandy.Account.equity.name(),
    }) };
    lines[7] = .{ .text = try garden.dupe(u8, "sight fold green") };
    return lines;
}

fn run_sight_view_witness(garden: std.mem.Allocator, io: std.Io) !u8 {
    const empty = try garden.alloc(surface.SkateLine, 1);
    empty[0] = .{ .text = "" };
    const sig_empty = try surface.content_signature(garden, empty);

    const frame = try compose_sight_view_lines(garden, io);
    defer {
        var i: u32 = 0;
        while (i < frame.len) : (i += 1) garden.free(frame[i].text);
        garden.free(frame);
    }
    assert(frame.len == sight_view_max_lines);
    const sig = try surface.content_signature(garden, frame);
    assert(sig != sig_empty);

    const golden = [_][]const u8{
        "linengrow sight view",
        "carriage mala:mint amount 1000",
        "carriage wov seq 1",
        "conservation 1000 issued 1000 redeemed 0",
        "books cash 800 retained 800 · pnl net 800 · bs equity 0 · tb 0",
        "journal entries 2 stipend received · exceptions 2 · ex unknown account · ex2 bad amount · unk 1 bad 1 · kinds 2",
        "chart cash revenue expense equity",
        "sight fold green",
    };
    assert(lines_equal(&golden, frame));

    var out: [320]u8 = undefined;
    const msg = try std.fmt.bufPrint(
        &out,
        "drawn terminal sight view: journal=2 chart=4 pnl=800 equity=0 tb=0 exceptions=2 ex=unknown ex2=bad unk=1 bad=1 kinds=2 sig={x} lines={d} — GREEN\n",
        .{ sig, frame.len },
    );
    try std.Io.File.stdout().writeStreamingAll(io, msg);
    return 0;
}

fn count_corpus_kinds(text: []const u8) struct { rye: u32, rish: u32 } {
    var rye: u32 = 0;
    var rish: u32 = 0;
    var lines = std.mem.splitScalar(u8, text, '\n');
    while (lines.next()) |raw| {
        const line = std.mem.trim(u8, raw, " \t\r\n");
        if (std.mem.eql(u8, line, "kind rye")) rye += 1;
        if (std.mem.eql(u8, line, "kind rish")) rish += 1;
    }
    return .{ .rye = rye, .rish = rish };
}

/// Inference assist — Anvil corpus + Scribble snippets + Lantern + journal on one Skate frame.
fn count_scribble_fence_kinds(text: []const u8) struct { rye: u32, rish: u32 } {
    var rye: u32 = 0;
    var rish: u32 = 0;
    var lines = std.mem.splitScalar(u8, text, '\n');
    while (lines.next()) |raw| {
        const line = std.mem.trim(u8, raw, " \t\r\n");
        if (std.mem.eql(u8, line, "```rye")) rye += 1;
        if (std.mem.eql(u8, line, "```rish")) rish += 1;
    }
    return .{ .rye = rye, .rish = rish };
}

fn count_scribble_fences(text: []const u8) u32 {
    const kinds = count_scribble_fence_kinds(text);
    return kinds.rye + kinds.rish;
}

/// RW-5 assist integration — lantern band via the same `complete_fixture` ask path as tip 420.
const LanternAssistBand = struct {
    model_hash: []const u8,
    tokens_in: u32,
    tokens_out: u32,
    stopped: []const u8,
    echo: []const u8,
    user: []const u8,
    suggestion: []const u8,
};

fn ask_lantern_assist_band(garden: std.mem.Allocator, io: std.Io) !LanternAssistBand {
    const cwd = std.Io.Dir.cwd();
    var completion_buf: [1024]u8 = undefined;
    const completion_text = try cwd.readFile(io, lantern_completion_fixture, &completion_buf);
    var echo_buf: [1024]u8 = undefined;
    const echo_text = try cwd.readFile(io, lantern_echo_fixture, &echo_buf);
    var user_buf: [1024]u8 = undefined;
    const user_text = try cwd.readFile(io, lantern_user_fixture, &user_buf);

    const model_hash = "sha3-256-rye-forge-lap0";
    const resp = try lc.complete_fixture(.{
        .model_hash = model_hash,
        .prompt = "init.garden for args",
        .max_tokens = 64,
    }, completion_text);
    assert(resp.tokens_in == 24);
    assert(resp.tokens_out == 12);
    assert(resp.stopped_reason == .eos);

    _ = try lc.complete_fixture(.{
        .model_hash = model_hash,
        .prompt = "echo",
        .max_tokens = 64,
        .echo = true,
    }, echo_text);

    _ = try lc.complete_fixture(.{
        .model_hash = model_hash,
        .prompt = "user",
        .max_tokens = 64,
        .user = "steward-rio",
    }, user_text);

    return .{
        .model_hash = model_hash,
        .tokens_in = resp.tokens_in,
        .tokens_out = resp.tokens_out,
        .stopped = @tagName(resp.stopped_reason),
        .echo = "1",
        .user = "steward-rio",
        .suggestion = try garden.dupe(u8, resp.text),
    };
}

fn compose_assist_view_lines(garden: std.mem.Allocator, io: std.Io) ![]surface.SkateLine {
    const cwd = std.Io.Dir.cwd();
    var corpus_buf: [4096]u8 = undefined;
    const corpus = try cwd.readFile(io, anvil_corpus_fixture, &corpus_buf);
    var journal_buf: [2048]u8 = undefined;
    const journal = try cwd.readFile(io, greencandy_journal_fixture, &journal_buf);
    var snippets_buf: [4096]u8 = undefined;
    const snippets = try cwd.readFile(io, scribble_snippets_fixture, &snippets_buf);
    var fence_kinds_buf: [scribble.max_doc_bytes]u8 = undefined;
    const fence_kinds = try cwd.readFile(io, scribble_fence_kinds_fixture, &fence_kinds_buf);

    const kinds = count_corpus_kinds(corpus);
    assert(kinds.rye == 2);
    assert(kinds.rish == 1);
    const fences = count_scribble_fence_kinds(snippets);
    assert(fences.rye == 2);
    assert(fences.rish == 1);
    var fence_blocks: [scribble.max_blocks]scribble.Block = undefined;
    const fence_n = try scribble.parse_markdown(fence_kinds, &fence_blocks);
    const plain_kinds = scribble.count_fence_kinds(fence_blocks[0..fence_n]);
    assert(plain_kinds.plain == 1);
    assert(fence_n == 4);
    var rye_snips: [scribble.max_snippets]scribble.Snippet = undefined;
    const fence_rye = try scribble.extract_rye_snippets(fence_blocks[0..fence_n], &rye_snips);
    assert(fence_rye == 1);

    const band = try ask_lantern_assist_band(garden, io);
    defer garden.free(band.suggestion);

    var entries: [greencandy.max_entries]greencandy.Entry = undefined;
    var entry_count: u32 = 0;
    try greencandy.parse_journal(journal, &entries, &entry_count);
    if (entry_count != 2) return error.BadJournal;

    var nets: [4]i64 = undefined;
    try fold_greencandy_fixture(journal, &nets);
    const pl = income_from_nets(&nets);

    const lines = try garden.alloc(surface.SkateLine, assist_view_max_lines);
    lines[0] = .{ .text = try garden.dupe(u8, "inference assist view") };
    lines[1] = .{ .text = try std.fmt.allocPrint(garden, "corpus rye {d} rish {d}", .{ kinds.rye, kinds.rish }) };
    lines[2] = .{ .text = try std.fmt.allocPrint(garden, "snippets rye {d} rish {d} plain {d} blocks {d} fence-rye {d}", .{ fences.rye, fences.rish, plain_kinds.plain, fence_n, fence_rye }) };
    lines[3] = .{ .text = try std.fmt.allocPrint(garden, "model {s}", .{band.model_hash}) };
    lines[4] = .{ .text = try std.fmt.allocPrint(garden, "lantern {d}/{d} {s} · echo {s} · user {s}", .{ band.tokens_in, band.tokens_out, band.stopped, band.echo, band.user }) };
    lines[5] = .{ .text = try std.fmt.allocPrint(garden, "suggest {s}", .{band.suggestion}) };
    const bs = balance_from_nets(&nets);
    const ex = try greencandy_exception_summary();
    lines[6] = .{ .text = try std.fmt.allocPrint(garden, "journal {d} {s} · chart {s} {s} {s} {s} · pnl net {d} · bs equity {d} · exceptions {d} · ex {s} · ex2 {s} · unk {d} bad {d} · kinds {d}", .{
        entry_count,
        entries[0].memo,
        greencandy.Account.cash.name(),
        greencandy.Account.revenue.name(),
        greencandy.Account.expense.name(),
        greencandy.Account.equity.name(),
        pl.net,
        bs.equity,
        ex.count,
        ex.first_reason,
        ex.second_reason,
        ex.unknown_n,
        ex.bad_n,
        ex.kinds_n,
    }) };
    lines[7] = .{ .text = try garden.dupe(u8, "assist fold green") };
    return lines;
}

fn run_assist_view_witness(garden: std.mem.Allocator, io: std.Io) !u8 {
    const empty = try garden.alloc(surface.SkateLine, 1);
    empty[0] = .{ .text = "" };
    const sig_empty = try surface.content_signature(garden, empty);

    const frame = try compose_assist_view_lines(garden, io);
    defer {
        var i: u32 = 0;
        while (i < frame.len) : (i += 1) garden.free(frame[i].text);
        garden.free(frame);
    }
    assert(frame.len == assist_view_max_lines);
    const sig = try surface.content_signature(garden, frame);
    assert(sig != sig_empty);

    const golden = [_][]const u8{
        "inference assist view",
        "corpus rye 2 rish 1",
        "snippets rye 2 rish 1 plain 1 blocks 4 fence-rye 1",
        "model sha3-256-rye-forge-lap0",
        "lantern 24/12 eos · echo 1 · user steward-rio",
        "suggest use init.garden not ArgIterator",
        "journal 2 stipend received · chart cash revenue expense equity · pnl net 800 · bs equity 0 · exceptions 2 · ex unknown account · ex2 bad amount · unk 1 bad 1 · kinds 2",
        "assist fold green",
    };
    assert(lines_equal(&golden, frame));

    var out: [480]u8 = undefined;
    const msg = try std.fmt.bufPrint(
        &out,
        "drawn terminal assist view: snippets=3 rye=2 rish=1 plain=1 blocks=4 fence_rye=1 echo=1 user=steward-rio journal=2 chart=4 pnl=800 equity=0 exceptions=2 ex=unknown ex2=bad unk=1 bad=1 kinds=2 sig={x} lines={d} — GREEN\n",
        .{ sig, frame.len },
    );
    try std.Io.File.stdout().writeStreamingAll(io, msg);
    return 0;
}

/// Inference assist sight — MALA/WOV carriage + assist fold on one Skate frame.
