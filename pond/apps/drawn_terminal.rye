    assert(sig != sig_empty);

    const golden = [_][]const u8{
        "scribble rye blocks view",
        "rye 1",
        "blocks 4",
        "rye blocks combo",
        "combo fold green",
    };
    assert(lines_equal(&golden, frame));

    var out: [200]u8 = undefined;
    const msg = try std.fmt.bufPrint(
        &out,
        "drawn terminal scribble rye blocks view: rye=1 blocks=4 sig={x} lines={d} — GREEN\n",
        .{ sig, frame.len },
    );
    try std.Io.File.stdout().writeStreamingAll(io, msg);
    return 0;
}

/// Scribble rish+blocks combo — rish fence count and block count on one Skate frame.
fn compose_scribble_rish_blocks_view_lines(garden: std.mem.Allocator, io: std.Io) ![]surface.SkateLine {
    const cwd = std.Io.Dir.cwd();
    var buf: [scribble.max_doc_bytes]u8 = undefined;
    const text = try cwd.readFile(io, scribble_fence_kinds_fixture, &buf);
    var blocks: [scribble.max_blocks]scribble.Block = undefined;
    const n = try scribble.parse_markdown(text, &blocks);
    var snippets: [scribble.max_snippets]scribble.Snippet = undefined;
    const rish_n = try scribble.extract_rish_snippets(blocks[0..n], &snippets);
    if (rish_n != 1 or n != 4) return error.BadScribbleFixture;

    const lines = try garden.alloc(surface.SkateLine, scribble_rish_blocks_view_max_lines);
    lines[0] = .{ .text = try garden.dupe(u8, "scribble rish blocks view") };
    lines[1] = .{ .text = try std.fmt.allocPrint(garden, "rish {d}", .{rish_n}) };
    lines[2] = .{ .text = try std.fmt.allocPrint(garden, "blocks {d}", .{n}) };
    lines[3] = .{ .text = try garden.dupe(u8, "rish blocks combo") };
    lines[4] = .{ .text = try garden.dupe(u8, "combo fold green") };
    return lines;
}

fn run_scribble_rish_blocks_view_witness(garden: std.mem.Allocator, io: std.Io) !u8 {
    const empty = try garden.alloc(surface.SkateLine, 1);
    empty[0] = .{ .text = "" };
