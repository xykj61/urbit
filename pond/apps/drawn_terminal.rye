//! pond/apps/drawn_terminal.rye — SLC-2a Lap 3 + SLC-2b Dexter keyboard.
//!
//! Composes Rishi's live session (run_one_input + session_lines) with Brushstroke's
//! Skate surface. SLC-2b carries keyboard input through Wayland so one typed
//! line in the window runs through Rishi and redraws the frame. Inference and
//! commerce folds share the same glass under the thin-view exception.
//!
//! Build (from repo root — prefer rishi):
//!   rishi/bin/rishi run tools/fixtures/pond_build_drawn_terminal.rish
//!
//! Manual rye escape hatch: see pond/README.md
//!
//!   pond/bin/drawn-terminal              # live mirror (Wayland keyboard + stdin)
//!   pond/bin/drawn-terminal sessiontest  # headless Lap 3 witness
//!   pond/bin/drawn-terminal keyboardtest # headless SLC-2b witness
//!   pond/bin/drawn-terminal rw2collabtest  # headless RW-2 app collaboration witness
//!   pond/bin/drawn-terminal rw5collabtest  # headless RW-5 Lantern collaboration (parity tip 420)
//!   pond/bin/drawn-terminal thinviewtest   # Realidream thin view — local MALA/WOV fixtures
//!   pond/bin/drawn-terminal booksviewtest  # Greencandy books view — trial balance + P&L + BS
//!   pond/bin/drawn-terminal sightviewtest  # Linengrow sight — carriage + books on one Skate frame
//!   pond/bin/drawn-terminal assistviewtest # Inference assist — corpus + lantern + books fold (tip 428 asks complete_fixture)
//!   pond/bin/drawn-terminal assistviewsighttest # Assist sight — carriage + assist on one frame
//!   pond/bin/drawn-terminal queryviewtest  # Realidream query view — Tablecloth query-wire hits
//!   pond/bin/drawn-terminal querydeviceviewtest # Query device-wire hits → Skate
//!   pond/bin/drawn-terminal queryunifiedviewtest # Hosted + device query hits on one Skate frame
//!   pond/bin/drawn-terminal forgeviewtest  # Realidream forge view — live Amphora pour → Skate
//!   pond/bin/drawn-terminal forgedeviceviewtest # Forge device-wire fetch → Skate
//!   pond/bin/drawn-terminal forgeunifiedviewtest # Hosted pour + device fetch on one Skate frame
//!   pond/bin/drawn-terminal forgequeryviewtest # Forge Tablecloth-query hits → Skate
//!   pond/bin/drawn-terminal forgequerydeviceviewtest # Forge query device-wire hits → Skate
//!   pond/bin/drawn-terminal forgequeryunifiedviewtest # Hosted + device forge query hits
//!   pond/bin/drawn-terminal corpusviewtest # Anvil corpus query hits → Skate
//!   pond/bin/drawn-terminal corpusprefixviewtest # Anvil path_prefix query → Skate
//!   pond/bin/drawn-terminal corpusrishviewtest # Anvil rish-kind query → Skate
//!   pond/bin/drawn-terminal corpusryeprefixviewtest # Anvil rye + pond/ → Skate
//!   pond/bin/drawn-terminal corpustoolsprefixviewtest # Anvil tools/ prefix → Skate
//!   pond/bin/drawn-terminal corpuscandyprefixviewtest # Anvil greencandy/ prefix → Skate
//!   pond/bin/drawn-terminal corpusappsprefixviewtest # Anvil pond/apps/ prefix → Skate
//!   pond/bin/drawn-terminal scribbleviewtest # Scribble outline headings → Skate
//!   pond/bin/drawn-terminal scribbleparaviewtest # Scribble paragraphs → Skate
//!   pond/bin/drawn-terminal scribblefenceviewtest # Scribble fence kinds → Skate
//!   pond/bin/drawn-terminal scribbleplainviewtest # Scribble plain snippets → Skate
//!   pond/bin/drawn-terminal scribbleryeviewtest # Scribble rye snippets → Skate
//!   pond/bin/drawn-terminal scribblerishviewtest # Scribble rish snippets → Skate
//!   pond/bin/drawn-terminal scribbleh1viewtest # Scribble h1 headings → Skate
//!   pond/bin/drawn-terminal scribbleh2viewtest # Scribble h2 headings → Skate
//!   pond/bin/drawn-terminal scribbleh3viewtest # Scribble h3 headings → Skate
//!   pond/bin/drawn-terminal scribbledepthviewtest # Scribble h1/h2/h3 depth tallies → Skate
//!   pond/bin/drawn-terminal scribbletallyviewtest # Scribble headings+paragraphs tally → Skate
//!   pond/bin/drawn-terminal scribbleblocksviewtest # Scribble block count → Skate
//!   pond/bin/drawn-terminal scribblefenceheadingviewtest # Scribble fence+heading combo → Skate
