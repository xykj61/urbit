        .{ sig, frame.len },
    );
    try std.Io.File.stdout().writeStreamingAll(io, msg);
    return 0;
}

/// Realidream forge query device view — device-wire forge Tablecloth hits → Skate.
fn compose_forge_query_device_view_lines(garden: std.mem.Allocator, io: std.Io) ![]surface.SkateLine {
