/// Realidream forge query unified view — hosted + device forge Tablecloth hits on one Skate frame.
fn compose_forge_query_unified_view_lines(garden: std.mem.Allocator, io: std.Io) ![]surface.SkateLine {
    const cwd = std.Io.Dir.cwd();
    var hosted_buf: [1024]u8 = undefined;
    const hosted = try cwd.readFile(io, forge_query_hits_fixture, &hosted_buf);
    var device_buf: [1024]u8 = undefined;
    const device = try cwd.readFile(io, forge_query_device_hits_fixture, &device_buf);

    if (field_value(hosted, "wire")) |_| return error.HostedMarkedDevice;
    const device_wire = field_value(device, "wire") orelse return error.BadForgeQueryFixture;
    if (!std.mem.eql(u8, device_wire, "device")) return error.BadForgeQueryFixture;

    const h_tilak = field_value(hosted, "filter_tilak") orelse return error.BadForgeQueryFixture;
    const h_count_text = field_value(hosted, "hit_count") orelse return error.BadForgeQueryFixture;
    const h_count = tally_parse_int.parse_int(u32, h_count_text, .{}) catch return error.BadForgeQueryFixture;
    if (h_count != 2) return error.BadForgeQueryFixture;
    const h_hit = try first_hit_line(hosted);

    const d_tilak = field_value(device, "filter_tilak") orelse return error.BadForgeQueryFixture;
    const d_count_text = field_value(device, "hit_count") orelse return error.BadForgeQueryFixture;
    const d_count = tally_parse_int.parse_int(u32, d_count_text, .{}) catch return error.BadForgeQueryFixture;
    if (d_count != 2) return error.BadForgeQueryFixture;
    const d_hit = try first_hit_line(device);

    const lines = try garden.alloc(surface.SkateLine, forge_query_unified_view_max_lines);
    lines[0] = .{ .text = try garden.dupe(u8, "realidream forge query unified") };
    lines[1] = .{ .text = try std.fmt.allocPrint(garden, "hosted filter tilak {s}", .{h_tilak}) };
    lines[2] = .{ .text = try std.fmt.allocPrint(garden, "hosted hits {d}", .{h_count}) };
    lines[3] = .{ .text = try std.fmt.allocPrint(garden, "hosted hit {s}", .{h_hit}) };
    lines[4] = .{ .text = try std.fmt.allocPrint(garden, "device filter tilak {s}", .{d_tilak}) };
    lines[5] = .{ .text = try std.fmt.allocPrint(garden, "device hits {d}", .{d_count}) };
    lines[6] = .{ .text = try std.fmt.allocPrint(garden, "device hit {s}", .{d_hit}) };
    lines[7] = .{ .text = try garden.dupe(u8, "forge query unified fold green") };
    return lines;
}

fn run_forge_query_unified_view_witness(garden: std.mem.Allocator, io: std.Io) !u8 {
    const empty = try garden.alloc(surface.SkateLine, 1);
    empty[0] = .{ .text = "" };
    const sig_empty = try surface.content_signature(garden, empty);

    const frame = try compose_forge_query_unified_view_lines(garden, io);
    defer {
        var i: u32 = 0;
        while (i < frame.len) : (i += 1) garden.free(frame[i].text);
        garden.free(frame);
    }
    assert(frame.len == forge_query_unified_view_max_lines);
    const sig = try surface.content_signature(garden, frame);
    assert(sig != sig_empty);

    const golden = [_][]const u8{
        "realidream forge query unified",
        "hosted filter tilak amber-manifest",
        "hosted hits 2",
        "hosted hit peerForge amber 1 manifest.bron",
        "device filter tilak amber-manifest",
        "device hits 2",
        "device hit peerForge amber 1 manifest.bron",
        "forge query unified fold green",
    };
    assert(lines_equal(&golden, frame));

    // Unwelcome — device fixture without wire=device refused.
    const cwd = std.Io.Dir.cwd();
    var bad_buf: [1024]u8 = undefined;
    const bad = try cwd.readFile(io, forge_query_hits_fixture, &bad_buf);
    if (field_value(bad, "wire")) |_| return error.HostedMarkedDevice;

    var out: [180]u8 = undefined;
    const msg = try std.fmt.bufPrint(
        &out,
        "drawn terminal forge query unified view: sig={x} lines={d} — GREEN\n",
        .{ sig, frame.len },
    );
    try std.Io.File.stdout().writeStreamingAll(io, msg);
    return 0;
}

