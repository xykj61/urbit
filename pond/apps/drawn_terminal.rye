/// Anvil corpus sum_lines view — rye line total on Skate.
fn compose_corpus_sum_lines_view_lines(garden: std.mem.Allocator, io: std.Io) ![]surface.SkateLine {
    const cwd = std.Io.Dir.cwd();
    var buf: [4096]u8 = undefined;
    const text = try cwd.readFile(io, anvil_corpus_fixture, &buf);
    var cat: anvil.Catalog = .{};
    try anvil.parse_catalog(text, &cat);
    var hits: [anvil.max_chunks]u32 = undefined;
    const n = try anvil.query_corpus(&cat, .{ .kind = .rye }, hits[0..]);
    if (n != 2) return error.BadCorpusFixture;
    const sum = anvil.sum_lines(&cat, .{ .kind = .rye });
    if (sum != 1004) return error.BadCorpusFixture;

    const lines = try garden.alloc(surface.SkateLine, corpus_sum_lines_view_max_lines);
