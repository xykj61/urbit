/// Scribble outline view — heading extract folded onto a Skate frame.
fn compose_scribble_view_lines(garden: std.mem.Allocator, io: std.Io) ![]surface.SkateLine {
    const cwd = std.Io.Dir.cwd();
    var buf: [scribble.max_doc_bytes]u8 = undefined;
    const text = try cwd.readFile(io, scribble_outline_fixture, &buf);
    var blocks: [scribble.max_blocks]scribble.Block = undefined;
    const n = try scribble.parse_markdown(text, &blocks);
    var headings: [scribble.max_headings]scribble.Heading = undefined;
    const hn = try scribble.extract_headings(blocks[0..n], &headings);
    if (hn != 3) return error.BadScribbleFixture;

    const lines = try garden.alloc(surface.SkateLine, scribble_view_max_lines);
    lines[0] = .{ .text = try garden.dupe(u8, "scribble outline view") };
    lines[1] = .{ .text = try std.fmt.allocPrint(garden, "headings {d}", .{hn}) };
    lines[2] = .{ .text = try std.fmt.allocPrint(garden, "h{d} {s}", .{ headings[0].depth, headings[0].text_slice() }) };
    lines[3] = .{ .text = try std.fmt.allocPrint(garden, "h{d} {s}", .{ headings[1].depth, headings[1].text_slice() }) };
    lines[4] = .{ .text = try std.fmt.allocPrint(garden, "h{d} {s}", .{ headings[2].depth, headings[2].text_slice() }) };
    lines[5] = .{ .text = try garden.dupe(u8, "scribble fold green") };
    return lines;
}

