    assert(lines_equal(&golden, frame));

    // Unwelcome — hosted fixture lacks wire=device mark.
    const cwd = std.Io.Dir.cwd();
    var buf: [1024]u8 = undefined;
    const hosted = try cwd.readFile(io, forge_query_hits_fixture, &buf);
    if (field_value(hosted, "wire")) |_| return error.HostedMarkedDevice;

    var out: [180]u8 = undefined;
    const msg = try std.fmt.bufPrint(
        &out,
        "drawn terminal forge query device view: sig={x} lines={d} — GREEN\n",
        .{ sig, frame.len },
    );
    try std.Io.File.stdout().writeStreamingAll(io, msg);
    return 0;
}

