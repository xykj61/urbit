fn greencandy_exception_summary() !struct { count: u32, first_reason: []const u8, second_reason: []const u8, unknown_n: u32, bad_n: u32, kinds_n: u32 } {
    const drafts = [_][]const u8{
        "debit cash\ncredit notanaccount\namount 10\nmemo bad\nstamp 20260710.182502\n",
        "debit cash\ncredit revenue\namount 0\nmemo zero\nstamp 20260710.182502\n",
        "debit cash\ncredit revenue\namount 50\nmemo welcome\nstamp 20260710.182502\n",
    };
    var out_ex: [greencandy.max_exceptions]greencandy.Exception = undefined;
    var count: u32 = 0;
    greencandy.collect_exceptions(&drafts, &out_ex, &count);
    if (count < 2) return error.BadExceptionFixture;
    var unknown_n: u32 = 0;
    var bad_n: u32 = 0;
    var i: u32 = 0;
    while (i < count) : (i += 1) {
        if (std.mem.eql(u8, out_ex[i].reason, "unknown account")) unknown_n += 1;
        if (std.mem.eql(u8, out_ex[i].reason, "bad amount")) bad_n += 1;
    }
    var kinds_n: u32 = 0;
    if (unknown_n > 0) kinds_n += 1;
    if (bad_n > 0) kinds_n += 1;
    return .{ .count = count, .first_reason = out_ex[0].reason, .second_reason = out_ex[1].reason, .unknown_n = unknown_n, .bad_n = bad_n, .kinds_n = kinds_n };
}

/// Greencandy exception queue view — refused drafts on Skate.
fn compose_exception_view_lines(garden: std.mem.Allocator, io: std.Io) ![]surface.SkateLine {
    _ = io;
    const drafts = [_][]const u8{
        \\debit cash
        \\credit notanaccount
        \\amount 10
        \\memo bad
        \\stamp 20260710.182502
        \\
        ,
        \\debit cash
        \\credit revenue
        \\amount 0
        \\memo zero
        \\stamp 20260710.182502
        \\
        ,
        \\debit cash
        \\credit revenue
        \\amount 50
        \\memo welcome
        \\stamp 20260710.182502
        \\
        ,
    };
    var out_ex: [greencandy.max_exceptions]greencandy.Exception = undefined;
    var count: u32 = 0;
    greencandy.collect_exceptions(&drafts, &out_ex, &count);
    if (count != 2) return error.BadExceptionFixture;

    const lines = try garden.alloc(surface.SkateLine, exception_view_max_lines);
    lines[0] = .{ .text = try garden.dupe(u8, "greencandy exception view") };
    lines[1] = .{ .text = try std.fmt.allocPrint(garden, "exceptions {d}", .{count}) };
    lines[2] = .{ .text = try std.fmt.allocPrint(garden, "exception {s}", .{out_ex[0].reason}) };
    lines[3] = .{ .text = try std.fmt.allocPrint(garden, "exception {s}", .{out_ex[1].reason}) };
    lines[4] = .{ .text = try garden.dupe(u8, "exception fold green") };
    return lines;
}

fn run_exception_view_witness(garden: std.mem.Allocator, io: std.Io) !u8 {
    const empty = try garden.alloc(surface.SkateLine, 1);
    empty[0] = .{ .text = "" };
    const sig_empty = try surface.content_signature(garden, empty);

    const frame = try compose_exception_view_lines(garden, io);
    defer {
        var i: u32 = 0;
        while (i < frame.len) : (i += 1) garden.free(frame[i].text);
        garden.free(frame);
    }
    assert(frame.len == exception_view_max_lines);
    const sig = try surface.content_signature(garden, frame);
    assert(sig != sig_empty);

    const golden = [_][]const u8{
        "greencandy exception view",
        "exceptions 2",
        "exception unknown account",
        "exception bad amount",
        "exception fold green",
    };
    assert(lines_equal(&golden, frame));

    var out: [160]u8 = undefined;
    const msg = try std.fmt.bufPrint(
        &out,
        "drawn terminal exception view: sig={x} lines={d} — GREEN\n",
        .{ sig, frame.len },
    );
    try std.Io.File.stdout().writeStreamingAll(io, msg);
    return 0;
}

