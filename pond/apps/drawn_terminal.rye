/// Granary weave view — resolve person/weave, fold-clone resin, Scribble → Skate.
fn compose_granary_view_lines(garden: std.mem.Allocator, io: std.Io) ![]surface.SkateLine {
    const cwd = std.Io.Dir.cwd();
    var md_buf: [granary.max_resin_bytes]u8 = undefined;
    const markdown = try cwd.readFile(io, granary_front_page_fixture, &md_buf);

    var store = granary.ResinStore.empty();
    const digest = try granary.put_resin(&store, markdown);
    var fact_buf: [granary.max_fact_len]u8 = undefined;
    const fact_len = try granary.sign_name_fact(
        granary.granary_version,
        "rio",
        "greeting",
        &digest,
        &fact_buf,
    );
    var reg = granary.Registry.empty();
    try granary.append_fact(&reg, fact_buf[0..fact_len]);
    const resolved = try granary.resolve(&reg, "rio/greeting");
    assert(std.mem.eql(u8, resolved.resin_digest, &digest));

    var clone: [granary.max_resin_bytes]u8 = undefined;
    const clone_len = try granary.clone_resin(&store, resolved.resin_digest, &clone);
    assert(std.mem.eql(u8, clone[0..clone_len], markdown));

    var frame: granary.Frame = .{};
    try granary.render_front_page(clone[0..clone_len], &frame);
    // Frame: border, heading, paragraph, rye fence, border — need middle three.
    assert(frame.line_count >= 5);
    const heading = frame.lines[1].slice();
    const paragraph = frame.lines[2].slice();
    const fence = frame.lines[3].slice();

    const lines = try garden.alloc(surface.SkateLine, granary_view_max_lines);
    lines[0] = .{ .text = try garden.dupe(u8, "granary weave view") };
    lines[1] = .{ .text = try garden.dupe(u8, "path rio/greeting") };
    lines[2] = .{ .text = try std.fmt.allocPrint(garden, "resin {s}", .{digest[0..12]}) };
    lines[3] = .{ .text = try garden.dupe(u8, heading) };
    lines[4] = .{ .text = try garden.dupe(u8, paragraph) };
    lines[5] = .{ .text = try garden.dupe(u8, fence) };
    lines[6] = .{ .text = try garden.dupe(u8, "fold green") };
    return lines;
}

fn run_granary_view_witness(garden: std.mem.Allocator, io: std.Io) !u8 {
    const empty = try garden.alloc(surface.SkateLine, 1);
    empty[0] = .{ .text = "" };
    const sig_empty = try surface.content_signature(garden, empty);

    const frame = try compose_granary_view_lines(garden, io);
    defer {
        var i: u32 = 0;
        while (i < frame.len) : (i += 1) garden.free(frame[i].text);
        garden.free(frame);
    }
    assert(frame.len == granary_view_max_lines);
    const sig = try surface.content_signature(garden, frame);
    assert(sig != sig_empty);

    const golden = [_][]const u8{
        "granary weave view",
        "path rio/greeting",
        "resin 5b3b4e968679",
        "# rio/greeting",
        "A first weave in the Granary — signed, named, and shared.",
        "[rye fence]",
        "fold green",
    };
    assert(lines_equal(&golden, frame));

    // Unwelcome — missing fixture path refuses.
    const cwd = std.Io.Dir.cwd();
    var probe: [8]u8 = undefined;
    if (cwd.readFile(io, "tools/fixtures/does_not_exist_granary_view.md", &probe)) |_| {
        return error.UnwelcomePassed;
    } else |_| {}

    var out: [160]u8 = undefined;
    const msg = try std.fmt.bufPrint(
        &out,
        "drawn terminal granary weave view: sig={x} lines={d} — GREEN\n",
        .{ sig, frame.len },
    );
    try std.Io.File.stdout().writeStreamingAll(io, msg);
    return 0;
}

/// Granary Exchange view — weave listing priced in MALA → Skate.
fn compose_exchange_view_lines(garden: std.mem.Allocator) ![]surface.SkateLine {
    var store = granary.ResinStore.empty();
    const digest = try granary.put_resin(&store, "# priced weave\n\nfor sale in mala.\n");
    var fact: [granary.max_fact_len]u8 = undefined;
    const fact_len = try granary.sign_name_fact(granary.granary_version, "rio", "greeting", &digest, &fact);
    var reg = granary.Registry.empty();
    try granary.append_fact(&reg, fact[0..fact_len]);

    var listing: [exchange.max_listing_len]u8 = undefined;
    const n = try exchange.sign_listing(exchange.exchange_version, "rio/greeting", &digest, "100", &listing);
    try exchange.verify_listing(listing[0..n]);
    try exchange.verify_against_registry(listing[0..n], &reg);

    var receipt: [exchange.digest_hex_len]u8 = undefined;
    try exchange.receipt_digest(listing[0..n], &receipt);

    const lines = try garden.alloc(surface.SkateLine, exchange_view_max_lines);
    lines[0] = .{ .text = try garden.dupe(u8, "granary exchange view") };
    lines[1] = .{ .text = try garden.dupe(u8, "path rio/greeting") };
    lines[2] = .{ .text = try std.fmt.allocPrint(garden, "resin {s}", .{digest[0..12]}) };
    lines[3] = .{ .text = try garden.dupe(u8, "price 100 mala") };
    lines[4] = .{ .text = try std.fmt.allocPrint(garden, "receipt {s}", .{receipt[0..12]}) };
    lines[5] = .{ .text = try garden.dupe(u8, "fold green") };
    return lines;
}

fn run_exchange_view_witness(garden: std.mem.Allocator, io: std.Io) !u8 {
    const empty = try garden.alloc(surface.SkateLine, 1);
    empty[0] = .{ .text = "" };
    const sig_empty = try surface.content_signature(garden, empty);

    const frame = try compose_exchange_view_lines(garden);
    defer {
        var i: u32 = 0;
        while (i < frame.len) : (i += 1) garden.free(frame[i].text);
        garden.free(frame);
    }
    assert(frame.len == exchange_view_max_lines);
    const sig = try surface.content_signature(garden, frame);
    assert(sig != sig_empty);

    const golden = [_][]const u8{
        "granary exchange view",
        "path rio/greeting",
        "resin e132424d71e0",
        "price 100 mala",
        "receipt 1c8546c14e86",
        "fold green",
    };
    assert(lines_equal(&golden, frame));

    // Unwelcome — registry digest mismatch refused.
    var store = granary.ResinStore.empty();
    const digest = try granary.put_resin(&store, "# priced weave\n\nfor sale in mala.\n");
    var fact: [granary.max_fact_len]u8 = undefined;
    const fact_len = try granary.sign_name_fact(granary.granary_version, "rio", "greeting", &digest, &fact);
    var reg = granary.Registry.empty();
    try granary.append_fact(&reg, fact[0..fact_len]);
    const other = try granary.put_resin(&store, "# other\n");
    var bad: [exchange.max_listing_len]u8 = undefined;
    const bn = try exchange.sign_listing(exchange.exchange_version, "rio/greeting", &other, "25", &bad);
    if (exchange.verify_against_registry(bad[0..bn], &reg)) |_| {
        return error.MismatchAccepted;
    } else |err| {
        assert(err == error.DigestMismatch);
    }

    var out: [160]u8 = undefined;
    const msg = try std.fmt.bufPrint(
        &out,
        "drawn terminal granary exchange view: sig={x} lines={d} — GREEN\n",
        .{ sig, frame.len },
    );
    try std.Io.File.stdout().writeStreamingAll(io, msg);
    return 0;
}

/// Mandi floor view — signed vessel listing priced in MALA → Skate.
fn compose_mandi_floor_view_lines(garden: std.mem.Allocator) ![]surface.SkateLine {
    var parent: [mandi.digest_hex_len]u8 = undefined;
    mandi.witness_vessel_parent(&parent);

    var listing: [mandi.max_listing_len]u8 = undefined;
    const n = try mandi.sign_listing(mandi.mandi_version, &parent, "25", &listing);
    try mandi.verify_listing(listing[0..n]);
    try mandi.verify_against_parent(listing[0..n], &parent);

    var receipt: [mandi.digest_hex_len]u8 = undefined;
    try mandi.receipt_digest(listing[0..n], &receipt);

    const lines = try garden.alloc(surface.SkateLine, mandi_view_max_lines);
    lines[0] = .{ .text = try garden.dupe(u8, "mandi floor view") };
    lines[1] = .{ .text = try std.fmt.allocPrint(garden, "vessel {s}", .{parent[0..12]}) };
    lines[2] = .{ .text = try garden.dupe(u8, "price 25 mala") };
    lines[3] = .{ .text = try std.fmt.allocPrint(garden, "receipt {s}", .{receipt[0..12]}) };
    lines[4] = .{ .text = try garden.dupe(u8, "fold green") };
    return lines;
}

fn run_mandi_floor_view_witness(garden: std.mem.Allocator, io: std.Io) !u8 {
    const empty = try garden.alloc(surface.SkateLine, 1);
    empty[0] = .{ .text = "" };
    const sig_empty = try surface.content_signature(garden, empty);

    const frame = try compose_mandi_floor_view_lines(garden);
    defer {
        var i: u32 = 0;
        while (i < frame.len) : (i += 1) garden.free(frame[i].text);
        garden.free(frame);
    }
    assert(frame.len == mandi_view_max_lines);
    const sig = try surface.content_signature(garden, frame);
    assert(sig != sig_empty);

    const golden = [_][]const u8{
        "mandi floor view",
        "vessel 675cd344edbf",
        "price 25 mala",
        "receipt a8e89899c996",
        "fold green",
    };
    assert(lines_equal(&golden, frame));

    // Unwelcome — lying stamp_sig refused.
    var parent: [mandi.digest_hex_len]u8 = undefined;
    mandi.witness_vessel_parent(&parent);
    var lying: [mandi.max_listing_len]u8 = undefined;
    const ln = try mandi.sign_listing(mandi.mandi_version, &parent, "10", &lying);
    const sig_key = "stamp_sig ";
    const sig_at = std.mem.indexOf(u8, lying[0..ln], sig_key) orelse return error.MissingSig;
    lying[sig_at + sig_key.len] = if (lying[sig_at + sig_key.len] == '0') '1' else '0';
    if (mandi.verify_listing(lying[0..ln])) |_| {
        return error.LyingAccepted;
    } else |err| {
        assert(err == error.VerifyFailed);
    }

    var out: [160]u8 = undefined;
    const msg = try std.fmt.bufPrint(
        &out,
        "drawn terminal mandi floor view: sig={x} lines={d} — GREEN\n",
        .{ sig, frame.len },
    );
    try std.Io.File.stdout().writeStreamingAll(io, msg);
    return 0;
}

/// Mandi settle view — vessel listing closed with MALA/WOV payment → Skate.
fn compose_mandi_settle_view_lines(garden: std.mem.Allocator) ![]surface.SkateLine {
    var parent: [mandi.digest_hex_len]u8 = undefined;
    mandi.witness_vessel_parent(&parent);
    var listing: [mandi.max_listing_len]u8 = undefined;
    const ln = try mandi.sign_listing(mandi.mandi_version, &parent, "25", &listing);
    try mandi.verify_listing(listing[0..ln]);
    var listing_receipt: [mandi.digest_hex_len]u8 = undefined;
    try mandi.receipt_digest(listing[0..ln], &listing_receipt);

    const issuer_kp = kumara.keypair_from_seed(&mala.issuer_seed);
    const holder_kp = kumara.keypair_from_seed(&mala.holder_seed);
    var issuer_hex: [mala.pubkey_hex_len]u8 = undefined;
    var holder_hex: [mala.pubkey_hex_len]u8 = undefined;
    mala.hex_of_key(issuer_kp.public_key, &issuer_hex);
    mala.hex_of_key(holder_kp.public_key, &holder_hex);

    var log: [rc.max_log_len]u8 = undefined;
    var log_len: u32 = 0;
    const mint_fields = rc.FactFields{
        .from = issuer_hex[0..],
        .to = holder_hex[0..],
        .amount = "1000",
        .memo = mala.memo_mint,
        .stamp = settle.settle_version,
    };
    try mala.sign_append(&log, &log_len, mint_fields, issuer_kp);
    const send_fields = rc.FactFields{
        .from = holder_hex[0..],
        .to = issuer_hex[0..],
        .amount = "25",
        .memo = mala.memo_send,
        .stamp = settle.settle_version,
    };
    var send_canonical: [rc.max_fact_len]u8 = undefined;
    const send_canon_len = try rc.write_canonical_fact(send_fields, &send_canonical);
    try mala.sign_append(&log, &log_len, send_fields, holder_kp);
    _ = try mala.fold_mala_log(
        log[0..log_len],
        &issuer_hex,
        &holder_hex,
        issuer_kp.public_key,
        holder_kp.public_key,
    );
    var mala_digest: [settle.digest_hex_len]u8 = undefined;
    settle.digest_bytes(send_canonical[0..send_canon_len], &mala_digest);

    const buyer_kp = kumara.keypair_from_seed(&wov_core.holder_a_seed);
    const seller_kp = kumara.keypair_from_seed(&wov_core.holder_b_seed);
    var buyer_hex: [wov_core.pubkey_hex_len]u8 = undefined;
    var seller_hex: [wov_core.pubkey_hex_len]u8 = undefined;
    wov_core.hex_of_key(buyer_kp.public_key, &buyer_hex);
    wov_core.hex_of_key(seller_kp.public_key, &seller_hex);
    var book = wov_core.Book.init();
    try wov_core.mint(&book, &buyer_hex, 100);
    try wov_core.transfer(&book, &buyer_hex, &seller_hex, 25);
    var wov_line: [160]u8 = undefined;
    const wov_line_len = try std.fmt.bufPrint(
        &wov_line,
        "wov-transfer {s} {s} 25\n",
        .{ buyer_hex[0..], seller_hex[0..] },
    );
    var wov_digest: [settle.digest_hex_len]u8 = undefined;
    settle.digest_bytes(wov_line_len, &wov_digest);

    const payment_fields = settle.PaymentFields{
        .amount = "25",
        .currency = "mala",
        .mala_digest = &mala_digest,
        .wov_digest = &wov_digest,
    };
    var payment_hex: [settle.digest_hex_len]u8 = undefined;
    try settle.payment_digest(payment_fields, &payment_hex);

    var slip: [settle.max_settle_len]u8 = undefined;
    const sn = try settle.sign_settle(settle.settle_version, &listing_receipt, &payment_hex, &slip);
    try settle.verify_against_listing(slip[0..sn], &listing_receipt, &payment_hex, "25", "25");

    const lines = try garden.alloc(surface.SkateLine, mandi_settle_view_max_lines);
    lines[0] = .{ .text = try garden.dupe(u8, "mandi settle view") };
    lines[1] = .{ .text = try std.fmt.allocPrint(garden, "listing {s}", .{listing_receipt[0..12]}) };
    lines[2] = .{ .text = try garden.dupe(u8, "price 25 mala") };
    lines[3] = .{ .text = try std.fmt.allocPrint(garden, "payment {s}", .{payment_hex[0..12]}) };
    lines[4] = .{ .text = try garden.dupe(u8, "settled") };
    lines[5] = .{ .text = try garden.dupe(u8, "fold green") };
    return lines;
}

fn run_mandi_settle_view_witness(garden: std.mem.Allocator, io: std.Io) !u8 {
    const empty = try garden.alloc(surface.SkateLine, 1);
    empty[0] = .{ .text = "" };
    const sig_empty = try surface.content_signature(garden, empty);

    const frame = try compose_mandi_settle_view_lines(garden);
    defer {
        var i: u32 = 0;
        while (i < frame.len) : (i += 1) garden.free(frame[i].text);
        garden.free(frame);
    }
    assert(frame.len == mandi_settle_view_max_lines);
    const sig = try surface.content_signature(garden, frame);
    assert(sig != sig_empty);

    // Golden prefixes from live settle path (listing receipt known; payment from payment_digest).
    assert(std.mem.eql(u8, frame[0].text, "mandi settle view"));
    assert(std.mem.eql(u8, frame[1].text, "listing a8e89899c996"));
    assert(std.mem.eql(u8, frame[2].text, "price 25 mala"));
    assert(std.mem.startsWith(u8, frame[3].text, "payment "));
    assert(frame[3].text.len == "payment ".len + 12);
    assert(std.mem.eql(u8, frame[4].text, "settled"));
    assert(std.mem.eql(u8, frame[5].text, "fold green"));

    // Unwelcome — double settle refused.
    var settled = settle.SettledSet.empty();
    var listing_receipt: [mandi.digest_hex_len]u8 = undefined;
    // Recompute listing receipt for refuse path.
    var parent: [mandi.digest_hex_len]u8 = undefined;
    mandi.witness_vessel_parent(&parent);
    var listing: [mandi.max_listing_len]u8 = undefined;
    const ln = try mandi.sign_listing(mandi.mandi_version, &parent, "25", &listing);
    try mandi.receipt_digest(listing[0..ln], &listing_receipt);
    try settle.record_settle(&settled, &listing_receipt);
    if (settle.record_settle(&settled, &listing_receipt)) |_| {
        return error.DoubleSettleAccepted;
    } else |err| {
        assert(err == error.DoubleSettle);
    }

    var out: [160]u8 = undefined;
    const msg = try std.fmt.bufPrint(
        &out,
        "drawn terminal mandi settle view: sig={x} lines={d} — GREEN\n",
        .{ sig, frame.len },
    );
    try std.Io.File.stdout().writeStreamingAll(io, msg);
    return 0;
}

const steward_sale_entry =
    \\debit cash
    \\credit revenue
    \\amount 25
    \\memo mandi:vessel-sale
    \\stamp 20260711.010030
    \\
;

const StewardFold = struct {
    listing_receipt: [mandi.digest_hex_len]u8,
    cash: i64,
    pnl_net: i64,
    journal_count: u32,
};

/// Shared settle + Greencandy fold for steward view and steward sight.
fn run_steward_fold() !StewardFold {
    var parent: [mandi.digest_hex_len]u8 = undefined;
    mandi.witness_vessel_parent(&parent);
    var listing: [mandi.max_listing_len]u8 = undefined;
    const ln = try mandi.sign_listing(mandi.mandi_version, &parent, "25", &listing);
    try mandi.verify_listing(listing[0..ln]);
    var listing_receipt: [mandi.digest_hex_len]u8 = undefined;
    try mandi.receipt_digest(listing[0..ln], &listing_receipt);

    const issuer_kp = kumara.keypair_from_seed(&mala.issuer_seed);
    const holder_kp = kumara.keypair_from_seed(&mala.holder_seed);
    var issuer_hex: [mala.pubkey_hex_len]u8 = undefined;
    var holder_hex: [mala.pubkey_hex_len]u8 = undefined;
    mala.hex_of_key(issuer_kp.public_key, &issuer_hex);
    mala.hex_of_key(holder_kp.public_key, &holder_hex);

    var log: [rc.max_log_len]u8 = undefined;
    var log_len: u32 = 0;
    const mint_fields = rc.FactFields{
        .from = issuer_hex[0..],
        .to = holder_hex[0..],
        .amount = "1000",
        .memo = mala.memo_mint,
        .stamp = "20260711.010030",
    };
    try mala.sign_append(&log, &log_len, mint_fields, issuer_kp);
    const send_fields = rc.FactFields{
        .from = holder_hex[0..],
        .to = issuer_hex[0..],
        .amount = "25",
        .memo = mala.memo_send,
        .stamp = "20260711.010030",
    };
    var send_canonical: [rc.max_fact_len]u8 = undefined;
    const send_canon_len = try rc.write_canonical_fact(send_fields, &send_canonical);
    try mala.sign_append(&log, &log_len, send_fields, holder_kp);
    _ = try mala.fold_mala_log(
        log[0..log_len],
        &issuer_hex,
        &holder_hex,
        issuer_kp.public_key,
        holder_kp.public_key,
    );
    var mala_digest: [settle.digest_hex_len]u8 = undefined;
    settle.digest_bytes(send_canonical[0..send_canon_len], &mala_digest);

    const buyer_kp = kumara.keypair_from_seed(&wov_core.holder_a_seed);
    const seller_kp = kumara.keypair_from_seed(&wov_core.holder_b_seed);
    var buyer_hex: [wov_core.pubkey_hex_len]u8 = undefined;
    var seller_hex: [wov_core.pubkey_hex_len]u8 = undefined;
    wov_core.hex_of_key(buyer_kp.public_key, &buyer_hex);
    wov_core.hex_of_key(seller_kp.public_key, &seller_hex);
    var book = wov_core.Book.init();
    try wov_core.mint(&book, &buyer_hex, 100);
    try wov_core.transfer(&book, &buyer_hex, &seller_hex, 25);
    var wov_line: [160]u8 = undefined;
    const wov_line_len = try std.fmt.bufPrint(
        &wov_line,
        "wov-transfer {s} {s} 25\n",
        .{ buyer_hex[0..], seller_hex[0..] },
    );
    var wov_digest: [settle.digest_hex_len]u8 = undefined;
    settle.digest_bytes(wov_line_len, &wov_digest);

    const payment_fields = settle.PaymentFields{
        .amount = "25",
        .currency = "mala",
        .mala_digest = &mala_digest,
        .wov_digest = &wov_digest,
    };
    var payment_hex: [settle.digest_hex_len]u8 = undefined;
    try settle.payment_digest(payment_fields, &payment_hex);
    var slip: [settle.max_settle_len]u8 = undefined;
    const sn = try settle.sign_settle(settle.settle_version, &listing_receipt, &payment_hex, &slip);
    try settle.verify_against_listing(slip[0..sn], &listing_receipt, &payment_hex, "25", "25");
    var settled = settle.SettledSet.empty();
    try settle.record_settle(&settled, &listing_receipt);

    var journal_buf: [greencandy.max_journal_len]u8 = undefined;
    const journal = try std.fmt.bufPrint(
        &journal_buf,
        "{s}---\n{s}",
        .{ greencandy.welcome_journal, steward_sale_entry },
    );
    var entries: [greencandy.max_entries]greencandy.Entry = undefined;
    var count: u32 = 0;
    try greencandy.parse_journal(journal, &entries, &count);
    if (count != 3) return error.BadJournal;
    const tb = try greencandy.fold_journal(entries[0..count]);
    if (tb.conservation() != 0) return error.BadJournal;
    const cash = tb.nets[@intFromEnum(greencandy.Account.cash)];
    if (cash != 825) return error.BadJournal;
    const pl = greencandy.fold_income_statement(tb);
    if (pl.net_income != 825) return error.BadJournal;

    return .{
        .listing_receipt = listing_receipt,
        .cash = cash,
        .pnl_net = pl.net_income,
        .journal_count = count,
    };
}

/// Commerce steward composition — list → settle → Greencandy receipt on one Skate frame.
fn compose_steward_view_lines(garden: std.mem.Allocator) ![]surface.SkateLine {
    const fold = try run_steward_fold();
    const lines = try garden.alloc(surface.SkateLine, steward_view_max_lines);
    lines[0] = .{ .text = try garden.dupe(u8, "commerce steward view") };
    lines[1] = .{ .text = try garden.dupe(u8, "listed 25 mala") };
    lines[2] = .{ .text = try std.fmt.allocPrint(garden, "listing {s}", .{fold.listing_receipt[0..12]}) };
    lines[3] = .{ .text = try garden.dupe(u8, "settled") };
    lines[4] = .{ .text = try garden.dupe(u8, "receipt mandi:vessel-sale") };
    lines[5] = .{ .text = try std.fmt.allocPrint(garden, "cash {d}", .{fold.cash}) };
    lines[6] = .{ .text = try garden.dupe(u8, "conservation 0") };
    lines[7] = .{ .text = try garden.dupe(u8, "fold green") };
    return lines;
}

fn run_steward_view_witness(garden: std.mem.Allocator, io: std.Io) !u8 {
    const empty = try garden.alloc(surface.SkateLine, 1);
    empty[0] = .{ .text = "" };
    const sig_empty = try surface.content_signature(garden, empty);

    const frame = try compose_steward_view_lines(garden);
    defer {
        var i: u32 = 0;
        while (i < frame.len) : (i += 1) garden.free(frame[i].text);
        garden.free(frame);
    }
    assert(frame.len == steward_view_max_lines);
    const sig = try surface.content_signature(garden, frame);
    assert(sig != sig_empty);

    const golden = [_][]const u8{
        "commerce steward view",
        "listed 25 mala",
        "listing a8e89899c996",
        "settled",
        "receipt mandi:vessel-sale",
        "cash 825",
        "conservation 0",
        "fold green",
    };
    assert(lines_equal(&golden, frame));

    // Unwelcome — zero-sale amount refused.
    const zero_sale =
        \\debit cash
        \\credit revenue
        \\amount 0
        \\memo mandi:vessel-sale
        \\stamp 20260711.010030
        \\
    ;
    var bad_entry: greencandy.Entry = undefined;
    if (greencandy.parse_entry(zero_sale, &bad_entry)) |_| {
        return error.ZeroSaleAccepted;
    } else |err| {
        assert(err == error.BadAmount);
    }

    var out: [220]u8 = undefined;
    const msg = try std.fmt.bufPrint(
        &out,
        "drawn terminal steward view: listed=25 settled=1 cash=825 conservation=0 memo=mandi:vessel-sale sig={x} lines={d} — GREEN\n",
        .{ sig, frame.len },
    );
    try std.Io.File.stdout().writeStreamingAll(io, msg);
    return 0;
}

/// Steward sight — livelihood loop + books fold from the same journal on one Skate frame.
fn compose_steward_sight_view_lines(garden: std.mem.Allocator) ![]surface.SkateLine {
    const fold = try run_steward_fold();
    const lines = try garden.alloc(surface.SkateLine, steward_sight_view_max_lines);
    lines[0] = .{ .text = try garden.dupe(u8, "commerce steward sight") };
    lines[1] = .{ .text = try garden.dupe(u8, "listed 25 mala") };
    lines[2] = .{ .text = try std.fmt.allocPrint(garden, "listing {s}", .{fold.listing_receipt[0..12]}) };
    lines[3] = .{ .text = try garden.dupe(u8, "settled · receipt mandi:vessel-sale") };
    lines[4] = .{ .text = try std.fmt.allocPrint(garden, "cash {d} · conservation 0 · pnl {d}", .{ fold.cash, fold.pnl_net }) };
    lines[5] = .{ .text = try std.fmt.allocPrint(garden, "journal entries {d}", .{fold.journal_count}) };
    lines[6] = .{ .text = try std.fmt.allocPrint(garden, "chart {s} {s} {s} {s}", .{
        greencandy.Account.cash.name(),
        greencandy.Account.revenue.name(),
        greencandy.Account.expense.name(),
        greencandy.Account.equity.name(),
    }) };
    lines[7] = .{ .text = try garden.dupe(u8, "sight fold green") };
    return lines;
}

fn run_steward_sight_view_witness(garden: std.mem.Allocator, io: std.Io) !u8 {
    const empty = try garden.alloc(surface.SkateLine, 1);
    empty[0] = .{ .text = "" };
    const sig_empty = try surface.content_signature(garden, empty);

    const frame = try compose_steward_sight_view_lines(garden);
    defer {
        var i: u32 = 0;
        while (i < frame.len) : (i += 1) garden.free(frame[i].text);
        garden.free(frame);
    }
    assert(frame.len == steward_sight_view_max_lines);
    const sig = try surface.content_signature(garden, frame);
    assert(sig != sig_empty);

    const golden = [_][]const u8{
        "commerce steward sight",
        "listed 25 mala",
        "listing a8e89899c996",
        "settled · receipt mandi:vessel-sale",
        "cash 825 · conservation 0 · pnl 825",
        "journal entries 3",
        "chart cash revenue expense equity",
        "sight fold green",
    };
    assert(lines_equal(&golden, frame));

    var out: [240]u8 = undefined;
    const msg = try std.fmt.bufPrint(
        &out,
        "drawn terminal steward sight: listed=25 settled=1 cash=825 conservation=0 pnl=825 journal=3 memo=mandi:vessel-sale sig={x} lines={d} — GREEN\n",
        .{ sig, frame.len },
    );
    try std.Io.File.stdout().writeStreamingAll(io, msg);
    return 0;
}

/// Granary settle view — Exchange listing closed with MALA/WOV payment → Skate.
fn compose_granary_settle_view_lines(garden: std.mem.Allocator) ![]surface.SkateLine {
    var store = granary.ResinStore.empty();
    const digest = try granary.put_resin(&store, "# priced weave\n\nfor sale in mala.\n");
    var fact: [granary.max_fact_len]u8 = undefined;
    const fact_len = try granary.sign_name_fact(granary.granary_version, "rio", "greeting", &digest, &fact);
    var reg = granary.Registry.empty();
    try granary.append_fact(&reg, fact[0..fact_len]);

    var listing: [exchange.max_listing_len]u8 = undefined;
    const ln = try exchange.sign_listing(exchange.exchange_version, "rio/greeting", &digest, "100", &listing);
    try exchange.verify_listing(listing[0..ln]);
    try exchange.verify_against_registry(listing[0..ln], &reg);
    var listing_receipt: [exchange.digest_hex_len]u8 = undefined;
    try exchange.receipt_digest(listing[0..ln], &listing_receipt);

    const issuer_kp = kumara.keypair_from_seed(&mala.issuer_seed);
    const holder_kp = kumara.keypair_from_seed(&mala.holder_seed);
    var issuer_hex: [mala.pubkey_hex_len]u8 = undefined;
    var holder_hex: [mala.pubkey_hex_len]u8 = undefined;
    mala.hex_of_key(issuer_kp.public_key, &issuer_hex);
    mala.hex_of_key(holder_kp.public_key, &holder_hex);

    var log: [rc.max_log_len]u8 = undefined;
    var log_len: u32 = 0;
    const mint_fields = rc.FactFields{
        .from = issuer_hex[0..],
        .to = holder_hex[0..],
        .amount = "1000",
        .memo = mala.memo_mint,
        .stamp = weave_settle.settle_version,
    };
    try mala.sign_append(&log, &log_len, mint_fields, issuer_kp);
    const send_fields = rc.FactFields{
        .from = holder_hex[0..],
        .to = issuer_hex[0..],
        .amount = "100",
        .memo = mala.memo_send,
        .stamp = weave_settle.settle_version,
    };
    var send_canonical: [rc.max_fact_len]u8 = undefined;
    const send_canon_len = try rc.write_canonical_fact(send_fields, &send_canonical);
    try mala.sign_append(&log, &log_len, send_fields, holder_kp);
    _ = try mala.fold_mala_log(
        log[0..log_len],
        &issuer_hex,
        &holder_hex,
        issuer_kp.public_key,
        holder_kp.public_key,
    );
    var mala_digest: [weave_settle.digest_hex_len]u8 = undefined;
    weave_settle.digest_bytes(send_canonical[0..send_canon_len], &mala_digest);

    const buyer_kp = kumara.keypair_from_seed(&wov_core.holder_a_seed);
    const seller_kp = kumara.keypair_from_seed(&wov_core.holder_b_seed);
    var buyer_hex: [wov_core.pubkey_hex_len]u8 = undefined;
    var seller_hex: [wov_core.pubkey_hex_len]u8 = undefined;
    wov_core.hex_of_key(buyer_kp.public_key, &buyer_hex);
    wov_core.hex_of_key(seller_kp.public_key, &seller_hex);
    var book = wov_core.Book.init();
    try wov_core.mint(&book, &buyer_hex, 200);
    try wov_core.transfer(&book, &buyer_hex, &seller_hex, 100);
    var wov_line: [160]u8 = undefined;
    const wov_line_len = try std.fmt.bufPrint(
        &wov_line,
        "wov-transfer {s} {s} 100\n",
        .{ buyer_hex[0..], seller_hex[0..] },
    );
    var wov_digest: [weave_settle.digest_hex_len]u8 = undefined;
    weave_settle.digest_bytes(wov_line_len, &wov_digest);

    const payment_fields = weave_settle.PaymentFields{
        .amount = "100",
        .currency = "mala",
        .mala_digest = &mala_digest,
        .wov_digest = &wov_digest,
    };
    var payment_hex: [weave_settle.digest_hex_len]u8 = undefined;
    try weave_settle.payment_digest(payment_fields, &payment_hex);

    var slip: [weave_settle.max_settle_len]u8 = undefined;
    const sn = try weave_settle.sign_settle(weave_settle.settle_version, &listing_receipt, &payment_hex, &slip);
    try weave_settle.verify_against_listing(slip[0..sn], &listing_receipt, &payment_hex, "100", "100");

    const lines = try garden.alloc(surface.SkateLine, granary_settle_view_max_lines);
    lines[0] = .{ .text = try garden.dupe(u8, "granary settle view") };
    lines[1] = .{ .text = try std.fmt.allocPrint(garden, "listing {s}", .{listing_receipt[0..12]}) };
    lines[2] = .{ .text = try garden.dupe(u8, "price 100 mala") };
    lines[3] = .{ .text = try std.fmt.allocPrint(garden, "payment {s}", .{payment_hex[0..12]}) };
    lines[4] = .{ .text = try garden.dupe(u8, "settled") };
    lines[5] = .{ .text = try garden.dupe(u8, "fold green") };
    return lines;
}

fn run_granary_settle_view_witness(garden: std.mem.Allocator, io: std.Io) !u8 {
    const empty = try garden.alloc(surface.SkateLine, 1);
    empty[0] = .{ .text = "" };
    const sig_empty = try surface.content_signature(garden, empty);

    const frame = try compose_granary_settle_view_lines(garden);
    defer {
        var i: u32 = 0;
        while (i < frame.len) : (i += 1) garden.free(frame[i].text);
        garden.free(frame);
    }
    assert(frame.len == granary_settle_view_max_lines);
    const sig = try surface.content_signature(garden, frame);
    assert(sig != sig_empty);

    // Golden prefixes — listing receipt matches Exchange view; payment from payment_digest.
    assert(std.mem.eql(u8, frame[0].text, "granary settle view"));
    assert(std.mem.eql(u8, frame[1].text, "listing 1c8546c14e86"));
    assert(std.mem.eql(u8, frame[2].text, "price 100 mala"));
    assert(std.mem.startsWith(u8, frame[3].text, "payment "));
    assert(frame[3].text.len == "payment ".len + 12);
    assert(std.mem.eql(u8, frame[4].text, "settled"));
    assert(std.mem.eql(u8, frame[5].text, "fold green"));

    // Unwelcome — double settle refused.
    var settled = weave_settle.SettledSet.empty();
    var listing_receipt: [exchange.digest_hex_len]u8 = undefined;
    var store = granary.ResinStore.empty();
    const digest = try granary.put_resin(&store, "# priced weave\n\nfor sale in mala.\n");
    var listing: [exchange.max_listing_len]u8 = undefined;
    const ln = try exchange.sign_listing(exchange.exchange_version, "rio/greeting", &digest, "100", &listing);
    try exchange.receipt_digest(listing[0..ln], &listing_receipt);
    try weave_settle.record_settle(&settled, &listing_receipt);
    if (weave_settle.record_settle(&settled, &listing_receipt)) |_| {
        return error.DoubleSettleAccepted;
    } else |err| {
        assert(err == error.DoubleSettle);
    }

    var out: [160]u8 = undefined;
    const msg = try std.fmt.bufPrint(
        &out,
        "drawn terminal granary settle view: sig={x} lines={d} — GREEN\n",
        .{ sig, frame.len },
    );
    try std.Io.File.stdout().writeStreamingAll(io, msg);
    return 0;
}

const granary_steward_sale_entry =
    \\debit cash
    \\credit revenue
    \\amount 100
    \\memo granary:weave-sale
    \\stamp 20260711.012451
    \\
;

const GranaryStewardFold = struct {
    listing_receipt: [exchange.digest_hex_len]u8,
    cash: i64,
    pnl_net: i64,
    journal_count: u32,
};

/// Shared weave settle + Greencandy fold for Granary steward view and sight.
fn run_granary_steward_fold() !GranaryStewardFold {
    var store = granary.ResinStore.empty();
    const digest = try granary.put_resin(&store, "# priced weave\n\nfor sale in mala.\n");
    var fact: [granary.max_fact_len]u8 = undefined;
    const fact_len = try granary.sign_name_fact(granary.granary_version, "rio", "greeting", &digest, &fact);
    var reg = granary.Registry.empty();
    try granary.append_fact(&reg, fact[0..fact_len]);

    var listing: [exchange.max_listing_len]u8 = undefined;
    const ln = try exchange.sign_listing(exchange.exchange_version, "rio/greeting", &digest, "100", &listing);
    try exchange.verify_listing(listing[0..ln]);
    try exchange.verify_against_registry(listing[0..ln], &reg);
    var listing_receipt: [exchange.digest_hex_len]u8 = undefined;
    try exchange.receipt_digest(listing[0..ln], &listing_receipt);

    const issuer_kp = kumara.keypair_from_seed(&mala.issuer_seed);
    const holder_kp = kumara.keypair_from_seed(&mala.holder_seed);
    var issuer_hex: [mala.pubkey_hex_len]u8 = undefined;
    var holder_hex: [mala.pubkey_hex_len]u8 = undefined;
    mala.hex_of_key(issuer_kp.public_key, &issuer_hex);
    mala.hex_of_key(holder_kp.public_key, &holder_hex);

    var log: [rc.max_log_len]u8 = undefined;
    var log_len: u32 = 0;
    const mint_fields = rc.FactFields{
        .from = issuer_hex[0..],
        .to = holder_hex[0..],
        .amount = "1000",
        .memo = mala.memo_mint,
        .stamp = "20260711.012451",
    };
    try mala.sign_append(&log, &log_len, mint_fields, issuer_kp);
    const send_fields = rc.FactFields{
        .from = holder_hex[0..],
        .to = issuer_hex[0..],
        .amount = "100",
        .memo = mala.memo_send,
        .stamp = "20260711.012451",
    };
    var send_canonical: [rc.max_fact_len]u8 = undefined;
    const send_canon_len = try rc.write_canonical_fact(send_fields, &send_canonical);
    try mala.sign_append(&log, &log_len, send_fields, holder_kp);
    _ = try mala.fold_mala_log(
        log[0..log_len],
        &issuer_hex,
        &holder_hex,
        issuer_kp.public_key,
        holder_kp.public_key,
    );
    var mala_digest: [weave_settle.digest_hex_len]u8 = undefined;
    weave_settle.digest_bytes(send_canonical[0..send_canon_len], &mala_digest);

    const buyer_kp = kumara.keypair_from_seed(&wov_core.holder_a_seed);
    const seller_kp = kumara.keypair_from_seed(&wov_core.holder_b_seed);
    var buyer_hex: [wov_core.pubkey_hex_len]u8 = undefined;
    var seller_hex: [wov_core.pubkey_hex_len]u8 = undefined;
    wov_core.hex_of_key(buyer_kp.public_key, &buyer_hex);
    wov_core.hex_of_key(seller_kp.public_key, &seller_hex);
    var book = wov_core.Book.init();
    try wov_core.mint(&book, &buyer_hex, 200);
    try wov_core.transfer(&book, &buyer_hex, &seller_hex, 100);
    var wov_line: [160]u8 = undefined;
    const wov_line_len = try std.fmt.bufPrint(
        &wov_line,
        "wov-transfer {s} {s} 100\n",
        .{ buyer_hex[0..], seller_hex[0..] },
    );
    var wov_digest: [weave_settle.digest_hex_len]u8 = undefined;
    weave_settle.digest_bytes(wov_line_len, &wov_digest);

    const payment_fields = weave_settle.PaymentFields{
        .amount = "100",
        .currency = "mala",
        .mala_digest = &mala_digest,
        .wov_digest = &wov_digest,
    };
    var payment_hex: [weave_settle.digest_hex_len]u8 = undefined;
    try weave_settle.payment_digest(payment_fields, &payment_hex);
    var slip: [weave_settle.max_settle_len]u8 = undefined;
    const sn = try weave_settle.sign_settle(weave_settle.settle_version, &listing_receipt, &payment_hex, &slip);
    try weave_settle.verify_against_listing(slip[0..sn], &listing_receipt, &payment_hex, "100", "100");
    var settled = weave_settle.SettledSet.empty();
    try weave_settle.record_settle(&settled, &listing_receipt);

    var journal_buf: [greencandy.max_journal_len]u8 = undefined;
    const journal = try std.fmt.bufPrint(
        &journal_buf,
        "{s}---\n{s}",
        .{ greencandy.welcome_journal, granary_steward_sale_entry },
    );
    var entries: [greencandy.max_entries]greencandy.Entry = undefined;
    var count: u32 = 0;
    try greencandy.parse_journal(journal, &entries, &count);
    if (count != 3) return error.BadJournal;
    const tb = try greencandy.fold_journal(entries[0..count]);
    if (tb.conservation() != 0) return error.BadJournal;
    const cash = tb.nets[@intFromEnum(greencandy.Account.cash)];
    if (cash != 900) return error.BadJournal;
    const pl = greencandy.fold_income_statement(tb);
    if (pl.net_income != 900) return error.BadJournal;

    return .{
        .listing_receipt = listing_receipt,
        .cash = cash,
        .pnl_net = pl.net_income,
        .journal_count = count,
    };
}

/// Granary weave steward — list → settle → Greencandy receipt on one Skate frame.
fn compose_granary_steward_view_lines(garden: std.mem.Allocator) ![]surface.SkateLine {
    const fold = try run_granary_steward_fold();
    const lines = try garden.alloc(surface.SkateLine, granary_steward_view_max_lines);
    lines[0] = .{ .text = try garden.dupe(u8, "granary steward view") };
    lines[1] = .{ .text = try garden.dupe(u8, "listed 100 mala") };
    lines[2] = .{ .text = try std.fmt.allocPrint(garden, "listing {s}", .{fold.listing_receipt[0..12]}) };
    lines[3] = .{ .text = try garden.dupe(u8, "settled") };
    lines[4] = .{ .text = try garden.dupe(u8, "receipt granary:weave-sale") };
    lines[5] = .{ .text = try std.fmt.allocPrint(garden, "cash {d}", .{fold.cash}) };
    lines[6] = .{ .text = try garden.dupe(u8, "conservation 0") };
    lines[7] = .{ .text = try garden.dupe(u8, "fold green") };
    return lines;
}

fn run_granary_steward_view_witness(garden: std.mem.Allocator, io: std.Io) !u8 {
    const empty = try garden.alloc(surface.SkateLine, 1);
    empty[0] = .{ .text = "" };
    const sig_empty = try surface.content_signature(garden, empty);

    const frame = try compose_granary_steward_view_lines(garden);
    defer {
        var i: u32 = 0;
        while (i < frame.len) : (i += 1) garden.free(frame[i].text);
        garden.free(frame);
    }
    assert(frame.len == granary_steward_view_max_lines);
    const sig = try surface.content_signature(garden, frame);
    assert(sig != sig_empty);

    const golden = [_][]const u8{
        "granary steward view",
        "listed 100 mala",
        "listing 1c8546c14e86",
        "settled",
        "receipt granary:weave-sale",
        "cash 900",
        "conservation 0",
        "fold green",
    };
    assert(lines_equal(&golden, frame));

    const zero_sale =
        \\debit cash
        \\credit revenue
        \\amount 0
        \\memo granary:weave-sale
        \\stamp 20260711.012451
        \\
    ;
    var bad_entry: greencandy.Entry = undefined;
    if (greencandy.parse_entry(zero_sale, &bad_entry)) |_| {
        return error.ZeroSaleAccepted;
    } else |err| {
        assert(err == error.BadAmount);
    }

    var out: [240]u8 = undefined;
    const msg = try std.fmt.bufPrint(
        &out,
        "drawn terminal granary steward view: listed=100 settled=1 cash=900 conservation=0 memo=granary:weave-sale sig={x} lines={d} — GREEN\n",
        .{ sig, frame.len },
    );
    try std.Io.File.stdout().writeStreamingAll(io, msg);
    return 0;
}

/// Granary steward sight — weave livelihood + books fold from the same journal.
fn compose_granary_steward_sight_view_lines(garden: std.mem.Allocator) ![]surface.SkateLine {
    const fold = try run_granary_steward_fold();
    const lines = try garden.alloc(surface.SkateLine, granary_steward_sight_view_max_lines);
    lines[0] = .{ .text = try garden.dupe(u8, "granary steward sight") };
    lines[1] = .{ .text = try garden.dupe(u8, "listed 100 mala") };
    lines[2] = .{ .text = try std.fmt.allocPrint(garden, "listing {s}", .{fold.listing_receipt[0..12]}) };
    lines[3] = .{ .text = try garden.dupe(u8, "settled · receipt granary:weave-sale") };
    lines[4] = .{ .text = try std.fmt.allocPrint(garden, "cash {d} · conservation 0 · pnl {d}", .{ fold.cash, fold.pnl_net }) };
    lines[5] = .{ .text = try std.fmt.allocPrint(garden, "journal entries {d}", .{fold.journal_count}) };
    lines[6] = .{ .text = try std.fmt.allocPrint(garden, "chart {s} {s} {s} {s}", .{
        greencandy.Account.cash.name(),
        greencandy.Account.revenue.name(),
        greencandy.Account.expense.name(),
        greencandy.Account.equity.name(),
    }) };
    lines[7] = .{ .text = try garden.dupe(u8, "sight fold green") };
    return lines;
}

