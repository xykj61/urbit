    lines[7] = .{ .text = try garden.dupe(u8, "assist sight fold green") };
    return lines;
}

fn run_assist_sight_view_witness(garden: std.mem.Allocator, io: std.Io) !u8 {
    const empty = try garden.alloc(surface.SkateLine, 1);
    empty[0] = .{ .text = "" };
