/// Scribble h2 view — depth-2 headings on Skate.
fn compose_scribble_h2_view_lines(garden: std.mem.Allocator, io: std.Io) ![]surface.SkateLine {
    const cwd = std.Io.Dir.cwd();
    var buf: [scribble.max_doc_bytes]u8 = undefined;
    const text = try cwd.readFile(io, scribble_outline_fixture, &buf);
    var blocks: [scribble.max_blocks]scribble.Block = undefined;
    const n = try scribble.parse_markdown(text, &blocks);
    var headings: [scribble.max_headings]scribble.Heading = undefined;
    const hn = try scribble.extract_headings_at_depth(blocks[0..n], 2, &headings);
    if (hn != 2) return error.BadScribbleFixture;

    const lines = try garden.alloc(surface.SkateLine, scribble_h2_view_max_lines);
    lines[0] = .{ .text = try garden.dupe(u8, "scribble h2 view") };
    lines[1] = .{ .text = try std.fmt.allocPrint(garden, "h2 {d}", .{hn}) };
    lines[2] = .{ .text = try std.fmt.allocPrint(garden, "h2 {s}", .{headings[0].text_slice()}) };
    lines[3] = .{ .text = try std.fmt.allocPrint(garden, "h2 {s}", .{headings[1].text_slice()}) };
    lines[4] = .{ .text = try garden.dupe(u8, "h2 fold green") };
    return lines;
}

fn run_scribble_h2_view_witness(garden: std.mem.Allocator, io: std.Io) !u8 {
    const empty = try garden.alloc(surface.SkateLine, 1);
    empty[0] = .{ .text = "" };
    const sig_empty = try surface.content_signature(garden, empty);

    const frame = try compose_scribble_h2_view_lines(garden, io);
    defer {
        var i: u32 = 0;
        while (i < frame.len) : (i += 1) garden.free(frame[i].text);
        garden.free(frame);
    }
    assert(frame.len == scribble_h2_view_max_lines);
    const sig = try surface.content_signature(garden, frame);
    assert(sig != sig_empty);

    const golden = [_][]const u8{
        "scribble h2 view",
        "h2 2",
        "h2 Lattice first",
        "h2 Scribble next",
        "h2 fold green",
    };
    assert(lines_equal(&golden, frame));

    var out: [160]u8 = undefined;
    const msg = try std.fmt.bufPrint(
        &out,
        "drawn terminal scribble h2 view: h2=2 sig={x} lines={d} — GREEN\n",
        .{ sig, frame.len },
    );
    try std.Io.File.stdout().writeStreamingAll(io, msg);
    return 0;
}

