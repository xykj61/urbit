    lines[3] = .{ .text = try std.fmt.allocPrint(garden, "hit {s}", .{cat.chunks[hits[0]].path_slice()}) };
    lines[4] = .{ .text = try std.fmt.allocPrint(garden, "hit {s}", .{cat.chunks[hits[1]].path_slice()}) };
    lines[5] = .{ .text = try garden.dupe(u8, "corpus fold green") };
    return lines;
}

