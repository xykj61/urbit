/// Realidream forge query view — Tablecloth-query hit shape for Amber/Amphora forge facts.
fn compose_forge_query_view_lines(garden: std.mem.Allocator, io: std.Io) ![]surface.SkateLine {
    const cwd = std.Io.Dir.cwd();
    var buf: [1024]u8 = undefined;
    const text = try cwd.readFile(io, forge_query_hits_fixture, &buf);

    const tilak = field_value(text, "filter_tilak") orelse return error.BadForgeQueryFixture;
    const hit_count_text = field_value(text, "hit_count") orelse return error.BadForgeQueryFixture;
    const hit_count = tally_parse_int.parse_int(u32, hit_count_text, .{}) catch return error.BadForgeQueryFixture;
    if (hit_count != 2) return error.BadForgeQueryFixture;

    var hit_lines: [2][]const u8 = undefined;
    var hit_i: u32 = 0;
    var lines_iter = std.mem.splitScalar(u8, text, '\n');
    while (lines_iter.next()) |raw| {
        const line = std.mem.trim(u8, raw, " \t\r\n");
        if (!std.mem.startsWith(u8, line, "hit ")) continue;
        if (hit_i >= 2) return error.BadForgeQueryFixture;
        hit_lines[hit_i] = line["hit ".len..];
        hit_i += 1;
    }
    if (hit_i != 2) return error.BadForgeQueryFixture;

    const lines = try garden.alloc(surface.SkateLine, forge_query_view_max_lines);
    lines[0] = .{ .text = try garden.dupe(u8, "realidream forge query") };
    lines[1] = .{ .text = try std.fmt.allocPrint(garden, "filter tilak {s}", .{tilak}) };
    lines[2] = .{ .text = try std.fmt.allocPrint(garden, "hits {d}", .{hit_count}) };
    lines[3] = .{ .text = try std.fmt.allocPrint(garden, "hit {s}", .{hit_lines[0]}) };
    lines[4] = .{ .text = try std.fmt.allocPrint(garden, "hit {s}", .{hit_lines[1]}) };
    lines[5] = .{ .text = try garden.dupe(u8, "forge query fold green") };
    return lines;
}

fn run_forge_query_view_witness(garden: std.mem.Allocator, io: std.Io) !u8 {
    const empty = try garden.alloc(surface.SkateLine, 1);
    empty[0] = .{ .text = "" };
    const sig_empty = try surface.content_signature(garden, empty);

    const frame = try compose_forge_query_view_lines(garden, io);
    defer {
