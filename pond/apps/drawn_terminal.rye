/// Realidream forge unified view — hosted pour + device fetch on one Skate frame.
fn compose_forge_unified_view_lines(garden: std.mem.Allocator, io: std.Io) ![]surface.SkateLine {
    const cwd = std.Io.Dir.cwd();
    var man_buf: [2048]u8 = undefined;
    const man = try cwd.readFile(io, forge_amber_manifest_fixture, &man_buf);
    var device_buf: [1024]u8 = undefined;
    const device = try cwd.readFile(io, amphora_device_fetch_hits_fixture, &device_buf);

    const format = field_value(man, "format") orelse return error.BadForgeFixture;
    if (!std.mem.eql(u8, format, "amber-ring1-v2-tilak")) return error.BadForgeFixture;
    var hello_digest: ?[]const u8 = null;
    var entry_count: u32 = 0;
    var lines_iter = std.mem.splitScalar(u8, man, '\n');
    while (lines_iter.next()) |raw| {
        const line = std.mem.trim(u8, raw, " \t\r\n");
        if (!std.mem.startsWith(u8, line, "entry ")) continue;
        entry_count += 1;
        var parts = std.mem.tokenizeScalar(u8, line, ' ');
        _ = parts.next();
        _ = parts.next();
        const digest = parts.next() orelse return error.BadForgeFixture;
        const name = parts.next() orelse return error.BadForgeFixture;
        if (std.mem.eql(u8, name, "hello.txt")) hello_digest = digest;
    }
    if (entry_count != 2) return error.BadForgeFixture;
    const hosted_digest = hello_digest orelse return error.BadForgeFixture;

    const wire = field_value(device, "wire") orelse return error.BadForgeFixture;
    if (!std.mem.eql(u8, wire, "device")) return error.BadForgeFixture;
    const device_digest = field_value(device, "digest") orelse return error.BadForgeFixture;
    if (device_digest.len != 64) return error.BadForgeFixture;
    const device_name = field_value(device, "name") orelse return error.BadForgeFixture;
    if (!std.mem.eql(u8, hosted_digest, device_digest)) return error.DigestMismatch;

    const lines = try garden.alloc(surface.SkateLine, forge_unified_view_max_lines);
    lines[0] = .{ .text = try garden.dupe(u8, "realidream forge unified view") };
    lines[1] = .{ .text = try garden.dupe(u8, "hosted cellar amber") };
    lines[2] = .{ .text = try std.fmt.allocPrint(garden, "hosted resins {d}", .{entry_count}) };
    lines[3] = .{ .text = try std.fmt.allocPrint(garden, "hosted resin hello.txt {s}", .{hosted_digest[0..12]}) };
    lines[4] = .{ .text = try garden.dupe(u8, "device wire device") };
    lines[5] = .{ .text = try std.fmt.allocPrint(garden, "device digest {s}", .{device_digest[0..12]}) };
    lines[6] = .{ .text = try std.fmt.allocPrint(garden, "device name {s}", .{device_name}) };
    lines[7] = .{ .text = try garden.dupe(u8, "unified fold green") };
    return lines;
}

