# env.rish — tests for the `env` process-environment builtin.

let home = env "HOME"
let home_len = length home
assert home_len != 0 else "HOME should be set on this host"

let missing = env "RISHI_DEFINITELY_UNSET_VAR_XYZ"
assert missing == "" else "unset env var should be empty string"

say "env builtin held."
