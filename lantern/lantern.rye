fn welcome_allow_count(io: std.Io) !void {
    const cwd = Dir.cwd();
    var buf: [1024]u8 = undefined;
    const text = try cwd.readFile(io, allow_count_fixture_path, &buf);
    var allow_buf: [1024]u8 = undefined;
    const allow = try cwd.readFile(io, allow_fixture_path, &allow_buf);
    const req = lc.Request{
        .model_hash = "sha3-256-rye-forge-lap0",
        .prompt = "listed",
        .max_tokens = 64,
    };
    const resp = try lc.complete_allowed(req, text, allow);
    assert(resp.stopped_reason == .eos);
    assert(lc.count_allowed_models(allow) == 2);
    print("lantern: allow_count pin completion — count 2\n", .{});
}

