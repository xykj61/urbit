fn unwelcome_bad_user() !void {
    var long_user: [lc.max_user_len + 1]u8 = undefined;
    @memset(&long_user, 'u');
    const req = lc.Request{
        .model_hash = "sha3-256-rye-forge-lap0",
        .prompt = "x",
        .max_tokens = 64,
        .user = &long_user,
    };
    if (lc.validate_request(req)) |_| {
        return error.UnwelcomePassed;
    } else |err| {
        assert(err == error.BadUser);
    }
    print("lantern: bad user refused\n", .{});
}



/// RW-5 contract — six welcome / unwelcome probes on the mirrored pair surface.
fn run_rw5_contract_test(io: std.Io) !u8 {
    try welcome_complete(io);
    try welcome_echo_pin(io);
    try welcome_user_pin(io);
    try unwelcome_model_mismatch(io);
    try unwelcome_echo_mismatch(io);
    try unwelcome_user_mismatch(io);
    print("lantern rw5 contract: 6/6 GREEN\n", .{});
    return 0;
}

pub fn main(init: std.process.Init) !u8 {
    const garden = init.arena.allocator();
    const io = init.io;
    const args = try init.minimal.args.toSlice(garden);
    if (args.len >= 2 and std.mem.eql(u8, args[1], "selftest")) {
        try welcome_complete(io);
        try welcome_length_budget(io);
        try welcome_allowlist(io);
        try welcome_seed_temperature(io);
        try welcome_top_p(io);
        try welcome_err_stop(io);
        try welcome_stop_sequence(io);
        try welcome_prompt_pin(io);
        try welcome_max_tokens_pin(io);
        try welcome_text_pin(io);
        try welcome_temperature_pin(io);
        try welcome_seed_pin(io);
        try welcome_err_stop_pin(io);
        try welcome_length_stop_pin(io);
        try welcome_allow_count(io);
        try welcome_dual_model_allow(io);
        try welcome_require_model(io);
        try welcome_stopped_reason_pin(io);
        try welcome_stopped_reason_length_pin(io);
        try welcome_stopped_reason_err_stop_pin(io);
        try welcome_stopped_reason_stop_sequence_pin(io);
        try welcome_stream_pin(io);
        try welcome_stream_on(io);
        try welcome_top_k_pin(io);
        try welcome_frequency_penalty_pin(io);
        try welcome_presence_penalty_pin(io);
        try welcome_n_pin(io);
        try welcome_tokens_out_pin(io);
        try welcome_tokens_in_pin(io);
        try welcome_echo_pin(io);
        try welcome_user_pin(io);
        try unwelcome_model_mismatch(io);
        try unwelcome_prompt_too_long();
        try unwelcome_zero_budget();
        try unwelcome_allowlist_refuse(io);
        try unwelcome_bad_temperature();
        try unwelcome_seed_mismatch(io);
        try unwelcome_seed_pin_mismatch(io);
        try unwelcome_bad_top_p();
        try unwelcome_top_p_mismatch(io);
        try unwelcome_stop_sequence_mismatch(io);
        try unwelcome_bad_stop_sequence();
        try unwelcome_prompt_mismatch(io);
        try unwelcome_max_tokens_mismatch(io);
        try unwelcome_text_mismatch(io);
        try unwelcome_temperature_mismatch(io);
        try unwelcome_err_stop_pin_mismatch(io);
        try unwelcome_length_stop_pin_mismatch(io);
        try unwelcome_allow_count_mismatch(io);
        try unwelcome_empty_allow_list(io);
        try unwelcome_require_model_missing(io);
        try unwelcome_stopped_reason_mismatch(io);
        try unwelcome_stream_mismatch(io);
        try unwelcome_top_k_mismatch(io);
        try unwelcome_frequency_penalty_mismatch(io);
        try unwelcome_presence_penalty_mismatch(io);
        try unwelcome_n_mismatch(io);
        try unwelcome_tokens_out_mismatch(io);
        try unwelcome_tokens_in_mismatch(io);
        try unwelcome_echo_mismatch(io);
        try unwelcome_user_mismatch(io);
        try unwelcome_bad_user();
        print("lantern lap33: version {s} — GREEN\n", .{lantern_version});
        return 0;
    }
    if (args.len >= 2 and std.mem.eql(u8, args[1], "rw5contracttest")) {
        return run_rw5_contract_test(io);
    }
    print("usage: lantern selftest|rw5contracttest\n", .{});
    return 1;
}
