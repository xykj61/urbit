//! glow/sample_demo_fact_line_lits_witness.rye — demo fact-line pins as face=lit.
//!
//! Pins must match linengrow/glow_sala_b0_line.rye demo_sig/fact · sig2/fact2 ·
//! sig3/fact3 (STOA225 · STOA231). Duplicated here — Glow cannot import linengrow.
//!
//!   rye build glow/sample_demo_fact_line_lits_witness.rye \
//!     -femit-bin=glow/bin/sample_demo_fact_line_lits_witness

const std = @import("std");
const assert = std.debug.assert;
const print = std.debug.print;
const face_lit = @import("face_lit.rye");
const lower = @import("lower_face_lit.rye");

const witness_version = "20260722.135948";

const demo_sig_hex =
    "93c92d1b6ac994d9560cc26480f36661f23be0144ac29e603d3f761df565a6c662a6083bca0e39bb3ca36d3b785789b1cc34d1bd491f5fa1eddd7a961684300b";
const demo_fact_hex =
    "";
const demo_sig2_hex =
    "cbff6d796bfc1880950a31752483526f394fcf7f5a5d31267289735637ec9b7a02b2a8d92b8edcdcac77cf30a44f973225356043c6777a67c0ad99e8df34bf0f";
const demo_fact2_hex =
    "";
const demo_sig3_hex =
    "33e4b1c91aa10787dec97f3db5e0f661d816eacdf97bfd28f24f38a7d23048ec7858fddc2259a2ff78bfe4e900e689b5a9612270ad365ab2ffa527bb44fd1f0e";
const demo_fact3_hex =
    "";

fn find_face(specs: []const face_lit.FaceLitSpec, name: []const u8) ?usize {
    var i: u32 = 0;
    const n: u32 = @intCast(specs.len);
    while (i < n) : (i += 1) {
        if (std.mem.eql(u8, face_lit.face_slice(&specs[@as(usize, @intCast(i))]), name))
            return @as(usize, @intCast(i));
    }
    return null;
}

fn run_selftest(init: std.process.Init) !u8 {
    print("sample_demo_fact_line_lits_witness {s}\n", .{witness_version});

    const a = init.arena.allocator();
    const cwd = std.Io.Dir.cwd();
    const io = init.io;
    const src = try cwd.readFileAlloc(io, "glow/gen/sample-demo-fact-line-lits.glow", a, .limited(8192));

    var specs: [face_lit.max_face_lits]face_lit.FaceLitSpec = undefined;
    const n = try face_lit.parse_face_lit_sample(src, specs[0..]);
    assert(n == 6);
    print("fact-line-lits: six face=lit clauses parse -- GREEN\n", .{});

    const i_sig = find_face(specs[0..n], "sig") orelse return error.MissingSig;
    const i_fact = find_face(specs[0..n], "fact") orelse return error.MissingFact;
    const i_sig2 = find_face(specs[0..n], "sig2") orelse return error.MissingSig2;
    const i_fact2 = find_face(specs[0..n], "fact2") orelse return error.MissingFact2;
    const i_sig3 = find_face(specs[0..n], "sig3") orelse return error.MissingSig3;
    const i_fact3 = find_face(specs[0..n], "fact3") orelse return error.MissingFact3;
    assert(specs[i_sig].lit_kind == .cord);
    assert(specs[i_fact].lit_kind == .cord);
    assert(specs[i_sig2].lit_kind == .cord);
    assert(specs[i_fact2].lit_kind == .cord);
    assert(specs[i_sig3].lit_kind == .cord);
    assert(specs[i_fact3].lit_kind == .cord);
    assert(std.mem.eql(u8, face_lit.lit_bytes(src, &specs[i_sig]), demo_sig_hex));
    assert(std.mem.eql(u8, face_lit.lit_bytes(src, &specs[i_fact]), demo_fact_hex));
    assert(std.mem.eql(u8, face_lit.lit_bytes(src, &specs[i_sig2]), demo_sig2_hex));
    assert(std.mem.eql(u8, face_lit.lit_bytes(src, &specs[i_fact2]), demo_fact2_hex));
    assert(std.mem.eql(u8, face_lit.lit_bytes(src, &specs[i_sig3]), demo_sig3_hex));
    assert(std.mem.eql(u8, face_lit.lit_bytes(src, &specs[i_fact3]), demo_fact3_hex));
    print("fact-line-lits: demo sig fact pins match -- GREEN\n", .{});

    var buf: [64 * 1024]u8 = undefined;
    const nl = try lower.lower_source_welcome(src, &buf);
    assert(std.mem.indexOf(u8, buf[0..nl], demo_sig_hex[0..16]) != null);
    assert(std.mem.indexOf(u8, buf[0..nl], demo_sig2_hex[0..16]) != null);
    assert(std.mem.indexOf(u8, buf[0..nl], demo_sig3_hex[0..16]) != null);
    assert(std.mem.indexOf(u8, buf[0..nl], "glow_demo_cord") == null);
    print("fact-line-lits: lower emit carries demo pins -- GREEN\n", .{});

    print("fact-line-lits: STOA225 desk pin -- GREEN\n", .{});
    print("fact-line-lits: STOA231 event 2-3 desk pins -- GREEN\n", .{});
    print("fact-line-lits: STOA241 glow face_lit side agrees pins -- GREEN\n", .{});
    return 0;
}

pub fn main(init: std.process.Init) !u8 {
    return run_selftest(init);
}
