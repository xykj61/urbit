}

/// STOA143: closed seven-field `$:` hepta-mold call body → HeptaShape flip (via STOA259).
fn emit_hepta_call_body(out: []u8, zface: []const u8, gate: []const u8, comment: []const u8) LowerError!u32 {
    assert(rb.is_hepta_call_gate(gate)); // parse/lower pin — flip only today
    return emit_n_field_flip_call_body(out, 7, zface, comment);
}

/// STOA145: closed eight-field `$:` octa-mold call body → OctaShape flip (via STOA259).
fn emit_octa_call_body(out: []u8, zface: []const u8, gate: []const u8, comment: []const u8) LowerError!u32 {
    assert(rb.is_octa_call_gate(gate)); // parse/lower pin — flip only today
    return emit_n_field_flip_call_body(out, 8, zface, comment);
}

/// STOA147: closed nine-field `$:` nona-mold call body → NonaShape flip (via STOA259).
fn emit_nona_call_body(out: []u8, zface: []const u8, gate: []const u8, comment: []const u8) LowerError!u32 {
    assert(rb.is_nona_call_gate(gate)); // parse/lower pin — flip only today
    return emit_n_field_flip_call_body(out, 9, zface, comment);
}

fn emit(spec: *const rb.GateSpec, out: []u8) LowerError!u32 {
    const face = rb.face_slice(spec);
    assert(face.len > 0); // invariant: spec carries a non-empty face
    const mold = sample_mold_label(spec);
    var zig_face_buf: [rb.max_face_len]u8 = undefined;
    const zn = try zig_safe_ident(face, &zig_face_buf);
    const zface = zig_face_buf[0..@as(usize, @intCast(zn))];

    if (is_kind_sample(spec)) {
        switch (spec.body) {
            .identity => {
                var comment_buf: [160]u8 = undefined;
                const comment = std.fmt.bufPrint(&comment_buf, "Lowered from Glow `|=  {s}={s}` bartis — KindShape identity (STOA123).", .{ face, mold }) catch return error.Overflow;
                return emit_kind_identity(out, zface, comment);
            },
            .call_one => {
                const gate = rb.gate_slice(spec);
                if (!rb.is_kind_call_gate(gate)) return error.BodyGateNotYetLowered;
                var comment_buf: [192]u8 = undefined;
                const comment = std.fmt.bufPrint(&comment_buf, "Lowered from Glow `|=  {s}={s}` / `%-  {s}  {s}` — KindShape call body (STOA127).", .{ face, mold, gate, face }) catch return error.Overflow;
                return emit_kind_call_body(out, zface, gate, comment);
            },
        }
    }

    if (is_xact_sample(spec)) {
        switch (spec.body) {
            .identity => {
                var comment_buf: [160]u8 = undefined;
                const comment = std.fmt.bufPrint(&comment_buf, "Lowered from Glow `|=  {s}={s}` bartis — XactShape identity (STOA124).", .{ face, mold }) catch return error.Overflow;
                return emit_xact_identity(out, zface, comment);
            },
            .call_one => {
                const gate = rb.gate_slice(spec);
                if (!rb.is_xact_call_gate(gate)) return error.BodyGateNotYetLowered;
                var comment_buf: [192]u8 = undefined;
                const comment = std.fmt.bufPrint(&comment_buf, "Lowered from Glow `|=  {s}={s}` / `%-  {s}  {s}` — XactShape call body (STOA128).", .{ face, mold, gate, face }) catch return error.Overflow;
                return emit_xact_call_body(out, zface, gate, comment);
            },
        }
    }

    if (is_xfer_sample(spec)) {
        switch (spec.body) {
            .identity => {
                var comment_buf: [160]u8 = undefined;
                const comment = std.fmt.bufPrint(&comment_buf, "Lowered from Glow `|=  {s}={s}` bartis — XferShape identity (STOA125).", .{ face, mold }) catch return error.Overflow;
                return emit_xfer_identity(out, zface, comment);
            },
            .call_one => {
                const gate = rb.gate_slice(spec);
                if (!rb.is_xfer_call_gate(gate)) return error.BodyGateNotYetLowered;
                var comment_buf: [192]u8 = undefined;
                const comment = std.fmt.bufPrint(&comment_buf, "Lowered from Glow `|=  {s}={s}` / `%-  {s}  {s}` — XferShape call body (STOA129).", .{ face, mold, gate, face }) catch return error.Overflow;
                return emit_xfer_call_body(out, zface, gate, comment);
            },
        }
    }

    if (is_pair_sample(spec)) {
        switch (spec.body) {
            .identity => {
                var comment_buf: [160]u8 = undefined;
                const comment = std.fmt.bufPrint(&comment_buf, "Lowered from Glow `|=  {s}={s}` bartis — PairShape identity (STOA126).", .{ face, mold }) catch return error.Overflow;
                return emit_pair_identity(out, zface, comment);
            },
            .call_one => {
                const gate = rb.gate_slice(spec);
                if (!rb.is_pair_call_gate(gate)) return error.BodyGateNotYetLowered;
                var comment_buf: [192]u8 = undefined;
                const comment = std.fmt.bufPrint(&comment_buf, "Lowered from Glow `|=  {s}={s}` / `%-  {s}  {s}` — PairShape call body (STOA131).", .{ face, mold, gate, face }) catch return error.Overflow;
                return emit_pair_call_body(out, zface, gate, comment);
            },
        }
    }

    if (is_triple_sample(spec)) {
        switch (spec.body) {
            .identity => {
                var comment_buf: [160]u8 = undefined;
                const comment = std.fmt.bufPrint(&comment_buf, "Lowered from Glow `|=  {s}={s}` bartis — TripleShape identity (STOA134).", .{ face, mold }) catch return error.Overflow;
                return emit_triple_identity(out, zface, comment);
            },
            .call_one => {
                const gate = rb.gate_slice(spec);
                if (!rb.is_triple_call_gate(gate)) return error.BodyGateNotYetLowered;
                var comment_buf: [192]u8 = undefined;
                const comment = std.fmt.bufPrint(&comment_buf, "Lowered from Glow `|=  {s}={s}` / `%-  {s}  {s}` — TripleShape call body (STOA136).", .{ face, mold, gate, face }) catch return error.Overflow;
                return emit_triple_call_body(out, zface, gate, comment);
            },
        }
    }

    if (is_quad_sample(spec)) {
        switch (spec.body) {
            .identity => {
                var comment_buf: [160]u8 = undefined;
                const comment = std.fmt.bufPrint(&comment_buf, "Lowered from Glow `|=  {s}={s}` bartis — QuadShape identity (STOA135).", .{ face, mold }) catch return error.Overflow;
                return emit_quad_identity(out, zface, comment);
            },
            .call_one => {
                const gate = rb.gate_slice(spec);
                if (!rb.is_quad_call_gate(gate)) return error.BodyGateNotYetLowered;
                var comment_buf: [192]u8 = undefined;
                const comment = std.fmt.bufPrint(&comment_buf, "Lowered from Glow `|=  {s}={s}` / `%-  {s}  {s}` — QuadShape call body (STOA137).", .{ face, mold, gate, face }) catch return error.Overflow;
                return emit_quad_call_body(out, zface, gate, comment);
            },
        }
    }

    // STOA138 / STOA139: penta-mold identity · flip call-body — five slots 5/3/1/2/7.
    if (is_penta_sample(spec)) {
        switch (spec.body) {
            .identity => {
                var comment_buf: [160]u8 = undefined;
                const comment = std.fmt.bufPrint(&comment_buf, "Lowered from Glow `|=  {s}={s}` bartis — PentaShape identity (STOA138).", .{ face, mold }) catch return error.Overflow;
                return emit_penta_identity(out, zface, comment);
            },
            .call_one => {
                const gate = rb.gate_slice(spec);
                if (!rb.is_penta_call_gate(gate)) return error.BodyGateNotYetLowered;
                var comment_buf: [192]u8 = undefined;
                const comment = std.fmt.bufPrint(&comment_buf, "Lowered from Glow `|=  {s}={s}` / `%-  {s}  {s}` — PentaShape call body (STOA139).", .{ face, mold, gate, face }) catch return error.Overflow;
                return emit_penta_call_body(out, zface, gate, comment);
            },
        }
    }

    // STOA140 / STOA141: hexa-mold identity · flip call-body — six slots 5/3/1/2/7/4.
    if (is_hexa_sample(spec)) {
        switch (spec.body) {
            .identity => {
                var comment_buf: [160]u8 = undefined;
                const comment = std.fmt.bufPrint(&comment_buf, "Lowered from Glow `|=  {s}={s}` bartis — HexaShape identity (STOA140).", .{ face, mold }) catch return error.Overflow;
                return emit_hexa_identity(out, zface, comment);
            },
            .call_one => {
                const gate = rb.gate_slice(spec);
                if (!rb.is_hexa_call_gate(gate)) return error.BodyGateNotYetLowered;
                var comment_buf: [192]u8 = undefined;
                const comment = std.fmt.bufPrint(&comment_buf, "Lowered from Glow `|=  {s}={s}` / `%-  {s}  {s}` — HexaShape call body (STOA141).", .{ face, mold, gate, face }) catch return error.Overflow;
                return emit_hexa_call_body(out, zface, gate, comment);
            },
        }
    }

    // STOA142 / STOA143: hepta-mold identity · flip call-body — seven slots 5/3/1/2/7/4/6.
    if (is_hepta_sample(spec)) {
        switch (spec.body) {
            .identity => {
                var comment_buf: [160]u8 = undefined;
                const comment = std.fmt.bufPrint(&comment_buf, "Lowered from Glow `|=  {s}={s}` bartis — HeptaShape identity (STOA142).", .{ face, mold }) catch return error.Overflow;
                return emit_hepta_identity(out, zface, comment);
            },
            .call_one => {
                const gate = rb.gate_slice(spec);
                if (!rb.is_hepta_call_gate(gate)) return error.BodyGateNotYetLowered;
                var comment_buf: [192]u8 = undefined;
                const comment = std.fmt.bufPrint(&comment_buf, "Lowered from Glow `|=  {s}={s}` / `%-  {s}  {s}` — HeptaShape call body (STOA143).", .{ face, mold, gate, face }) catch return error.Overflow;
                return emit_hepta_call_body(out, zface, gate, comment);
            },
        }
    }

    // STOA144 / STOA145: octa-mold identity · flip call-body — eight slots 5/3/1/2/7/4/6/8.
    if (is_octa_sample(spec)) {
        switch (spec.body) {
            .identity => {
                var comment_buf: [160]u8 = undefined;
                const comment = std.fmt.bufPrint(&comment_buf, "Lowered from Glow `|=  {s}={s}` bartis — OctaShape identity (STOA144).", .{ face, mold }) catch return error.Overflow;
                return emit_octa_identity(out, zface, comment);
            },
            .call_one => {
                const gate = rb.gate_slice(spec);
                if (!rb.is_octa_call_gate(gate)) return error.BodyGateNotYetLowered;
                var comment_buf: [192]u8 = undefined;
                const comment = std.fmt.bufPrint(&comment_buf, "Lowered from Glow `|=  {s}={s}` / `%-  {s}  {s}` — OctaShape call body (STOA145).", .{ face, mold, gate, face }) catch return error.Overflow;
                return emit_octa_call_body(out, zface, gate, comment);
            },
        }
    }

    // STOA146 / STOA147: nona-mold identity · flip call-body — nine slots 5/3/1/2/7/4/6/8/9.
    if (is_nona_sample(spec)) {
        switch (spec.body) {
            .identity => {
                var comment_buf: [160]u8 = undefined;
                const comment = std.fmt.bufPrint(&comment_buf, "Lowered from Glow `|=  {s}={s}` bartis — NonaShape identity (STOA146).", .{ face, mold }) catch return error.Overflow;
                return emit_nona_identity(out, zface, comment);
            },
            .call_one => {
                const gate = rb.gate_slice(spec);
                if (!rb.is_nona_call_gate(gate)) return error.BodyGateNotYetLowered;
                var comment_buf: [192]u8 = undefined;
                const comment = std.fmt.bufPrint(&comment_buf, "Lowered from Glow `|=  {s}={s}` / `%-  {s}  {s}` — NonaShape call body (STOA147).", .{ face, mold, gate, face }) catch return error.Overflow;
                return emit_nona_call_body(out, zface, gate, comment);
            },
        }
    }

    const expect = try expect_for(spec);
    var used: u32 = 0;

    try emit_prelude(out, &used);
    switch (spec.body) {
        .identity => {
            var comment_buf: [160]u8 = undefined;
            const comment = std.fmt.bufPrint(&comment_buf, "Lowered from Glow `|=  {s}={s}` bartis gate — identity (STOA100/109).", .{ face, mold }) catch return error.Overflow;
            try emit_gate_fn(out, &used, face, zface, zface, comment);
            try emit_welcome_main(out, &used, zface, expect);
        },
        .call_one => {
            const gate = rb.gate_slice(spec);
            assert(rb.is_closed_call_gate(gate)); // parse pin
            const op = try call_op_expr(gate);
            var body_buf: [96]u8 = undefined;
            const body_return = std.fmt.bufPrint(&body_buf, "{s}{s}", .{ zface, op }) catch return error.Overflow;
            var comment_buf: [192]u8 = undefined;
            const comment = std.fmt.bufPrint(&comment_buf, "Lowered from Glow `|=  {s}={s}` / `%-  {s}  {s}` — call body (STOA103–104).", .{ face, mold, gate, face }) catch return error.Overflow;
            try emit_gate_fn(out, &used, face, zface, body_return, comment);
            try emit_welcome_main(out, &used, zface, expect);
        },
    }
    return used;
}

fn emit_argv(spec: *const rb.GateSpec, out: []u8) LowerError!u32 {
    const face = rb.face_slice(spec);
    assert(face.len > 0); // invariant: spec carries a non-empty face
    const mold = sample_mold_label(spec);
    var zig_face_buf: [rb.max_face_len]u8 = undefined;
    const zn = try zig_safe_ident(face, &zig_face_buf);
    const zface = zig_face_buf[0..@as(usize, @intCast(zn))];

    // STOA300: kind unit-tag argv identity — distinct from u32 parseInt reader.
    if (is_kind_sample(spec)) {
        switch (spec.body) {
            .identity => {
                var comment_buf: [192]u8 = undefined;
                const comment = std.fmt.bufPrint(&comment_buf, "Lowered from Glow `|=  {s}={s}` bartis — KindShape argv tag (STOA300).", .{ face, mold }) catch return error.Overflow;
                return emit_kind_argv(out, zface, comment);
            },
            .call_one => return error.SampleDoesNotNest,
        }
    }

    // STOA303: xact payload argv identity — tag + amount; distinct from kind and u32-only.
    if (is_xact_sample(spec)) {
        switch (spec.body) {
            .identity => {
                var comment_buf: [192]u8 = undefined;
                const comment = std.fmt.bufPrint(&comment_buf, "Lowered from Glow `|=  {s}={s}` bartis — XactShape argv payload (STOA303).", .{ face, mold }) catch return error.Overflow;
                return emit_xact_argv(out, zface, comment);
            },
            .call_one => return error.SampleDoesNotNest,
        }
    }

    // STOA305: xfer payload argv identity — tag + from/amount.
    if (is_xfer_sample(spec)) {
        switch (spec.body) {
            .identity => {
                var comment_buf: [192]u8 = undefined;
                const comment = std.fmt.bufPrint(&comment_buf, "Lowered from Glow `|=  {s}={s}` bartis — XferShape argv payload (STOA305).", .{ face, mold }) catch return error.Overflow;
                return emit_xfer_argv(out, zface, comment);
            },
            .call_one => return error.SampleDoesNotNest,
        }
    }

    // STOA307: pair `$:` argv identity — two field decimals.
    if (is_pair_sample(spec)) {
        switch (spec.body) {
            .identity => {
                var comment_buf: [192]u8 = undefined;
                const comment = std.fmt.bufPrint(&comment_buf, "Lowered from Glow `|=  {s}={s}` bartis — PairShape argv fields (STOA307).", .{ face, mold }) catch return error.Overflow;
                return emit_pair_argv(out, zface, comment);
            },
            .call_one => return error.SampleDoesNotNest,
        }
    }

    // STOA309: triple `$:` argv identity — three field decimals.
    if (is_triple_sample(spec)) {
        switch (spec.body) {
            .identity => {
                var comment_buf: [192]u8 = undefined;
                const comment = std.fmt.bufPrint(&comment_buf, "Lowered from Glow `|=  {s}={s}` bartis — TripleShape argv fields (STOA309).", .{ face, mold }) catch return error.Overflow;
                return emit_triple_argv(out, zface, comment);
            },
            .call_one => return error.SampleDoesNotNest,
        }
    }

    // STOA311: quad `$:` argv identity — four field decimals.
    if (is_quad_sample(spec)) {
        switch (spec.body) {
            .identity => {
                var comment_buf: [192]u8 = undefined;
                const comment = std.fmt.bufPrint(&comment_buf, "Lowered from Glow `|=  {s}={s}` bartis — QuadShape argv fields (STOA311).", .{ face, mold }) catch return error.Overflow;
                return emit_quad_argv(out, zface, comment);
            },
            .call_one => return error.SampleDoesNotNest,
        }
    }

    // STOA313: penta `$:` argv identity — five field decimals; hexa…nona held.
    if (is_penta_sample(spec)) {
        switch (spec.body) {
            .identity => {
                var comment_buf: [192]u8 = undefined;
                const comment = std.fmt.bufPrint(&comment_buf, "Lowered from Glow `|=  {s}={s}` bartis — PentaShape argv fields (STOA313).", .{ face, mold }) catch return error.Overflow;
                return emit_penta_argv(out, zface, comment);
            },
            .call_one => return error.SampleDoesNotNest,
        }
    }

    if (is_hexa_sample(spec) or is_hepta_sample(spec) or is_octa_sample(spec) or is_nona_sample(spec)) return error.SampleDoesNotNest;
    var used: u32 = 0;

    try emit_prelude(out, &used);
    switch (spec.body) {
        .identity => {
            var comment_buf: [160]u8 = undefined;
            const comment = std.fmt.bufPrint(&comment_buf, "Lowered from Glow `|=  {s}={s}` bartis gate — argv sample (STOA101/109).", .{ face, mold }) catch return error.Overflow;
            try emit_gate_fn(out, &used, face, zface, zface, comment);
            try emit_argv_main(out, &used, zface, zface);
        },
        .call_one => {
            const gate = rb.gate_slice(spec);
            assert(rb.is_closed_call_gate(gate)); // parse pin
            const op = try call_op_expr(gate);
            var body_buf: [96]u8 = undefined;
            const body_return = std.fmt.bufPrint(&body_buf, "{s}{s}", .{ zface, op }) catch return error.Overflow;
            var expect_buf: [96]u8 = undefined;
            const expect_expr = std.fmt.bufPrint(&expect_buf, "{s}{s}", .{ zface, op }) catch return error.Overflow;
            var comment_buf: [192]u8 = undefined;
            const comment = std.fmt.bufPrint(&comment_buf, "Lowered from Glow `|=  {s}={s}` / `%-  {s}  {s}` — argv call body (STOA103–104).", .{ face, mold, gate, face }) catch return error.Overflow;
            try emit_gate_fn(out, &used, face, zface, body_return, comment);
            try emit_argv_main(out, &used, zface, expect_expr);
        },
    }
    return used;
}

/// Parse a bartis source and emit a welcome-path program (baked sample 5).
pub fn lower_source_welcome(src: []const u8, out: []u8) LowerError!u32 {
    const spec = try rb.parse_source(src);
    return emit(&spec, out);
}

/// Parse a bartis source and emit an argv-sample program (`@u32` or kind unit tag).
pub fn lower_source_argv_sample(src: []const u8, out: []u8) LowerError!u32 {
    const spec = try rb.parse_source(src);
    return emit_argv(&spec, out);
}
