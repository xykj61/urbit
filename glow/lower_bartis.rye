pub const bartis_octa_demo_via: u32 = 8;
pub const bartis_nona_demo_from: u32 = 5;
pub const bartis_nona_demo_amount: u32 = 3;
pub const bartis_nona_demo_fee: u32 = 1;
pub const bartis_nona_demo_nonce: u32 = 2;
pub const bartis_nona_demo_memo: u32 = 7;
pub const bartis_nona_demo_tag: u32 = 4;
pub const bartis_nona_demo_to: u32 = 6;
