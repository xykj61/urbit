/// STOA293: one tagged-payload `$%` flip call-body emit for xact (1 mint face) and xfer (2).
/// mint → .send; send → empty mint. Distinct from KindShape unit-enum flip and from `$:` N-field.
fn emit_tagged_payload_flip_call_body(out: []u8, mint_faces: u32, zface: []const u8, comment: []const u8) LowerError!u32 {
    assert(mint_faces == 1 or mint_faces == 2);
    const zig_type: []const u8 = if (mint_faces == 1) "XactShape" else "XferShape";
    var used: u32 = 0;
    try append_print(out, &used, "const std = @import(\"std\");\n\n", .{});
    try append_print(out, &used, "pub const {s} = union(enum) {{\n", .{zig_type});
    if (mint_faces == 1) {
        try append_print(out, &used, "    mint: struct {{ amount: u32 = 0 }},\n", .{});
    } else {
        try append_print(out, &used, "    mint: struct {{ from: u32 = 0, amount: u32 = 0 }},\n", .{});
    }
    try append_print(out, &used, "    send,\n", .{});
    try append_print(out, &used, "}};\n\n", .{});
    try append_print(out, &used, "/// {s}\n", .{comment});
    try append_print(out, &used, "fn bartis_gate({s}: {s}) {s} {{\n", .{ zface, zig_type, zig_type });
    if (mint_faces == 1) {
        try append_print(out, &used, "    return switch ({s}) {{ .mint => .send, .send => .{{ .mint = .{{ .amount = 0 }} }} }};\n", .{zface});
    } else {
        try append_print(out, &used, "    return switch ({s}) {{ .mint => .send, .send => .{{ .mint = .{{ .from = 0, .amount = 0 }} }} }};\n", .{zface});
    }
    try append_print(out, &used, "}}\n\n", .{});
    try append_print(out, &used, "pub fn main(_: std.process.Init) !u8 {{\n", .{});
    if (mint_faces == 1) {
        try append_print(out, &used, "    const {s}: {s} = .{{ .mint = .{{ .amount = {d} }} }};\n", .{ zface, zig_type, bartis_demo_sample });
    } else {
        try append_print(out, &used, "    const {s}: {s} = .{{ .mint = .{{ .from = {d}, .amount = {d} }} }};\n", .{ zface, zig_type, bartis_xfer_demo_from, bartis_xfer_demo_amount });
    }
    try append_print(out, &used, "    return switch (bartis_gate({s})) {{\n", .{zface});
    try append_print(out, &used, "        .send => 0,\n", .{});
    try append_print(out, &used, "        .mint => 1,\n", .{});
    try append_print(out, &used, "    }};\n", .{});
    try append_print(out, &used, "}}\n", .{});
    return used;
}

/// Closed `$:` face order for pair…nona identity emit (STOA253).
const closed_tuple_faces = [_][]const u8{ "from", "amount", "fee", "nonce", "memo", "tag", "to", "via", "ref" };

/// Closed `$:` demo vals for pair…nona identity emit (STOA253) — matches seated pins.
const closed_tuple_demos = [_]u32{ 5, 3, 1, 2, 7, 4, 6, 8, 9 };

fn closed_tuple_type_name(field_count: u32) []const u8 {
    return switch (field_count) {
        2 => "PairShape",
        3 => "TripleShape",
        4 => "QuadShape",
        5 => "PentaShape",
        6 => "HexaShape",
        7 => "HeptaShape",
        8 => "OctaShape",
        9 => "NonaShape",
        else => unreachable,
    };
}

/// STOA307: N-field `$:` argv identity — parse N decimals from argv[1..N] into the closed tuple.
/// Pair first (N=2). Distinct from tagged `$%` argv and from single-u32 parseInt.
fn emit_n_field_argv(out: []u8, field_count: u32, zface: []const u8, comment: []const u8) LowerError!u32 {
    assert(field_count >= 2);
    assert(field_count <= 9);
    const zig_type = closed_tuple_type_name(field_count);
    var used: u32 = 0;
    try append_print(out, &used, "const std = @import(\"std\");\n\n", .{});
    try append_print(out, &used, "pub const {s} = struct {{\n", .{zig_type});
    var i: u32 = 0;
    while (i < field_count) : (i += 1) {
        try append_print(out, &used, "    {s}: u32 = 0,\n", .{closed_tuple_faces[@as(usize, @intCast(i))]});
    }
    try append_print(out, &used, "}};\n\n", .{});
    try append_print(out, &used, "/// {s}\n", .{comment});
    try append_print(out, &used, "fn bartis_gate({s}: {s}) {s} {{\n", .{ zface, zig_type, zig_type });
    try append_print(out, &used, "    return {s};\n", .{zface});
    try append_print(out, &used, "}}\n\n", .{});
    try append_print(out, &used, "pub fn main(init: std.process.Init) !u8 {{\n", .{});
    try append_print(out, &used, "    const alloc = init.arena.allocator();\n", .{});
    try append_print(out, &used, "    const argv = try init.minimal.args.toSlice(alloc);\n", .{});
    try append_print(out, &used, "    if (argv.len < {d}) return 2;\n", .{field_count + 1});
    i = 0;
    while (i < field_count) : (i += 1) {
        try append_print(out, &used, "    const {s} = std.fmt.parseInt(u32, argv[{d}], 10) catch return 2;\n", .{
            closed_tuple_faces[@as(usize, @intCast(i))],
            i + 1,
        });
    }
    try append_print(out, &used, "    const {s}: {s} = .{{ ", .{ zface, zig_type });
    i = 0;
    while (i < field_count) : (i += 1) {
        if (i > 0) try append_print(out, &used, ", ", .{});
        try append_print(out, &used, ".{s} = {s}", .{
            closed_tuple_faces[@as(usize, @intCast(i))],
            closed_tuple_faces[@as(usize, @intCast(i))],
        });
    }
    try append_print(out, &used, " }};\n", .{});
    try append_print(out, &used, "    const got = bartis_gate({s});\n", .{zface});
    try append_print(out, &used, "    return if (", .{});
    i = 0;
    while (i < field_count) : (i += 1) {
        if (i > 0) try append_print(out, &used, " and ", .{});
        try append_print(out, &used, "got.{s} == {s}", .{
            closed_tuple_faces[@as(usize, @intCast(i))],
            closed_tuple_faces[@as(usize, @intCast(i))],
        });
    }
    try append_print(out, &used, ") 0 else 1;\n", .{});
    try append_print(out, &used, "}}\n", .{});
    return used;
}

/// STOA307: closed two-field `$:` pair-mold argv → PairShape (via N-field argv).
fn emit_pair_argv(out: []u8, zface: []const u8, comment: []const u8) LowerError!u32 {
    return emit_n_field_argv(out, 2, zface, comment);
}

/// STOA309: closed three-field `$:` triple-mold argv → TripleShape (via N-field argv).
fn emit_triple_argv(out: []u8, zface: []const u8, comment: []const u8) LowerError!u32 {
    return emit_n_field_argv(out, 3, zface, comment);
}

/// STOA311: closed four-field `$:` quad-mold argv → QuadShape (via N-field argv).
fn emit_quad_argv(out: []u8, zface: []const u8, comment: []const u8) LowerError!u32 {
    return emit_n_field_argv(out, 4, zface, comment);
}

/// STOA313: closed five-field `$:` penta-mold argv → PentaShape (via N-field argv).
fn emit_penta_argv(out: []u8, zface: []const u8, comment: []const u8) LowerError!u32 {
    return emit_n_field_argv(out, 5, zface, comment);
}

/// STOA253: one N-field identity emit for closed `$:` pair…nona (N = 2…9).
fn emit_n_field_identity(out: []u8, field_count: u32, zface: []const u8, comment: []const u8) LowerError!u32 {
    assert(field_count >= 2);
    assert(field_count <= 9);
    const zig_type = closed_tuple_type_name(field_count);
    var used: u32 = 0;
    try append_print(out, &used, "const std = @import(\"std\");\n\n", .{});
    try append_print(out, &used, "pub const {s} = struct {{\n", .{zig_type});
    var i: u32 = 0;
    while (i < field_count) : (i += 1) {
        try append_print(out, &used, "    {s}: u32 = 0,\n", .{closed_tuple_faces[@as(usize, @intCast(i))]});
    }
    try append_print(out, &used, "}};\n\n", .{});
    try append_print(out, &used, "/// {s}\n", .{comment});
    try append_print(out, &used, "fn bartis_gate({s}: {s}) {s} {{\n", .{ zface, zig_type, zig_type });
    try append_print(out, &used, "    return {s};\n", .{zface});
    try append_print(out, &used, "}}\n\n", .{});
    try append_print(out, &used, "pub fn main(_: std.process.Init) !u8 {{\n", .{});
    try append_print(out, &used, "    const {s}: {s} = .{{ ", .{ zface, zig_type });
    i = 0;
    while (i < field_count) : (i += 1) {
        if (i > 0) try append_print(out, &used, ", ", .{});
        try append_print(out, &used, ".{s} = {d}", .{
            closed_tuple_faces[@as(usize, @intCast(i))],
            closed_tuple_demos[@as(usize, @intCast(i))],
        });
    }
    try append_print(out, &used, " }};\n", .{});
    try append_print(out, &used, "    const got = bartis_gate({s});\n", .{zface});
    try append_print(out, &used, "    return if (", .{});
    i = 0;
    while (i < field_count) : (i += 1) {
        if (i > 0) try append_print(out, &used, " and ", .{});
        try append_print(out, &used, "got.{s} == {d}", .{
            closed_tuple_faces[@as(usize, @intCast(i))],
            closed_tuple_demos[@as(usize, @intCast(i))],
        });
    }
    try append_print(out, &used, ") 0 else 1;\n", .{});
    try append_print(out, &used, "}}\n", .{});
    return used;
}

