/// STOA123: closed unit `$%` kind-mold identity → KindShape enum · baked `.mint`.
fn emit_kind_identity(out: []u8, zface: []const u8, comment: []const u8) LowerError!u32 {
    var used: u32 = 0;
    try append_print(out, &used, "const std = @import(\"std\");\n\n", .{});
    try append_print(out, &used, "pub const KindShape = enum(u8) {{\n", .{});
    try append_print(out, &used, "    mint,\n", .{});
    try append_print(out, &used, "    send,\n", .{});
    try append_print(out, &used, "}};\n\n", .{});
    try append_print(out, &used, "/// {s}\n", .{comment});
    try append_print(out, &used, "fn bartis_gate({s}: KindShape) KindShape {{\n", .{zface});
    try append_print(out, &used, "    return {s};\n", .{zface});
    try append_print(out, &used, "}}\n\n", .{});
    try append_print(out, &used, "pub fn main(_: std.process.Init) !u8 {{\n", .{});
    try append_print(out, &used, "    const {s}: KindShape = .mint;\n", .{zface});
    try append_print(out, &used, "    return if (bartis_gate({s}) == .mint) 0 else 1;\n", .{zface});
    try append_print(out, &used, "}}\n", .{});
    return used;
}

/// STOA300: closed unit `$%` kind-mold argv identity → KindShape · tag word from argv.
fn emit_kind_argv(out: []u8, zface: []const u8, comment: []const u8) LowerError!u32 {
    var used: u32 = 0;
    try append_print(out, &used, "const std = @import(\"std\");\n\n", .{});
    try append_print(out, &used, "pub const KindShape = enum(u8) {{\n", .{});
    try append_print(out, &used, "    mint,\n", .{});
    try append_print(out, &used, "    send,\n", .{});
    try append_print(out, &used, "}};\n\n", .{});
    try append_print(out, &used, "/// {s}\n", .{comment});
    try append_print(out, &used, "fn bartis_gate({s}: KindShape) KindShape {{\n", .{zface});
    try append_print(out, &used, "    return {s};\n", .{zface});
    try append_print(out, &used, "}}\n\n", .{});
    try append_print(out, &used, "pub fn main(init: std.process.Init) !u8 {{\n", .{});
    try append_print(out, &used, "    const alloc = init.arena.allocator();\n", .{});
    try append_print(out, &used, "    const argv = try init.minimal.args.toSlice(alloc);\n", .{});
    try append_print(out, &used, "    if (argv.len < 2) return 2;\n", .{});
    try append_print(out, &used, "    const tag = argv[1];\n", .{});
    try append_print(out, &used, "    const {s}: KindShape = if (std.mem.eql(u8, tag, \"mint\")) .mint else if (std.mem.eql(u8, tag, \"send\")) .send else return 2;\n", .{zface});
    try append_print(out, &used, "    return if (bartis_gate({s}) == {s}) 0 else 1;\n", .{ zface, zface });
    try append_print(out, &used, "}}\n", .{});
    return used;
}

/// STOA303: closed payload `$%` xact-mold argv identity → XactShape · tag + amount from argv.
/// `mint <u32>` → `.mint { .amount }` · `send` → `.send`. Distinct from kind unit tags and u32 parseInt-only.
fn emit_xact_argv(out: []u8, zface: []const u8, comment: []const u8) LowerError!u32 {
    var used: u32 = 0;
    try append_print(out, &used, "const std = @import(\"std\");\n\n", .{});
    try append_print(out, &used, "pub const XactShape = union(enum) {{\n", .{});
    try append_print(out, &used, "    mint: struct {{ amount: u32 = 0 }},\n", .{});
    try append_print(out, &used, "    send,\n", .{});
    try append_print(out, &used, "}};\n\n", .{});
    try append_print(out, &used, "/// {s}\n", .{comment});
    try append_print(out, &used, "fn bartis_gate({s}: XactShape) XactShape {{\n", .{zface});
    try append_print(out, &used, "    return {s};\n", .{zface});
    try append_print(out, &used, "}}\n\n", .{});
    try append_print(out, &used, "pub fn main(init: std.process.Init) !u8 {{\n", .{});
    try append_print(out, &used, "    const alloc = init.arena.allocator();\n", .{});
    try append_print(out, &used, "    const argv = try init.minimal.args.toSlice(alloc);\n", .{});
    try append_print(out, &used, "    if (argv.len < 2) return 2;\n", .{});
    try append_print(out, &used, "    const tag = argv[1];\n", .{});
    try append_print(out, &used, "    if (std.mem.eql(u8, tag, \"send\")) {{\n", .{});
    try append_print(out, &used, "        const {s}: XactShape = .send;\n", .{zface});
    try append_print(out, &used, "        return switch (bartis_gate({s})) {{ .send => 0, .mint => 1 }};\n", .{zface});
    try append_print(out, &used, "    }}\n", .{});
    try append_print(out, &used, "    if (!std.mem.eql(u8, tag, \"mint\")) return 2;\n", .{});
    try append_print(out, &used, "    if (argv.len < 3) return 2;\n", .{});
    try append_print(out, &used, "    const amount = std.fmt.parseInt(u32, argv[2], 10) catch return 2;\n", .{});
    try append_print(out, &used, "    const {s}: XactShape = .{{ .mint = .{{ .amount = amount }} }};\n", .{zface});
    try append_print(out, &used, "    return switch (bartis_gate({s})) {{\n", .{zface});
    try append_print(out, &used, "        .mint => |m| if (m.amount == amount) 0 else 1,\n", .{});
    try append_print(out, &used, "        .send => 1,\n", .{});
    try append_print(out, &used, "    }};\n", .{});
    try append_print(out, &used, "}}\n", .{});
    return used;
}

/// STOA305: closed multi-face payload `$%` xfer-mold argv identity → XferShape · tag + from/amount.
/// `mint <from> <amount>` / `send`. Distinct from xact (one mint face) and kind unit tags.
fn emit_xfer_argv(out: []u8, zface: []const u8, comment: []const u8) LowerError!u32 {
    var used: u32 = 0;
    try append_print(out, &used, "const std = @import(\"std\");\n\n", .{});
    try append_print(out, &used, "pub const XferShape = union(enum) {{\n", .{});
    try append_print(out, &used, "    mint: struct {{ from: u32 = 0, amount: u32 = 0 }},\n", .{});
    try append_print(out, &used, "    send,\n", .{});
    try append_print(out, &used, "}};\n\n", .{});
    try append_print(out, &used, "/// {s}\n", .{comment});
    try append_print(out, &used, "fn bartis_gate({s}: XferShape) XferShape {{\n", .{zface});
    try append_print(out, &used, "    return {s};\n", .{zface});
    try append_print(out, &used, "}}\n\n", .{});
    try append_print(out, &used, "pub fn main(init: std.process.Init) !u8 {{\n", .{});
    try append_print(out, &used, "    const alloc = init.arena.allocator();\n", .{});
    try append_print(out, &used, "    const argv = try init.minimal.args.toSlice(alloc);\n", .{});
    try append_print(out, &used, "    if (argv.len < 2) return 2;\n", .{});
    try append_print(out, &used, "    const tag = argv[1];\n", .{});
    try append_print(out, &used, "    if (std.mem.eql(u8, tag, \"send\")) {{\n", .{});
    try append_print(out, &used, "        const {s}: XferShape = .send;\n", .{zface});
    try append_print(out, &used, "        return switch (bartis_gate({s})) {{ .send => 0, .mint => 1 }};\n", .{zface});
    try append_print(out, &used, "    }}\n", .{});
    try append_print(out, &used, "    if (!std.mem.eql(u8, tag, \"mint\")) return 2;\n", .{});
    try append_print(out, &used, "    if (argv.len < 4) return 2;\n", .{});
    try append_print(out, &used, "    const from = std.fmt.parseInt(u32, argv[2], 10) catch return 2;\n", .{});
    try append_print(out, &used, "    const amount = std.fmt.parseInt(u32, argv[3], 10) catch return 2;\n", .{});
    try append_print(out, &used, "    const {s}: XferShape = .{{ .mint = .{{ .from = from, .amount = amount }} }};\n", .{zface});
    try append_print(out, &used, "    return switch (bartis_gate({s})) {{\n", .{zface});
    try append_print(out, &used, "        .mint => |m| if (m.from == from and m.amount == amount) 0 else 1,\n", .{});
    try append_print(out, &used, "        .send => 1,\n", .{});
    try append_print(out, &used, "    }};\n", .{});
    try append_print(out, &used, "}}\n", .{});
    return used;
}

/// STOA127 / STOA297: closed unit `$%` kind-mold call body → KindShape flip (via unit helper).
