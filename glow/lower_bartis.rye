pub const bartis_hepta_demo_to: u32 = 6;
pub const bartis_octa_demo_from: u32 = 5;
pub const bartis_octa_demo_amount: u32 = 3;
pub const bartis_octa_demo_fee: u32 = 1;
pub const bartis_octa_demo_nonce: u32 = 2;
