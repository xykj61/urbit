/// Assert `mold_name` nests under a unit `$%` ShapeSpec (kind-mold shape · STOA123).
pub fn assert_kind_shape_nests(mold_name: []const u8, spec: *const rune_shape.ShapeSpec) NestError!void {
    if (!is_kind_named_shape(mold_name)) return error.SampleDoesNotNest;
    if (!std.mem.eql(u8, rune_shape.name_slice(spec), mold_name)) return error.SampleDoesNotNest;
    if (spec.body != .tagged) return error.SampleDoesNotNest;
    if (spec.field_count < 1) return error.SampleDoesNotNest;
    if (rune_shape.any_payload(spec)) return error.SampleDoesNotNest;
}

/// Assert `mold_name` nests under a one-face payload `$%` ShapeSpec (xact-mold · STOA124).
pub fn assert_xact_shape_nests(mold_name: []const u8, spec: *const rune_shape.ShapeSpec) NestError!void {
    if (!is_xact_named_shape(mold_name)) return error.SampleDoesNotNest;
    if (!std.mem.eql(u8, rune_shape.name_slice(spec), mold_name)) return error.SampleDoesNotNest;
    if (spec.body != .tagged) return error.SampleDoesNotNest;
    if (spec.field_count < 1) return error.SampleDoesNotNest;
    if (!rune_shape.any_payload(spec)) return error.SampleDoesNotNest;
    if (any_multi_face_payload(spec)) return error.SampleDoesNotNest;
}

/// Assert `mold_name` nests under a multi-face payload `$%` ShapeSpec (xfer-mold · STOA125).
pub fn assert_xfer_shape_nests(mold_name: []const u8, spec: *const rune_shape.ShapeSpec) NestError!void {
    if (!is_xfer_named_shape(mold_name)) return error.SampleDoesNotNest;
    if (!std.mem.eql(u8, rune_shape.name_slice(spec), mold_name)) return error.SampleDoesNotNest;
    if (spec.body != .tagged) return error.SampleDoesNotNest;
    if (spec.field_count < 1) return error.SampleDoesNotNest;
    if (!rune_shape.any_payload(spec)) return error.SampleDoesNotNest;
    if (!any_multi_face_payload(spec)) return error.SampleDoesNotNest;
}

/// Assert a sample claim is stated. Nesting-flagged claims refuse `SampleDoesNotNest`.
/// STOA110 refuse kept beside STOA119 mold-bounded nesting accept.
/// Hoon study word for nesting here was *wet*.
pub fn assert_sample_not_nesting(is_nesting: bool) NestError!void {
    if (is_nesting) return error.SampleDoesNotNest;
}

/// Nesting-sample accept under a stated closed shape (STOA119 · STOA130 · STOA148–160).
/// Stated path (`is_nesting=false`): no-op success.
/// Nesting path (`is_nesting=true`): sample must nest under `stated_mold` via aura
/// equality (`@…`) or the closed named-shape allowlist
/// (amount · amount-shape · count · count-shape · kind · kind-shape · xact · xact-shape · xfer · xfer-shape · pair · pair-shape · triple · triple-shape · quad · quad-shape · penta · penta-shape · hexa · hexa-shape · hepta · hepta-shape · octa · octa-shape · nona · nona-shape).
pub fn assert_sample_nesting_nests(is_nesting: bool, sample: []const u8, stated_mold: []const u8) NestError!void {
    if (!is_nesting) return;
    assert(sample.len > 0); // precondition: nesting sample non-empty
    assert(stated_mold.len > 0); // precondition: stated mold non-empty
    if (sample[0] == '@' or stated_mold[0] == '@') {
        try assert_aura_nests(sample, stated_mold);
        return;
    }
    try assert_bartis_named_shape(sample);
    try assert_bartis_named_shape(stated_mold);
    if (!std.mem.eql(u8, sample, stated_mold)) return error.SampleDoesNotNest;
}
