/// True when any `$%` arm carries two or more payload faces.
fn any_multi_face_payload(spec: *const rune_shape.ShapeSpec) bool {
    var i: usize = 0;
    while (i < spec.field_count) : (i += 1) {
        if (rune_shape.payload_count(spec, i) >= 2) return true;
    }
    return false;
}

/// Assert `mold_name` nests under a one-field `$:` ShapeSpec (amount/count one-field shape).
pub fn assert_named_shape_nests(mold_name: []const u8, spec: *const rune_shape.ShapeSpec) NestError!void {
    if (is_kind_named_shape(mold_name) or is_xact_named_shape(mold_name) or is_xfer_named_shape(mold_name) or is_pair_named_shape(mold_name) or is_triple_named_shape(mold_name) or is_quad_named_shape(mold_name) or is_penta_named_shape(mold_name) or is_hexa_named_shape(mold_name) or is_hepta_named_shape(mold_name) or is_octa_named_shape(mold_name) or is_nona_named_shape(mold_name))
        return error.SampleDoesNotNest;
    try assert_bartis_named_shape(mold_name);
    if (!std.mem.eql(u8, rune_shape.name_slice(spec), mold_name)) return error.SampleDoesNotNest;
    if (spec.body != .tuple) return error.SampleDoesNotNest;
    if (spec.field_count != 1) return error.SampleDoesNotNest;
}

/// Assert `mold_name` nests under a two-field `$:` ShapeSpec (pair-mold · STOA126).
pub fn assert_pair_shape_nests(mold_name: []const u8, spec: *const rune_shape.ShapeSpec) NestError!void {
    if (!is_pair_named_shape(mold_name)) return error.SampleDoesNotNest;
    if (!std.mem.eql(u8, rune_shape.name_slice(spec), mold_name)) return error.SampleDoesNotNest;
    if (spec.body != .tuple) return error.SampleDoesNotNest;
    if (spec.field_count != 2) return error.SampleDoesNotNest;
}

