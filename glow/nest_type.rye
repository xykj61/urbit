//! glow/nest_type.rye — nest/type surface (STOA107–110 · STOA118–130 · STOA148–160).
//!
//! Expansion-time checks that a sample nests under a stated shape:
//!   - STOA107: stated aura equality (`@u32` under `@u32`)
//!   - STOA108: unit `$%` tag membership (`mint` under kind-mold)
//!   - STOA109: closed named-shape bartis sample (`amount-mold` one-field `$:`)
//!   - STOA110: nesting-sample refuse — nesting-flagged claims do not nest
//!   - STOA118: same closed named shape on barket samples
//!   - STOA119: nesting-sample accept under a stated closed shape
//!   - STOA120: barket/bartis expansion call `assert_sample_nesting_nests`
//!   - STOA121: barket passes `is_nesting=true` through nesting-nests under stated shapes
//!   - STOA122–126: closed allowlist amount · count · kind · xact · xfer · pair
//!   - STOA130: Glow vocabulary — stated · nesting · gold (Hoon study: dry · wet · gold)
//!   - STOA134: closed allowlist adds three-field `$:` `triple-mold`
//!   - STOA135: closed allowlist adds four-field `$:` `quad-mold`
//!   - STOA138: closed allowlist adds five-field `$:` `penta-mold`
//!   - STOA140: closed allowlist adds six-field `$:` `hexa-mold`
//!   - STOA142: closed allowlist adds seven-field `$:` `hepta-mold`
//!   - STOA144: closed allowlist adds eight-field `$:` `octa-mold`
//!   - STOA146: closed allowlist adds nine-field `$:` `nona-mold`
//!   - STOA148: Glow OS shape alias `amount-shape` ≡ `amount-mold` (one-field `$:` / `@u32`)
//!   - STOA149: Glow OS shape alias `count-shape` ≡ `count-mold` (one-field `$:` / `@u32`)
//!   - STOA150: Glow OS shape alias `pair-shape` ≡ `pair-mold` (two-field `$:` / PairShape)
//!   - STOA151: Glow OS shape alias `kind-shape` ≡ `kind-mold` (unit `$%` / KindShape)
//!   - STOA152: Glow OS shape alias `xact-shape` ≡ `xact-mold` (payload `$%` / XactShape)
//!   - STOA153: Glow OS shape alias `xfer-shape` ≡ `xfer-mold` (multi-face payload `$%` / XferShape)
//!   - STOA154: Glow OS shape alias `triple-shape` ≡ `triple-mold` (three-field `$:` / TripleShape)
//!   - STOA155: Glow OS shape alias `quad-shape` ≡ `quad-mold` (four-field `$:` / QuadShape)
//!   - STOA156: Glow OS shape alias `penta-shape` ≡ `penta-mold` (five-field `$:` / PentaShape)
//!   - STOA157: Glow OS shape alias `hexa-shape` ≡ `hexa-mold` (six-field `$:` / HexaShape)
//!   - STOA158: Glow OS shape alias `hepta-shape` ≡ `hepta-mold` (seven-field `$:` / HeptaShape)
//!   - STOA159: Glow OS shape alias `octa-shape` ≡ `octa-mold` (eight-field `$:` / OctaShape)
//!   - STOA160: Glow OS shape alias `nona-shape` ≡ `nona-mold` (nine-field `$:` / NonaShape) — closes multi-field shape ladder at capacity freeze
//! Ambient gold / free polymorphism · open `$:` beyond nona stay held (capacity freeze at 9).
//!
//! Bartis calls nesting-nests stated (`false`). Barket calls nesting-nests nesting (`true`).
//! STOA110 `assert_sample_not_nesting(true)` refuse stays on the nest_type witness.

const std = @import("std");
const assert = std.debug.assert;
const rune_shape = @import("rune_shape.rye");

pub const nest_type_version = "20260721.192947";

/// STOA180: Glow cord aura `@t` — warm text atom with a stated byte ceiling (TAME-shaped).
/// STOA209: ceiling 1024 — covers elder max fact hex (`max_fact_len` 512 × 2).
pub const aura_t_max_bytes: u32 = 1024;
/// STOA183: Glow hex aura `@ux` — fixed pubkey-shaped byte ceiling (ed25519 peer).
pub const aura_ux_max_bytes: u32 = 32;

/// Closed named shapes welcome in gate samples (citizen desks lead with `-shape`; study twins keep `-mold`).
/// `$:` one-field ≡ `@u32`: amount · count · amount-shape · count-shape. `$:` two-field: pair · pair-shape. `$:` three-field: triple · triple-shape.
/// `$:` four-field: quad · quad-shape. `$:` five-field: penta · penta-shape. `$:` six-field: hexa · hexa-shape. `$:` seven-field: hepta · hepta-shape. `$:` eight-field: octa · octa-shape. `$:` nine-field: nona · nona-shape. Unit `$%`: kind · kind-shape. Payload `$%`: xact · xact-shape. Multi-face payload `$%`: xfer · xfer-shape.
pub const bartis_named_study_amount = "amount-mold";
/// STOA148: Glow OS shape-language alias — same one-field `$:` / `@u32` lower as `amount-mold`.
pub const bartis_named_shape_amount = "amount-shape";
pub const bartis_named_study_count = "count-mold";
/// STOA149: Glow OS shape-language alias — same one-field `$:` / `@u32` lower as `count-mold`.
pub const bartis_named_shape_count = "count-shape";
pub const bartis_named_study_kind = "kind-mold";
/// STOA151: Glow OS shape-language alias — same unit `$%` / KindShape lower as `kind-mold`.
pub const bartis_named_shape_kind = "kind-shape";
pub const bartis_named_study_xact = "xact-mold";
/// STOA152: Glow OS shape-language alias — same payload `$%` / XactShape lower as `xact-mold`.
pub const bartis_named_shape_xact = "xact-shape";
pub const bartis_named_study_xfer = "xfer-mold";
/// STOA153: Glow OS shape-language alias — same multi-face payload `$%` / XferShape lower as `xfer-mold`.
pub const bartis_named_shape_xfer = "xfer-shape";
pub const bartis_named_study_pair = "pair-mold";
/// STOA150: Glow OS shape-language alias — same two-field `$:` / PairShape lower as `pair-mold`.
pub const bartis_named_shape_pair = "pair-shape";
pub const bartis_named_study_triple = "triple-mold";
/// STOA154: Glow OS shape-language alias — same three-field `$:` / TripleShape lower as `triple-mold`.
pub const bartis_named_shape_triple = "triple-shape";
pub const bartis_named_study_quad = "quad-mold";
/// STOA155: Glow OS shape-language alias — same four-field `$:` / QuadShape lower as `quad-mold`.
pub const bartis_named_shape_quad = "quad-shape";
pub const bartis_named_study_penta = "penta-mold";
/// STOA156: Glow OS shape-language alias — same five-field `$:` / PentaShape lower as `penta-mold`.
pub const bartis_named_shape_penta = "penta-shape";
pub const bartis_named_study_hexa = "hexa-mold";
/// STOA157: Glow OS shape-language alias — same six-field `$:` / HexaShape lower as `hexa-mold`.
pub const bartis_named_shape_hexa = "hexa-shape";
pub const bartis_named_study_hepta = "hepta-mold";
/// STOA158: Glow OS shape-language alias — same seven-field `$:` / HeptaShape lower as `hepta-mold`.
pub const bartis_named_shape_hepta = "hepta-shape";
pub const bartis_named_study_octa = "octa-mold";
/// STOA159: Glow OS shape-language alias — same eight-field `$:` / OctaShape lower as `octa-mold`.
pub const bartis_named_shape_octa = "octa-shape";
pub const bartis_named_study_nona = "nona-mold";
/// STOA160: Glow OS shape-language alias — same nine-field `$:` / NonaShape lower as `nona-mold`.
pub const bartis_named_shape_nona = "nona-shape";

pub const NestError = error{
    SampleDoesNotNest,
};

/// Assert `sample_aura` nests under `stated_aura` (stated aura equality).
/// `@t` nests under `@t`; bound is `aura_t_max_bytes` (STOA180).
/// `@ux` nests under `@ux`; bound is `aura_ux_max_bytes` (STOA183).
pub fn assert_aura_nests(sample_aura: []const u8, stated_aura: []const u8) NestError!void {
    assert(sample_aura.len > 0); // precondition: sample aura non-empty
    assert(stated_aura.len > 0); // precondition: stated aura non-empty
    if (!std.mem.eql(u8, sample_aura, stated_aura)) return error.SampleDoesNotNest;
}

/// True when `aura` is the Glow cord aura `@t`.
pub fn is_cord_aura(aura: []const u8) bool {
    return std.mem.eql(u8, aura, "@t");
}

/// True when `aura` is the Glow hex aura `@ux`.
pub fn is_hex_aura(aura: []const u8) bool {
    return std.mem.eql(u8, aura, "@ux");
}

/// Strip one leading `%` so callers may pass `%mint` or `mint`.
fn tag_name(tag: []const u8) []const u8 {
    if (tag.len > 0 and tag[0] == '%') return tag[1..];
    return tag;
}

/// Assert `tag` nests under a `$%` ShapeSpec (unit membership).
/// `tag` may be bare (`mint`) or percent-spelled (`%mint`).
pub fn assert_tag_nests(tag: []const u8, spec: *const rune_shape.ShapeSpec) NestError!void {
    assert(tag.len > 0); // precondition: tag token non-empty
    const name = tag_name(tag);
    assert(name.len > 0); // precondition: bare tag non-empty after strip
    if (spec.body != .tagged) return error.SampleDoesNotNest;
    var i: usize = 0;
    while (i < spec.field_count) : (i += 1) {
        if (std.mem.eql(u8, rune_shape.field_slice(spec, i), name)) return;
    }
    return error.SampleDoesNotNest;
}

/// Assert `mold_name` is on the closed gate-sample allowlist (STOA109 · STOA122–126 · STOA134–135 · STOA138 · STOA140 · STOA142 · STOA144 · STOA146 · STOA148–160).
pub fn assert_bartis_named_shape(mold_name: []const u8) NestError!void {
    assert(mold_name.len > 0); // precondition: shape name non-empty
    if (std.mem.eql(u8, mold_name, bartis_named_study_amount)) return;
    if (std.mem.eql(u8, mold_name, bartis_named_shape_amount)) return;
    if (std.mem.eql(u8, mold_name, bartis_named_study_count)) return;
    if (std.mem.eql(u8, mold_name, bartis_named_shape_count)) return;
    if (std.mem.eql(u8, mold_name, bartis_named_study_kind)) return;
    if (std.mem.eql(u8, mold_name, bartis_named_shape_kind)) return;
    if (std.mem.eql(u8, mold_name, bartis_named_study_xact)) return;
    if (std.mem.eql(u8, mold_name, bartis_named_shape_xact)) return;
    if (std.mem.eql(u8, mold_name, bartis_named_study_xfer)) return;
    if (std.mem.eql(u8, mold_name, bartis_named_shape_xfer)) return;
    if (std.mem.eql(u8, mold_name, bartis_named_study_pair)) return;
    if (std.mem.eql(u8, mold_name, bartis_named_shape_pair)) return;
    if (std.mem.eql(u8, mold_name, bartis_named_study_triple)) return;
    if (std.mem.eql(u8, mold_name, bartis_named_shape_triple)) return;
    if (std.mem.eql(u8, mold_name, bartis_named_study_quad)) return;
    if (std.mem.eql(u8, mold_name, bartis_named_shape_quad)) return;
    if (std.mem.eql(u8, mold_name, bartis_named_study_penta)) return;
    if (std.mem.eql(u8, mold_name, bartis_named_shape_penta)) return;
    if (std.mem.eql(u8, mold_name, bartis_named_study_hexa)) return;
    if (std.mem.eql(u8, mold_name, bartis_named_shape_hexa)) return;
    if (std.mem.eql(u8, mold_name, bartis_named_study_hepta)) return;
    if (std.mem.eql(u8, mold_name, bartis_named_shape_hepta)) return;
    if (std.mem.eql(u8, mold_name, bartis_named_study_octa)) return;
    if (std.mem.eql(u8, mold_name, bartis_named_shape_octa)) return;
    if (std.mem.eql(u8, mold_name, bartis_named_study_nona)) return;
    if (std.mem.eql(u8, mold_name, bartis_named_shape_nona)) return;
    return error.SampleDoesNotNest;
}

/// True when `mold_name` is the closed unit `$%` kind-mold or its Glow OS shape alias.
pub fn is_kind_named_shape(mold_name: []const u8) bool {
    if (std.mem.eql(u8, mold_name, bartis_named_study_kind)) return true;
    return std.mem.eql(u8, mold_name, bartis_named_shape_kind);
}

