//! glow/nest_type.rye — nest/type surface (STOA107–110 · STOA118–130).
//!
//! Expansion-time checks that a sample nests under a stated mold:
//!   - STOA107: stated aura equality (`@u32` under `@u32`)
//!   - STOA108: unit `$%` tag membership (`mint` under kind-mold)
//!   - STOA109: closed named-mold bartis sample (`amount-mold` one-field `$:`)
//!   - STOA110: nesting-sample refuse — nesting-flagged claims do not nest
//!   - STOA118: same closed named mold on barket samples
//!   - STOA119: nesting-sample accept under a stated closed mold
//!   - STOA120: barket/bartis expansion call `assert_sample_nesting_nests`
//!   - STOA121: barket passes `is_nesting=true` through nesting-nests under stated molds
//!   - STOA122–126: closed allowlist amount · count · kind · xact · xfer · pair
//!   - STOA130: Glow vocabulary — stated · nesting · gold (Hoon study: dry · wet · gold)
//!   - STOA134: closed allowlist adds three-field `$:` `triple-mold`
//!   - STOA135: closed allowlist adds four-field `$:` `quad-mold`
//!   - STOA138: closed allowlist adds five-field `$:` `penta-mold`
//!   - STOA140: closed allowlist adds six-field `$:` `hexa-mold`
//!   - STOA142: closed allowlist adds seven-field `$:` `hepta-mold`
//! Ambient gold / free polymorphism · open `$:` beyond hepta stay held.
//!
//! Bartis calls nesting-nests stated (`false`). Barket calls nesting-nests nesting (`true`).
//! STOA110 `assert_sample_not_nesting(true)` refuse stays on the nest_type witness.

const std = @import("std");
const assert = std.debug.assert;
const rune_mold = @import("rune_mold.rye");

pub const nest_type_version = "20260720.222827";

/// Closed named molds welcome in gate samples.
/// `$:` one-field ≡ `@u32`: amount · count. `$:` two-field: pair. `$:` three-field: triple.
/// `$:` four-field: quad. `$:` five-field: penta. `$:` six-field: hexa. `$:` seven-field: hepta. Unit `$%`: kind. Payload `$%`: xact. Multi-face payload `$%`: xfer.
pub const bartis_named_mold_amount = "amount-mold";
pub const bartis_named_mold_count = "count-mold";
pub const bartis_named_mold_kind = "kind-mold";
pub const bartis_named_mold_xact = "xact-mold";
pub const bartis_named_mold_xfer = "xfer-mold";
pub const bartis_named_mold_pair = "pair-mold";
pub const bartis_named_mold_triple = "triple-mold";
pub const bartis_named_mold_quad = "quad-mold";
pub const bartis_named_mold_penta = "penta-mold";
pub const bartis_named_mold_hexa = "hexa-mold";
pub const bartis_named_mold_hepta = "hepta-mold";

pub const NestError = error{
    SampleDoesNotNest,
};

/// Assert `sample_aura` nests under `stated_mold` (stated aura equality).
pub fn assert_aura_nests(sample_aura: []const u8, stated_mold: []const u8) NestError!void {
    assert(sample_aura.len > 0); // precondition: sample aura non-empty
    assert(stated_mold.len > 0); // precondition: stated mold non-empty
    if (!std.mem.eql(u8, sample_aura, stated_mold)) return error.SampleDoesNotNest;
}

/// Strip one leading `%` so callers may pass `%mint` or `mint`.
fn tag_name(tag: []const u8) []const u8 {
    if (tag.len > 0 and tag[0] == '%') return tag[1..];
    return tag;
}

/// Assert `tag` nests under a `$%` MoldSpec (unit membership).
/// `tag` may be bare (`mint`) or percent-spelled (`%mint`).
pub fn assert_tag_nests(tag: []const u8, spec: *const rune_mold.MoldSpec) NestError!void {
    assert(tag.len > 0); // precondition: tag token non-empty
    const name = tag_name(tag);
    assert(name.len > 0); // precondition: bare tag non-empty after strip
    if (spec.body != .tagged) return error.SampleDoesNotNest;
    var i: usize = 0;
    while (i < spec.field_count) : (i += 1) {
        if (std.mem.eql(u8, rune_mold.field_slice(spec, i), name)) return;
    }
    return error.SampleDoesNotNest;
}

/// Assert `mold_name` is on the closed gate-sample allowlist (STOA109 · STOA122–126 · STOA134–135 · STOA138 · STOA140 · STOA142).
pub fn assert_bartis_named_mold(mold_name: []const u8) NestError!void {
    assert(mold_name.len > 0); // precondition: mold name non-empty
    if (std.mem.eql(u8, mold_name, bartis_named_mold_amount)) return;
    if (std.mem.eql(u8, mold_name, bartis_named_mold_count)) return;
    if (std.mem.eql(u8, mold_name, bartis_named_mold_kind)) return;
    if (std.mem.eql(u8, mold_name, bartis_named_mold_xact)) return;
    if (std.mem.eql(u8, mold_name, bartis_named_mold_xfer)) return;
    if (std.mem.eql(u8, mold_name, bartis_named_mold_pair)) return;
    if (std.mem.eql(u8, mold_name, bartis_named_mold_triple)) return;
    if (std.mem.eql(u8, mold_name, bartis_named_mold_quad)) return;
    if (std.mem.eql(u8, mold_name, bartis_named_mold_penta)) return;
    if (std.mem.eql(u8, mold_name, bartis_named_mold_hexa)) return;
    if (std.mem.eql(u8, mold_name, bartis_named_mold_hepta)) return;
    return error.SampleDoesNotNest;
}

/// True when `mold_name` is the closed unit `$%` kind-mold.
pub fn is_kind_named_mold(mold_name: []const u8) bool {
    return std.mem.eql(u8, mold_name, bartis_named_mold_kind);
}

/// True when `mold_name` is the closed payload `$%` xact-mold.
pub fn is_xact_named_mold(mold_name: []const u8) bool {
    return std.mem.eql(u8, mold_name, bartis_named_mold_xact);
}

/// True when `mold_name` is the closed multi-face payload `$%` xfer-mold.
pub fn is_xfer_named_mold(mold_name: []const u8) bool {
    return std.mem.eql(u8, mold_name, bartis_named_mold_xfer);
}

/// True when `mold_name` is the closed multi-field `$:` pair-mold.
pub fn is_pair_named_mold(mold_name: []const u8) bool {
    return std.mem.eql(u8, mold_name, bartis_named_mold_pair);
}

/// True when `mold_name` is the closed three-field `$:` triple-mold.
pub fn is_triple_named_mold(mold_name: []const u8) bool {
    return std.mem.eql(u8, mold_name, bartis_named_mold_triple);
}

/// True when `mold_name` is the closed four-field `$:` quad-mold.
pub fn is_quad_named_mold(mold_name: []const u8) bool {
    return std.mem.eql(u8, mold_name, bartis_named_mold_quad);
}

/// True when `mold_name` is the closed five-field `$:` penta-mold.
pub fn is_penta_named_mold(mold_name: []const u8) bool {
    return std.mem.eql(u8, mold_name, bartis_named_mold_penta);
}

/// True when `mold_name` is the closed six-field `$:` hexa-mold.
pub fn is_hexa_named_mold(mold_name: []const u8) bool {
    return std.mem.eql(u8, mold_name, bartis_named_mold_hexa);
}

/// True when `mold_name` is the closed seven-field `$:` hepta-mold.
pub fn is_hepta_named_mold(mold_name: []const u8) bool {
    return std.mem.eql(u8, mold_name, bartis_named_mold_hepta);
}

/// True when any `$%` arm carries two or more payload faces.
fn any_multi_face_payload(spec: *const rune_mold.MoldSpec) bool {
    var i: usize = 0;
    while (i < spec.field_count) : (i += 1) {
        if (rune_mold.payload_count(spec, i) >= 2) return true;
    }
    return false;
}

/// Assert `mold_name` nests under a one-field `$:` MoldSpec (amount/count shape).
pub fn assert_named_mold_nests(mold_name: []const u8, spec: *const rune_mold.MoldSpec) NestError!void {
    if (is_kind_named_mold(mold_name) or is_xact_named_mold(mold_name) or is_xfer_named_mold(mold_name) or is_pair_named_mold(mold_name) or is_triple_named_mold(mold_name) or is_quad_named_mold(mold_name) or is_penta_named_mold(mold_name) or is_hexa_named_mold(mold_name) or is_hepta_named_mold(mold_name))
        return error.SampleDoesNotNest;
    try assert_bartis_named_mold(mold_name);
    if (!std.mem.eql(u8, rune_mold.name_slice(spec), mold_name)) return error.SampleDoesNotNest;
    if (spec.body != .tuple) return error.SampleDoesNotNest;
    if (spec.field_count != 1) return error.SampleDoesNotNest;
}

/// Assert `mold_name` nests under a two-field `$:` MoldSpec (pair-mold · STOA126).
pub fn assert_pair_mold_nests(mold_name: []const u8, spec: *const rune_mold.MoldSpec) NestError!void {
    if (!is_pair_named_mold(mold_name)) return error.SampleDoesNotNest;
    if (!std.mem.eql(u8, rune_mold.name_slice(spec), mold_name)) return error.SampleDoesNotNest;
    if (spec.body != .tuple) return error.SampleDoesNotNest;
    if (spec.field_count != 2) return error.SampleDoesNotNest;
}

/// Assert `mold_name` nests under a three-field `$:` MoldSpec (triple-mold · STOA134).
pub fn assert_triple_mold_nests(mold_name: []const u8, spec: *const rune_mold.MoldSpec) NestError!void {
    if (!is_triple_named_mold(mold_name)) return error.SampleDoesNotNest;
    if (!std.mem.eql(u8, rune_mold.name_slice(spec), mold_name)) return error.SampleDoesNotNest;
    if (spec.body != .tuple) return error.SampleDoesNotNest;
    if (spec.field_count != 3) return error.SampleDoesNotNest;
}

/// Assert `mold_name` nests under a four-field `$:` MoldSpec (quad-mold · STOA135).
pub fn assert_quad_mold_nests(mold_name: []const u8, spec: *const rune_mold.MoldSpec) NestError!void {
    if (!is_quad_named_mold(mold_name)) return error.SampleDoesNotNest;
    if (!std.mem.eql(u8, rune_mold.name_slice(spec), mold_name)) return error.SampleDoesNotNest;
    if (spec.body != .tuple) return error.SampleDoesNotNest;
    if (spec.field_count != 4) return error.SampleDoesNotNest;
}

/// Assert `mold_name` nests under a five-field `$:` MoldSpec (penta-mold · STOA138).
pub fn assert_penta_mold_nests(mold_name: []const u8, spec: *const rune_mold.MoldSpec) NestError!void {
    if (!is_penta_named_mold(mold_name)) return error.SampleDoesNotNest;
    if (!std.mem.eql(u8, rune_mold.name_slice(spec), mold_name)) return error.SampleDoesNotNest;
    if (spec.body != .tuple) return error.SampleDoesNotNest;
    if (spec.field_count != 5) return error.SampleDoesNotNest;
