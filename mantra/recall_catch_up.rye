//! mantra/recall_catch_up.rye — catch-up-to-latest: bounded inner loop over syncRevision.
//!
//! Tries the next revision the fetcher does not yet hold, applies it if the source
//! has it, and repeats until an ask comes back empty. Composing rather than extending:
//! recall_lap1.rye is imported and left standing.
//!
//!   rye build mantra/recall_catch_up.rye -femit-bin=mantra/bin/recall-catch-up
//!   mantra/bin/recall-catch-up selftest
//!
//! Counsel: [`counsel/20260707-001612_claude-counsel-subscribe-revisited.md`](../counsel/20260707-001612_claude-counsel-subscribe-revisited.md)

const std = @import("std");
const assert = std.debug.assert;
const print = std.debug.print;
const recall_lap1 = @import("recall_lap1.rye");

pub const recall_catch_up_version = "20260707.001612";

pub const CatchUpReport = struct {
    revisions_synced: u32,
    empty_asks: u32,
    total_leaves: u32,
    had_already: u32,
    needed: u32,
};

/// Highest revision number held in `cat` for peer/bolt (0 if none).
pub fn max_revision_held(cat: *const recall_lap1.BoltCatalog, peer: []const u8, bolt: []const u8) u32 {
    var max_rev: u32 = 0;
    var i: u32 = 0;
    while (i < cat.leaf_count) : (i += 1) {
        const leaf = &cat.leaves[i];
        if (!std.mem.eql(u8, leaf.peer[0..leaf.peer_len], peer)) continue;
        if (!std.mem.eql(u8, leaf.bolt[0..leaf.bolt_len], bolt)) continue;
        if (leaf.revision > max_rev) max_rev = leaf.revision;
    }
    return max_rev;
}

/// Sync every revision on `source` that `fetcher` lacks, stopping at the first empty ask.
pub fn catch_up_to_latest(
    fetcher: *recall_lap1.BoltCatalog,
    source: *const recall_lap1.BoltCatalog,
    peer: []const u8,
    bolt: []const u8,
) recall_lap1.RecallError!CatchUpReport {
    var report: CatchUpReport = .{
        .revisions_synced = 0,
        .empty_asks = 0,
        .total_leaves = 0,
        .had_already = 0,
        .needed = 0,
    };
    var next_rev = max_revision_held(fetcher, peer, bolt) + 1;
    while (true) {
        const sync = try recall_lap1.sync_revision(fetcher, source, peer, bolt, next_rev);
        if (sync.total == 0) {
            report.empty_asks += 1;
            break;
        }
        report.revisions_synced += 1;
        report.total_leaves += sync.total;
        report.had_already += sync.had_already;
        report.needed += sync.needed;
        next_rev += 1;
    }
    return report;
}

fn run_selftest(_: std.Io) !u8 {
    const path = "bolt.txt";
    var source: recall_lap1.BoltCatalog = .empty();
    try source.append_leaf("peerB", "b", 1, path, "rev-one", "plain-text");
    try source.append_leaf("peerB", "b", 2, path, "rev-two", "plain-text");
    try source.append_leaf("peerB", "b", 3, path, "rev-three", "plain-text");

    // Fetcher holds rev 1 only — two revisions behind.
    var fetcher: recall_lap1.BoltCatalog = .empty();
    try fetcher.append_leaf("peerB", "b", 1, path, "rev-one", "plain-text");

    const first = try catch_up_to_latest(&fetcher, &source, "peerB", "b");
    assert(first.revisions_synced == 2);
    assert(first.empty_asks == 1);
    assert(first.needed == 2);
    assert(first.had_already == 0);

    const second = try catch_up_to_latest(&fetcher, &source, "peerB", "b");
    assert(second.revisions_synced == 0);
    assert(second.empty_asks == 1);
    assert(second.needed == 0);

    const expected = [_][]const u8{ "rev-one", "rev-two", "rev-three" };
    var rev: u32 = 1;
    while (rev <= 3) : (rev += 1) {
        const name = recall_lap1.Name{ .peer = "peerB", .bolt = "b", .revision = rev, .path = path };
        var buf_f: [recall_lap1.max_resin_bytes]u8 = undefined;
        var buf_s: [recall_lap1.max_resin_bytes]u8 = undefined;
        const rf = try fetcher.recall(name, &buf_f);
        const rs = try source.recall(name, &buf_s);
        assert(std.mem.eql(u8, buf_f[0..rf.len], expected[rev - 1]));
        assert(std.mem.eql(u8, buf_s[0..rs.len], expected[rev - 1]));
        assert(std.mem.eql(u8, buf_f[0..rf.len], buf_s[0..rs.len]));
    }

    print("ns-catchup: two revisions crossed in one call — empty ask stops loop GREEN\n", .{});
    print("ns-catchup: second call asked once, changed nothing — stopping rule GREEN\n", .{});
    print("ns-catchup: recall identical on both catalogs — referential transparency GREEN\n", .{});
    print("ns-catchup: version {s}\n", .{recall_catch_up_version});
    print("GREEN: catch-up-to-latest — bounded inner loop over syncRevision, in-process.\n", .{});
    return 0;
}

pub fn main(init: std.process.Init) !u8 {
    const io = init.io;
    const args = try init.minimal.args.toSlice(init.arena.allocator());
    if (args.len >= 2 and std.mem.eql(u8, args[1], "selftest")) return run_selftest(io);
    return run_selftest(io);
}
