//! mantra/recall_subscribe_poll_delivery.rye — outer subscribe poll over Comlink sealed datagrams.
//!
//! Bounded poll cycles over catch-up wire exchanges — composes recall_subscribe_poll
//! and the catch-up wire path, editing nothing beneath them.
//!
//!   rye build mantra/recall_subscribe_poll_delivery.rye -lc -femit-bin=mantra/bin/recall-subscribe-poll-delivery
//!   mantra/bin/recall-subscribe-poll-delivery selftest
//!   mantra/bin/recall-subscribe-poll-delivery demo
//!
//! Counsel: [`counsel/20260707-004712_claude-counsel-outer-subscribe-and-host-mirror.md`](../counsel/20260707-004712_claude-counsel-outer-subscribe-and-host-mirror.md)

const std = @import("std");
const assert = std.debug.assert;
const print = std.debug.print;
const c = std.c;
const ns = @import("recall_lap1.rye");
const sw = @import("recall_sync_wire.rye");
const wf = @import("wire_format.rye");
const cu = @import("recall_catch_up.rye");
const sp = @import("recall_subscribe_poll.rye");
const tally_copy = @import("tally_copy.rye");
const tally_parse_int = @import("parse_int.rye");

const npw_version = "20260707.052012";

/// Matches `caravan/supervisor_exit.rye` — deliberate stop at a cycle boundary.
const stop_requested: u8 = 8;

const AF_INET: c_uint = 2;
const SOCK_DGRAM: c_uint = 2;
const SOL_SOCKET: c_int = 1;
const SO_REUSEADDR: c_int = 2;
const SO_RCVTIMEO: c_int = 20;

const fetcher_port: u16 = 38486;
const source_port: u16 = 38487;

const witness_path = "bolt.txt";

const sockaddr_in = extern struct {
    sin_family: c_ushort = AF_INET,
    sin_port: c_ushort,
    sin_addr: [4]u8 = .{ 127, 0, 0, 1 },
    sin_zero: [8]u8 = .{0} ** 8,
};

fn localhost_addr(port: u16) sockaddr_in {
    return .{ .sin_port = std.mem.nativeToBig(u16, port) };
}

fn open_socket() !c.fd_t {
    const fd = c.socket(AF_INET, SOCK_DGRAM, 0);
    if (fd < 0) return error.SocketFailed;
    const yes: c_int = 1;
    _ = c.setsockopt(fd, SOL_SOCKET, SO_REUSEADDR, &yes, @sizeOf(c_int));
    return fd;
}

fn send_wire(port: u16, wire: []const u8) !void {
    const fd = try open_socket();
    defer _ = c.close(fd);
    const dest = localhost_addr(port);
    const sent = c.sendto(fd, wire.ptr, @intCast(wire.len), 0, @ptrCast(&dest), @sizeOf(sockaddr_in));
    if (sent < 0 or @as(usize, @intCast(sent)) != wire.len) return error.SendFailed;
}

fn recv_wire_timeout(port: u16, wire: []u8, timeout_sec: u32) !u64 {
    const fd = try open_socket();
    defer _ = c.close(fd);
    if (timeout_sec > 0) {
        var tv = c.timeval{ .sec = @intCast(timeout_sec), .usec = 0 };
        _ = c.setsockopt(fd, SOL_SOCKET, SO_RCVTIMEO, &tv, @sizeOf(c.timeval));
    }
    var bind_addr = localhost_addr(port);
    if (c.bind(fd, @ptrCast(&bind_addr), @sizeOf(sockaddr_in)) < 0) return error.BindFailed;
    var from: sockaddr_in = undefined;
    var from_len: c.socklen_t = @sizeOf(sockaddr_in);
    const n = c.recvfrom(fd, wire.ptr, @intCast(wire.len), 0, @ptrCast(&from), &from_len);
    if (n < 0) return error.RecvFailed;
    return @intCast(n);
}

fn recv_wire(port: u16, wire: []u8) !u64 {
    return recv_wire_timeout(port, wire, 0);
}

fn seal_payload(payload: []const u8, wire: *[@intCast(wf.wire_capacity)]u8) !u64 {
    return try wf.seal_message(payload, wire);
}

fn open_wire(wire: []const u8, opened: *[@intCast(wf.max_message)]u8) !u64 {
    return try wf.open_datagram(wire, opened);
}

fn build_catch_up_request(
    fetcher: *const ns.BoltCatalog,
    peer: []const u8,
    bolt: []const u8,
    revision: u32,
) sw.WireError!sw.SyncRequest {
    var req: sw.SyncRequest = .{
        .peer = peer,
        .bolt = bolt,
        .revision = revision,
        .held_count = 0,
        .held_digests = undefined,
    };
    var i: u32 = 0;
    while (i < fetcher.leaf_count and req.held_count < sw.max_held_digests) : (i += 1) {
        const leaf = &fetcher.leaves[i];
        const digest = leaf.digest_hex[0..64];
        var seen: u32 = 0;
        while (seen < req.held_count) : (seen += 1) {
            if (std.mem.eql(u8, req.held_digests[seen][0..64], digest)) break;
        }
        if (seen < req.held_count) continue;
        tally_copy.copy_disjoint(u8, req.held_digests[req.held_count][0..64], digest);
        req.held_count += 1;
    }
    return req;
}

fn run_wire_exchange_in_process(
    fetcher: *ns.BoltCatalog,
    source: *const ns.BoltCatalog,
    peer: []const u8,
    bolt: []const u8,
    revision: u32,
) !struct { report: ns.SyncReport, entry_count: u32 } {
    const req = try build_catch_up_request(fetcher, peer, bolt, revision);
    var req_buf: [sw.max_wire_payload]u8 = undefined;
    const req_len = try sw.encode_request(req, &req_buf);

    var wire_resp: sw.SyncResponse = undefined;
    try sw.build_response(source, &req, &wire_resp);
    const entry_count = wire_resp.entry_count;
    var resp_buf: [sw.max_wire_payload]u8 = undefined;
    const resp_len = try sw.encode_response(&wire_resp, &resp_buf);

    var req_wire: [@intCast(wf.wire_capacity)]u8 = undefined;
    const req_wire_len = try seal_payload(req_buf[0..req_len], &req_wire);
    var req_opened: [@intCast(wf.max_message)]u8 = undefined;
    const req_opened_len = try open_wire(req_wire[0..@intCast(req_wire_len)], &req_opened);

    var decoded_req: sw.SyncRequest = undefined;
    try sw.decode_request(req_opened[0..@intCast(req_opened_len)], &decoded_req);

    var built_resp: sw.SyncResponse = undefined;
    try sw.build_response(source, &decoded_req, &built_resp);
    var resp_wire: [@intCast(wf.wire_capacity)]u8 = undefined;
    const resp_wire_len = try seal_payload(resp_buf[0..resp_len], &resp_wire);
    var resp_opened: [@intCast(wf.max_message)]u8 = undefined;
    const resp_opened_len = try open_wire(resp_wire[0..@intCast(resp_wire_len)], &resp_opened);

    var decoded_resp: sw.SyncResponse = undefined;
    try sw.decode_response(resp_opened[0..@intCast(resp_opened_len)], &decoded_resp);
    const report = try sw.apply_sync_response(fetcher, &decoded_resp);
    return .{ .report = report, .entry_count = entry_count };
}

fn catch_up_wire_in_process(
    fetcher: *ns.BoltCatalog,
    source: *const ns.BoltCatalog,
    peer: []const u8,
    bolt: []const u8,
) !cu.CatchUpReport {
    var report: cu.CatchUpReport = .{
        .revisions_synced = 0,
        .empty_asks = 0,
        .total_leaves = 0,
        .had_already = 0,
        .needed = 0,
    };
    var next_rev = cu.max_revision_held(fetcher, peer, bolt) + 1;
    while (true) {
        const step = try run_wire_exchange_in_process(fetcher, source, peer, bolt, next_rev);
        if (step.entry_count == 0) {
            report.empty_asks += 1;
            break;
        }
        report.revisions_synced += 1;
        report.total_leaves += step.report.total;
        report.had_already += step.report.had_already;
        report.needed += step.report.needed;
        next_rev += 1;
    }
    return report;
}

fn poll_one_cycle_wire_in_process(
    fetcher: *ns.BoltCatalog,
    source: *const ns.BoltCatalog,
    pairs: []const sp.PeerBoltPair,
) !sp.PollCycleReport {
    var report: sp.PollCycleReport = .{ .revisions_synced = 0, .empty_asks = 0 };
    var i: u32 = 0;
    while (i < pairs.len) : (i += 1) {
        const pair = pairs[i];
        const step = try catch_up_wire_in_process(fetcher, source, pair.peer, pair.bolt);
        report.revisions_synced += step.revisions_synced;
        report.empty_asks += step.empty_asks;
    }
    return report;
}

fn run_one_wire_exchange_sockets(
    fetcher: *ns.BoltCatalog,
    peer: []const u8,
    bolt: []const u8,
    revision: u32,
) !struct { report: ns.SyncReport, entry_count: u32 } {
    const req = try build_catch_up_request(fetcher, peer, bolt, revision);
    var payload: [sw.max_wire_payload]u8 = undefined;
    const payload_len = try sw.encode_request(req, &payload);
    var wire: [@intCast(wf.wire_capacity)]u8 = undefined;
    const wire_len = try seal_payload(payload[0..payload_len], &wire);
    try send_wire(source_port, wire[0..@intCast(wire_len)]);

    var recv_buf: [@intCast(wf.wire_capacity)]u8 = undefined;
    const recv_len = try recv_wire(fetcher_port, &recv_buf);
    if (recv_len < wf.off_cipher or recv_len > wf.wire_capacity) return error.RecvFailed;

    var opened: [@intCast(wf.max_message)]u8 = undefined;
    const opened_len = try open_wire(recv_buf[0..@intCast(recv_len)], &opened);

    var resp: sw.SyncResponse = undefined;
    try sw.decode_response(opened[0..@intCast(opened_len)], &resp);
    const entry_count = resp.entry_count;
    const report = try sw.apply_sync_response(fetcher, &resp);
    return .{ .report = report, .entry_count = entry_count };
}

fn catch_up_wire_over_sockets(
    fetcher: *ns.BoltCatalog,
    peer: []const u8,
    bolt: []const u8,
) !cu.CatchUpReport {
    var report: cu.CatchUpReport = .{
        .revisions_synced = 0,
        .empty_asks = 0,
        .total_leaves = 0,
        .had_already = 0,
        .needed = 0,
    };
    var next_rev = cu.max_revision_held(fetcher, peer, bolt) + 1;
    while (true) {
        const step = try run_one_wire_exchange_sockets(fetcher, peer, bolt, next_rev);
        if (step.entry_count == 0) {
            report.empty_asks += 1;
            break;
        }
        report.revisions_synced += 1;
        report.total_leaves += step.report.total;
        report.had_already += step.report.had_already;
        report.needed += step.report.needed;
        next_rev += 1;
    }
    return report;
}

fn poll_one_cycle_wire_sockets(
    fetcher: *ns.BoltCatalog,
    pairs: []const sp.PeerBoltPair,
) !sp.PollCycleReport {
    var report: sp.PollCycleReport = .{ .revisions_synced = 0, .empty_asks = 0 };
    var i: u32 = 0;
    while (i < pairs.len) : (i += 1) {
        const pair = pairs[i];
        const step = try catch_up_wire_over_sockets(fetcher, pair.peer, pair.bolt);
        report.revisions_synced += step.revisions_synced;
        report.empty_asks += step.empty_asks;
    }
    return report;
}

fn init_demo_source(cat: *ns.BoltCatalog) !void {
    cat.* = .empty();
    try cat.append_leaf("peerB", "b", 1, witness_path, "rev-one", "plain-text");
    try cat.append_leaf("peerB", "b", 2, witness_path, "rev-two", "plain-text");
}

fn init_demo_fetcher(cat: *ns.BoltCatalog) !void {
    cat.* = .empty();
    try cat.append_leaf("peerB", "b", 1, witness_path, "rev-one", "plain-text");
}

fn init_demo_mirror_source(cat: *ns.BoltCatalog) !void {
    cat.* = .empty();
    try cat.append_leaf("peerB", "b", 1, witness_path, "rev-one", "plain-text");
    try cat.append_leaf("peerB", "b", 2, witness_path, "rev-two", "plain-text");
    try cat.append_leaf("peerC", "c", 1, witness_path, "alpha", "plain-text");
}

fn init_demo_mirror_fetcher(cat: *ns.BoltCatalog) !void {
    cat.* = .empty();
    try cat.append_leaf("peerB", "b", 1, witness_path, "rev-one", "plain-text");
    try cat.append_leaf("peerC", "c", 1, witness_path, "alpha", "plain-text");
}

const mirror_pairs = [_]sp.PeerBoltPair{
    .{ .peer = "peerB", .bolt = "b" },
    .{ .peer = "peerC", .bolt = "c" },
};

fn run_selftest(_: std.Io) !u8 {
    var source: ns.BoltCatalog = .empty();
    try source.append_leaf("peerB", "b", 1, witness_path, "rev-one", "plain-text");

    var fetcher: ns.BoltCatalog = .empty();
    try fetcher.append_leaf("peerB", "b", 1, witness_path, "rev-one", "plain-text");

    const one_pair = [_]sp.PeerBoltPair{.{ .peer = "peerB", .bolt = "b" }};

    const c1 = try poll_one_cycle_wire_in_process(&fetcher, &source, &one_pair);
    assert(c1.revisions_synced == 0);
    assert(c1.empty_asks == 1);

    try source.append_leaf("peerB", "b", 2, witness_path, "rev-two", "plain-text");

    const c2 = try poll_one_cycle_wire_in_process(&fetcher, &source, &one_pair);
    assert(c2.revisions_synced == 1);
    assert(c2.empty_asks == 1);

    const c3 = try poll_one_cycle_wire_in_process(&fetcher, &source, &one_pair);
    assert(c3.revisions_synced == 0);
    assert(c3.empty_asks == 1);

    const name2 = ns.Name{ .peer = "peerB", .bolt = "b", .revision = 2, .path = witness_path };
    var buf: [ns.max_resin_bytes]u8 = undefined;
    const r2 = try fetcher.recall(name2, &buf);
    assert(std.mem.eql(u8, buf[0..r2.len], "rev-two"));

    // In-process poll matches wire poll for same shape.
    var fetcher2: ns.BoltCatalog = .empty();
    try fetcher2.append_leaf("peerB", "b", 1, witness_path, "rev-one", "plain-text");
    var source2: ns.BoltCatalog = .empty();
    try source2.append_leaf("peerB", "b", 1, witness_path, "rev-one", "plain-text");
    try source2.append_leaf("peerB", "b", 2, witness_path, "rev-two", "plain-text");
    const composed = try sp.poll_one_cycle(&fetcher2, &source2, &one_pair);
    assert(composed.revisions_synced == c2.revisions_synced);

    print("ns-pollw: delayed revision caught on wire cycle 2 — empty ask stops GREEN\n", .{});
    print("ns-pollw: version {s} subscribe_poll {s}\n", .{ npw_version, sp.recall_subscribe_poll_version });
    print("GREEN: outer subscribe poll wire lap — bounded cycles over catch-up wire.\n", .{});
    return 0;
}

fn run_source_loop_with_catalog(src: *ns.BoltCatalog) !u8 {
    while (true) {
        var wire: [@intCast(wf.wire_capacity)]u8 = undefined;
        const wire_len = recv_wire_timeout(source_port, &wire, 2) catch continue;
        if (wire_len < wf.off_cipher or wire_len > wf.wire_capacity) return error.RecvFailed;

        var opened: [@intCast(wf.max_message)]u8 = undefined;
        const opened_len = try open_wire(wire[0..@intCast(wire_len)], &opened);

        var req: sw.SyncRequest = undefined;
        try sw.decode_request(opened[0..@intCast(opened_len)], &req);

        var resp: sw.SyncResponse = undefined;
        try sw.build_response(src, &req, &resp);
        var payload: [sw.max_wire_payload]u8 = undefined;
        const payload_len = try sw.encode_response(&resp, &payload);

        var out_wire: [@intCast(wf.wire_capacity)]u8 = undefined;
        const out_wire_len = try seal_payload(payload[0..payload_len], &out_wire);
        try send_wire(fetcher_port, out_wire[0..@intCast(out_wire_len)]);
    }
}

fn run_source_loop(_: std.Io) !u8 {
    var src: ns.BoltCatalog = undefined;
    try init_demo_source(&src);
    return run_source_loop_with_catalog(&src);
}

fn run_source_loop_mirror(_: std.Io) !u8 {
    var src: ns.BoltCatalog = undefined;
    try init_demo_mirror_source(&src);
    return run_source_loop_with_catalog(&src);
}

fn stop_sentinel_present(io: std.Io, path: []const u8) bool {
    if (path.len == 0) return false;
    std.Io.Dir.cwd().access(io, path, .{}) catch return false;
    return true;
}

fn run_fetcher_poll_once(io: std.Io, sentinel_path: []const u8, interval_ns: u64) !u8 {
    if (stop_sentinel_present(io, sentinel_path)) {
        print("ns-pollw: stop sentinel at boundary — stop_requested\n", .{});
        return stop_requested;
    }

    var fetcher: ns.BoltCatalog = undefined;
    try init_demo_fetcher(&fetcher);

    const one_pair = [_]sp.PeerBoltPair{.{ .peer = "peerB", .bolt = "b" }};
    _ = try poll_one_cycle_wire_sockets(&fetcher, &one_pair);

    if (interval_ns > 0) {
        sp.sleep_interval_ns(interval_ns);
        print("ns-pollw: slept {d} ns at cycle boundary\n", .{interval_ns});
    }

    print("ns-pollw: one wire poll cycle at boundary — cycle_ok\n", .{});
    return 0;
}

fn run_fetcher_poll_mirror_once(io: std.Io, sentinel_path: []const u8, interval_ns: u64) !u8 {
    if (stop_sentinel_present(io, sentinel_path)) {
        print("ns-pollw: stop sentinel at boundary — stop_requested\n", .{});
        return stop_requested;
    }

    var fetcher: ns.BoltCatalog = undefined;
    try init_demo_mirror_fetcher(&fetcher);

    const step = try poll_one_cycle_wire_sockets(&fetcher, &mirror_pairs);

    if (interval_ns > 0) {
        sp.sleep_interval_ns(interval_ns);
        print("ns-pollw: slept {d} ns at cycle boundary\n", .{interval_ns});
    }

    print("ns-pollw: host mirror cycle — {d} pair(s), {d} revision(s) synced — cycle_ok\n", .{
        mirror_pairs.len, step.revisions_synced,
    });
    return 0;
}

fn run_fetcher_poll_legacy(_: std.Io, fail_after_first: bool) !u8 {
    var fetcher: ns.BoltCatalog = undefined;
    try init_demo_fetcher(&fetcher);

    const one_pair = [_]sp.PeerBoltPair{.{ .peer = "peerB", .bolt = "b" }};

    const c1 = try poll_one_cycle_wire_sockets(&fetcher, &one_pair);
    if (c1.revisions_synced != 1 or c1.empty_asks != 1) return error.SyncFailed;

    if (fail_after_first) {
        print("ns-pollw: fetcher poll fell mid-service — restart expected\n", .{});
        return 1;
    }

    const c2 = try poll_one_cycle_wire_sockets(&fetcher, &one_pair);
    if (c2.revisions_synced != 0 or c2.empty_asks != 1) return error.SyncFailed;

    const name2 = ns.Name{ .peer = "peerB", .bolt = "b", .revision = 2, .path = witness_path };
    var buf: [128]u8 = undefined;
    const r2 = try fetcher.recall(name2, &buf);
    if (!std.mem.eql(u8, buf[0..r2.len], "rev-two")) return error.SyncFailed;

    print("ns-pollw: fetcher poll over localhost — recall GREEN\n", .{});
    return 0;
}

fn run_demo(allocator: std.mem.Allocator, io: std.Io, self_path: []const u8) !u8 {
    const source_argv = try allocator.alloc([]const u8, 2);
    source_argv[0] = self_path;
    source_argv[1] = "source-loop";
    var source_child = try std.process.spawn(io, .{ .argv = source_argv });
    var pause = c.timespec{ .sec = 0, .nsec = 50_000_000 };
    _ = c.nanosleep(&pause, null);

    const fetcher_argv = try allocator.alloc([]const u8, 2);
    fetcher_argv[0] = self_path;
    fetcher_argv[1] = "fetcher-poll-legacy";
    var fetcher_child = try std.process.spawn(io, .{ .argv = fetcher_argv });

    const ft = try fetcher_child.wait(io);
    const fc: u8 = switch (ft) { .exited => |c0| c0, else => 255 };
    if (fc != 0) return fc;

    source_child.kill(io);

    print("ns-pollw: demo GREEN — poll crossed localhost under Comlink seal\n", .{});
    print("ns-pollw: version {s}\n", .{npw_version});
    return 0;
}

pub fn main(init: std.process.Init) !u8 {
    const garden = init.arena.allocator();
    const io = init.io;
    const args = try init.minimal.args.toSlice(garden);

    if (args.len >= 2) {
        if (std.mem.eql(u8, args[1], "source-loop")) return run_source_loop(io);
        if (std.mem.eql(u8, args[1], "source-loop-mirror")) return run_source_loop_mirror(io);
        if (std.mem.eql(u8, args[1], "fetcher-poll")) {
            if (args.len < 3) return error.SyncFailed;
            if (std.mem.eql(u8, args[2], "fail")) return run_fetcher_poll_legacy(io, true);
            const interval_ns: u64 = if (args.len >= 4)
                try tally_parse_int.parse_int(u64, args[3], .{})
            else
                0;
            return run_fetcher_poll_once(io, args[2], interval_ns);
        }
        if (std.mem.eql(u8, args[1], "fetcher-poll-mirror")) {
            if (args.len < 3) return error.SyncFailed;
            const interval_ns: u64 = if (args.len >= 4)
                try tally_parse_int.parse_int(u64, args[3], .{})
            else
                0;
            return run_fetcher_poll_mirror_once(io, args[2], interval_ns);
        }
        if (std.mem.eql(u8, args[1], "fetcher-poll-legacy")) {
            const fail_mid = args.len >= 3 and std.mem.eql(u8, args[2], "fail");
            return run_fetcher_poll_legacy(io, fail_mid);
        }
        if (std.mem.eql(u8, args[1], "selftest")) return run_selftest(io);
        if (std.mem.eql(u8, args[1], "demo")) {
            assert(args.len >= 1);
            return run_demo(garden, io, args[0]);
        }
    }

    if (args.len >= 1) return run_selftest(io);
    return 1;
}
