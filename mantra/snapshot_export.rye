//! mantra/snapshot_export.rye — I2 snapshot export: batch replay + horizon bundles.
//!
//! Lap 1 reuses `resin_batch.rye` frames under a `0x06` snapshot header.
//! Lap 2 adds bundle prefixes (`catalog/`, `trust/`), a SHA3-512 head record,
//! and a continuity fact sketch per counsel I2 and I7.
//!
//!   rye build mantra/snapshot_export.rye -femit-bin=mantra/bin/snapshot-export
//!   mantra/bin/snapshot-export selftest
//!
//! Counsel: [`counsel/20260704-181612_zero-copy-resins-counsel-answers.md`](../counsel/20260704-181612_zero-copy-resins-counsel-answers.md) I2
//! · ruling [`counsel/20260706-232812_claude-ruling-oal4-mala-edit5-and-horizons.md`](../counsel/20260706-232812_claude-ruling-oal4-mala-edit5-and-horizons.md)

const std = @import("std");
const assert = std.debug.assert;
const tally_parse_int = @import("parse_int.rye");
const print = std.debug.print;
const ns = @import("recall_lap1.rye");
const rb = @import("resin_batch.rye");
const kumara = @import("kumara.rye");
const Sha3_512 = std.crypto.hash.sha3.Sha3_512;
const Sha3_256 = std.crypto.hash.sha3.Sha3_256;
const tally_copy = @import("tally_copy.rye");

pub const snapshot_export_version = "20260707.024712";
pub const snapshot_lap1_version = "20260707.021512";
const snapshot_kind: u8 = 0x06;
pub const max_revision_groups: u32 = 16;
pub const max_snapshot_bytes: u32 = 65536;

pub const bundle_catalog = "catalog/";
pub const bundle_trust = "trust/";
pub const head_record_path = "catalog/HEAD";
pub const trust_signer_path = "trust/export-signer.pk";

const meta_peer = "_snap";
const meta_bolt = "_meta";
const meta_revision: u32 = 1;
const tilak_manifest = "manifest";

pub const ContinuityKind = enum {
    export_kind,
    boot_kind,
};

pub const ContinuityFact = struct {
    identity: kumara.PublicKey,
    epoch: u64,
    kind: ContinuityKind,
    parent_hex: [64]u8,
    stamp: []const u8,
};

pub const SnapshotError = error{
    Overflow,
    Truncated,
    BadKind,
    BatchCountMismatch,
    LeafCountMismatch,
    ReplayMismatch,
    HeadRecordMissing,
    HeadDigestMismatch,
    ContinuityViolation,
};

pub const RevisionKey = struct {
    peer: [16]u8,
    peer_len: u32,
    bolt: [32]u8,
    bolt_len: u32,
    revision: u32,

    pub fn peer_slice(self: *const RevisionKey) []const u8 {
        return self.peer[0..self.peer_len];
    }

    pub fn bolt_slice(self: *const RevisionKey) []const u8 {
        return self.bolt[0..self.bolt_len];
    }

    fn matches(self: RevisionKey, peer: []const u8, bolt: []const u8, revision: u32) bool {
        return std.mem.eql(u8, self.peer_slice(), peer) and
            std.mem.eql(u8, self.bolt_slice(), bolt) and
            self.revision == revision;
    }
};

fn cap_u32(buf: []const u8) u32 {
    assert(buf.len <= std.math.maxInt(u32));
    return @intCast(buf.len);
}

fn put_u32(out: []u8, off: *u32, v: u32) SnapshotError!void {
    if (off.* + 4 > cap_u32(out)) return error.Overflow;
    std.mem.writeInt(u32, out[off.*..][0..4], v, .little);
    off.* += 4;
}

fn put_bytes(out: []u8, off: *u32, b: []const u8) SnapshotError!void {
    const n: u32 = @intCast(b.len);
    if (off.* + n > cap_u32(out)) return error.Overflow;
    tally_copy.copy_disjoint(u8, out[off.*..][0..b.len], b);
    off.* += n;
}

fn put_field(out: []u8, off: *u32, b: []const u8) SnapshotError!void {
    if (b.len > std.math.maxInt(u16)) return error.Overflow;
    if (off.* + 2 > cap_u32(out)) return error.Overflow;
    std.mem.writeInt(u16, out[off.*..][0..2], @intCast(b.len), .little);
    off.* += 2;
    try put_bytes(out, off, b);
}

fn get_u32(payload: []const u8, off: *u32) SnapshotError!u32 {
    if (off.* + 4 > cap_u32(payload)) return error.Truncated;
    const v = std.mem.readInt(u32, payload[off.*..][0..4], .little);
    off.* += 4;
    return v;
}

fn get_field(payload: []const u8, off: *u32) SnapshotError![]const u8 {
    if (off.* + 2 > cap_u32(payload)) return error.Truncated;
    const n = std.mem.readInt(u16, payload[off.*..][0..2], .little);
    off.* += 2;
    if (off.* + n > cap_u32(payload)) return error.Truncated;
    const s = payload[off.*..][0..n];
    off.* += n;
    return s;
}

fn path_starts_with(path: []const u8, prefix: []const u8) bool {
    return path.len >= prefix.len and std.mem.eql(u8, path[0..prefix.len], prefix);
}

fn is_head_or_trust_leaf(path: []const u8) bool {
    return std.mem.eql(u8, path, head_record_path) or path_starts_with(path, bundle_trust);
}

fn digest_hex256_of(content: []const u8, out: *[64]u8) void {
    var digest: [32]u8 = undefined;
    Sha3_256.hash(content, &digest, .{});
    var i: u32 = 0;
    while (i < 32) : (i += 1) {
        _ = std.fmt.bufPrint(out[i * 2 ..][0..2], "{x:0>2}", .{digest[i]}) catch unreachable;
    }
}

fn rebind_leaf_digest(leaf: *ns.LeafBinding) void {
    digest_hex256_of(leaf.bytes[0..leaf.bytes_len], &leaf.digest_hex);
}

fn digest_hex512_of(content: []const u8, out: *[128]u8) void {
    var digest: [Sha3_512.digest_length]u8 = undefined;
    Sha3_512.hash(content, &digest, .{});
    var i: u32 = 0;
    while (i < Sha3_512.digest_length) : (i += 1) {
        _ = std.fmt.bufPrint(out[i * 2 ..][0..2], "{x:0>2}", .{digest[i]}) catch unreachable;
    }
}

fn pubkey_hex(pk: kumara.PublicKey, out: *[64]u8) void {
    const bytes = pk.toBytes();
    var i: u32 = 0;
    while (i < bytes.len) : (i += 1) {
        _ = std.fmt.bufPrint(out[i * 2 ..][0..2], "{x:0>2}", .{bytes[i]}) catch unreachable;
    }
}

fn hex_eq128(a: []const u8, b: []const u8) bool {
    return a.len == 128 and b.len == 128 and std.mem.eql(u8, a, b);
}

pub fn collect_revisions(cat: *const ns.BoltCatalog, keys: *[max_revision_groups]RevisionKey, count: *u32) SnapshotError!void {
    count.* = 0;
    var i: u32 = 0;
    while (i < cat.leaf_count) : (i += 1) {
        const leaf = &cat.leaves[i];
        const peer = leaf.peer[0..leaf.peer_len];
        const bolt = leaf.bolt[0..leaf.bolt_len];
        const revision = leaf.revision;
        var j: u32 = 0;
        var seen = false;
        while (j < count.*) : (j += 1) {
            if (keys[j].matches(peer, bolt, revision)) {
                seen = true;
                break;
            }
        }
        if (!seen) {
            if (count.* >= max_revision_groups) return error.Overflow;
            var key: RevisionKey = undefined;
            tally_copy.copy_disjoint(u8, key.peer[0..peer.len], peer);
            key.peer_len = @intCast(peer.len);
            tally_copy.copy_disjoint(u8, key.bolt[0..bolt.len], bolt);
            key.bolt_len = @intCast(bolt.len);
            key.revision = revision;
            keys[count.*] = key;
            count.* += 1;
        }
    }
}

/// SHA3-512 HEAD over every catalog leaf digest in held order, excluding head/trust bundles.
pub fn compute_catalog_head512(cat: *const ns.BoltCatalog, out: *[128]u8) SnapshotError!void {
    var acc: [max_snapshot_bytes]u8 = undefined;
    var acc_len: u32 = 0;
    var i: u32 = 0;
    while (i < cat.leaf_count) : (i += 1) {
        const leaf = &cat.leaves[i];
        const path = leaf.path[0..leaf.path_len];
        if (is_head_or_trust_leaf(path)) continue;
        if (acc_len + 64 > cap_u32(&acc)) return error.Overflow;
        tally_copy.copy_disjoint(u8, acc[acc_len..][0..64], leaf.digest_hex[0..64]);
        acc_len += 64;
    }
    digest_hex512_of(acc[0..acc_len], out);
}

fn build_head_record_content(
    head_digest_hex: *const [128]u8,
    export_stamp: []const u8,
    identity_epoch: u64,
    continuity: ContinuityFact,
    parity_claim: []const u8,
    out: []u8,
) SnapshotError![]const u8 {
    var identity_hex: [64]u8 = undefined;
    pubkey_hex(continuity.identity, &identity_hex);
    const kind_str: []const u8 = switch (continuity.kind) {
        .export_kind => "export",
        .boot_kind => "boot",
    };
    const written = std.fmt.bufPrint(out, "head 1\nhead-digest-sha3-512:{s}\nexport-stamp:{s}\nidentity-epoch:{d}\nparity-claim:{s}\ncontinuity-identity:{s}\ncontinuity-epoch:{d}\ncontinuity-kind:{s}\ncontinuity-parent:{s}\ncontinuity-stamp:{s}\n", .{
        head_digest_hex,
        export_stamp,
        identity_epoch,
        parity_claim,
        identity_hex,
        continuity.epoch,
        kind_str,
        continuity.parent_hex,
        continuity.stamp,
    }) catch return error.Overflow;
    return written;
}

fn parse_head_record_content(content: []const u8) SnapshotError!struct {
    head_digest_hex: [128]u8,
    identity_epoch: u64,
    continuity: ContinuityFact,
    parity_claim: [64]u8,
    parity_claim_len: u32,
} {
    var head_digest_hex: [128]u8 = undefined;
    var identity_epoch: u64 = 0;
    var continuity_epoch: u64 = 0;
    var continuity_kind: ContinuityKind = .export_kind;
    var continuity_parent: [64]u8 = undefined;
    @memset(&continuity_parent, '0');
    var continuity_stamp: [64]u8 = undefined;
    var continuity_stamp_len: u32 = 0;
    var identity_hex: [64]u8 = undefined;
    @memset(&identity_hex, '0');
    var parity_claim: [64]u8 = undefined;
    var parity_claim_len: u32 = 0;
    var have_head_digest = false;

    var lines = std.mem.splitScalar(u8, content, '\n');
    while (lines.next()) |line| {
        if (line.len == 0) continue;
        if (std.mem.startsWith(u8, line, "head-digest-sha3-512:")) {
            const hex = line["head-digest-sha3-512:".len..];
            if (hex.len != 128) return error.Truncated;
            tally_copy.copy_disjoint(u8, head_digest_hex[0..128], hex);
            have_head_digest = true;
        } else if (std.mem.startsWith(u8, line, "identity-epoch:")) {
            identity_epoch = tally_parse_int.parse_int(u64, line["identity-epoch:".len..], .{}) catch return error.Truncated;
        } else if (std.mem.startsWith(u8, line, "parity-claim:")) {
            const claim = line["parity-claim:".len..];
            if (claim.len > parity_claim.len) return error.Truncated;
            tally_copy.copy_disjoint(u8, parity_claim[0..claim.len], claim);
            parity_claim_len = @intCast(claim.len);
        } else if (std.mem.startsWith(u8, line, "continuity-identity:")) {
            const hex = line["continuity-identity:".len..];
            if (hex.len != 64) return error.Truncated;
            tally_copy.copy_disjoint(u8, identity_hex[0..64], hex);
        } else if (std.mem.startsWith(u8, line, "continuity-epoch:")) {
            continuity_epoch = tally_parse_int.parse_int(u64, line["continuity-epoch:".len..], .{}) catch return error.Truncated;
        } else if (std.mem.startsWith(u8, line, "continuity-kind:")) {
            const kind = line["continuity-kind:".len..];
            if (std.mem.eql(u8, kind, "export")) {
                continuity_kind = .export_kind;
            } else if (std.mem.eql(u8, kind, "boot")) {
                continuity_kind = .boot_kind;
            } else {
                return error.Truncated;
            }
        } else if (std.mem.startsWith(u8, line, "continuity-parent:")) {
            const hex = line["continuity-parent:".len..];
            if (hex.len != 64) return error.Truncated;
            tally_copy.copy_disjoint(u8, continuity_parent[0..64], hex);
        } else if (std.mem.startsWith(u8, line, "continuity-stamp:")) {
            const stamp = line["continuity-stamp:".len..];
            if (stamp.len > continuity_stamp.len) return error.Truncated;
            tally_copy.copy_disjoint(u8, continuity_stamp[0..stamp.len], stamp);
            continuity_stamp_len = @intCast(stamp.len);
        }
    }

    if (!have_head_digest or continuity_epoch == 0) return error.Truncated;

    var pk_bytes: [32]u8 = undefined;
    var i: u32 = 0;
    while (i < 32) : (i += 1) {
        const pair = identity_hex[i * 2 ..][0..2];
        pk_bytes[i] = tally_parse_int.parse_int(u8, pair, .{ .base = 16, .allow_leading_zero = true }) catch return error.Truncated;
    }

    return .{
        .head_digest_hex = head_digest_hex,
        .identity_epoch = identity_epoch,
        .continuity = .{
            .identity = kumara.PublicKey.fromBytes(pk_bytes) catch return error.Truncated,
            .epoch = continuity_epoch,
            .kind = continuity_kind,
            .parent_hex = continuity_parent,
            .stamp = continuity_stamp[0..continuity_stamp_len],
        },
        .parity_claim = parity_claim,
        .parity_claim_len = parity_claim_len,
    };
}

fn find_leaf_bytes(cat: *const ns.BoltCatalog, peer: []const u8, bolt: []const u8, revision: u32, path: []const u8) SnapshotError![]const u8 {
    var i: u32 = 0;
    while (i < cat.leaf_count) : (i += 1) {
        const leaf = &cat.leaves[i];
        if (leaf.revision != revision) continue;
        if (!std.mem.eql(u8, leaf.peer[0..leaf.peer_len], peer)) continue;
        if (!std.mem.eql(u8, leaf.bolt[0..leaf.bolt_len], bolt)) continue;
        if (!std.mem.eql(u8, leaf.path[0..leaf.path_len], path)) continue;
        return leaf.bytes[0..leaf.bytes_len];
    }
    return error.HeadRecordMissing;
}

/// Verify the head record and continuity fact after batches apply.
pub fn verify_head_record(cat: *const ns.BoltCatalog, source_pk: kumara.PublicKey) SnapshotError!void {
    const head_bytes = try find_leaf_bytes(cat, meta_peer, meta_bolt, meta_revision, head_record_path);
    const parsed = try parse_head_record_content(head_bytes);

    var recomputed: [128]u8 = undefined;
    try compute_catalog_head512(cat, &recomputed);
    if (!hex_eq128(parsed.head_digest_hex[0..128], recomputed[0..128])) return error.HeadDigestMismatch;

    if (parsed.continuity.epoch == 0) return error.ContinuityViolation;
    if (!std.mem.eql(u8, &parsed.continuity.identity.toBytes(), &source_pk.toBytes())) return error.ContinuityViolation;

    _ = parsed.identity_epoch;
    _ = parsed.parity_claim;
    _ = parsed.parity_claim_len;
}

fn catalog_prefixed_path(orig: []const u8, out: []u8) SnapshotError![]const u8 {
    const prefixed = std.fmt.bufPrint(out, "{s}{s}", .{ bundle_catalog, orig }) catch return error.Overflow;
    if (prefixed.len > ns.max_path) return error.Overflow;
    return prefixed;
}

/// Stage a catalog with `catalog/` bundle prefixes plus head and trust leaves.
pub fn stage_horizon_catalog(
    src: *const ns.BoltCatalog,
    signer: kumara.KeyPair,
    identity_epoch: u64,
    continuity_stamp: []const u8,
    parity_claim: []const u8,
    staged: *ns.BoltCatalog,
) SnapshotError!void {
    staged.* = .empty();

    var path_buf: [ns.max_path]u8 = undefined;
    var i: u32 = 0;
    while (i < src.leaf_count) : (i += 1) {
        const leaf = &src.leaves[i];
        const orig_path = leaf.path[0..leaf.path_len];
        const prefixed = try catalog_prefixed_path(orig_path, &path_buf);
        staged.append_leaf(
            leaf.peer[0..leaf.peer_len],
            leaf.bolt[0..leaf.bolt_len],
            leaf.revision,
            prefixed,
            leaf.bytes[0..leaf.bytes_len],
            leaf.tilak[0..leaf.tilak_len],
        ) catch return error.Overflow;
    }

    var head_digest: [128]u8 = undefined;
    try compute_catalog_head512(staged, &head_digest);

    var parent_hex: [64]u8 = undefined;
    @memset(&parent_hex, '0');

    const continuity = ContinuityFact{
        .identity = signer.public_key,
        .epoch = 1,
        .kind = .export_kind,
        .parent_hex = parent_hex,
        .stamp = continuity_stamp,
    };

    var head_buf: [ns.max_resin_bytes]u8 = undefined;
    const head_content = try build_head_record_content(
        &head_digest,
        snapshot_export_version,
        identity_epoch,
        continuity,
        parity_claim,
        &head_buf,
    );
    staged.append_leaf(meta_peer, meta_bolt, meta_revision, head_record_path, head_content, tilak_manifest) catch return error.Overflow;

    const pk_bytes = signer.public_key.toBytes();
    staged.append_leaf(meta_peer, meta_bolt, meta_revision, trust_signer_path, &pk_bytes, "plain-bytes") catch return error.Overflow;
}

/// Write snapshot header (kind, version, leaf_count, rev_count); returns offset ready for batch append.
pub fn begin_snapshot_assembly(out: []u8, leaf_count: u32, rev_count: u32) SnapshotError!u32 {
    var off: u32 = 0;
    if (off + 1 > cap_u32(out)) return error.Overflow;
    out[off] = snapshot_kind;
    off += 1;
    try put_field(out, &off, snapshot_export_version);
    try put_u32(out, &off, leaf_count);
    try put_u32(out, &off, rev_count);
    return off;
}

/// Append one resin-batch frame into a snapshot buffer at `off`.
pub fn append_snapshot_batch(out: []u8, off: *u32, batch: []const u8) SnapshotError!void {
    try put_u32(out, off, @intCast(batch.len));
    try put_bytes(out, off, batch);
}

/// Initialize witness source catalog (lap 2 selftest shape).
pub fn init_witness_source_catalog(cat: *ns.BoltCatalog) SnapshotError!void {
    cat.* = .empty();
    cat.append_leaf("peerB", "b", 1, "a.txt", "alpha", "plain-text") catch return error.Overflow;
    cat.append_leaf("peerB", "b", 1, "b.txt", "beta", "plain-text") catch return error.Overflow;
    cat.append_leaf("peerB", "b", 2, "b.txt", "beta-two", "plain-text") catch return error.Overflow;
}

/// Build staged horizon + revision list for the witness fixture.
pub fn witness_horizon_plan(
    signer: kumara.KeyPair,
    staged: *ns.BoltCatalog,
    keys: *[max_revision_groups]RevisionKey,
    rev_count: *u32,
) SnapshotError!void {
    var src: ns.BoltCatalog = .empty();
    try init_witness_source_catalog(&src);
    try stage_horizon_catalog(&src, signer, 1, snapshot_export_version, "witnesses=185", staged);
    try collect_revisions(staged, keys, rev_count);
}

/// Export every leaf in `src` as one or more resin-batch frames under a snapshot header.
pub fn export_catalog(
    src: *const ns.BoltCatalog,
    signer: kumara.KeyPair,
    out: []u8,
) SnapshotError!u32 {
    var keys: [max_revision_groups]RevisionKey = undefined;
    var rev_count: u32 = 0;
    try collect_revisions(src, &keys, &rev_count);

    var off: u32 = 0;
    if (off + 1 > cap_u32(out)) return error.Overflow;
    out[off] = snapshot_kind;
    off += 1;
    try put_field(out, &off, snapshot_export_version);
    try put_u32(out, &off, src.leaf_count);
    try put_u32(out, &off, rev_count);

    var r: u32 = 0;
    while (r < rev_count) : (r += 1) {
        const key = keys[r];
        var batch_buf: [rb.max_batch_bytes]u8 = undefined;
        const built = rb.build_batch(
            src,
            key.peer_slice(),
            key.bolt_slice(),
            key.revision,
            &[_][64]u8{},
            signer,
            &batch_buf,
        ) catch return error.Overflow;
        try put_u32(out, &off, built.len);
        try put_bytes(out, &off, batch_buf[0..built.len]);
    }

    return off;
}

/// Export with bundle prefixes, head record, and trust signer leaf.
pub fn export_catalog_horizon(
    src: *const ns.BoltCatalog,
    signer: kumara.KeyPair,
    identity_epoch: u64,
    continuity_stamp: []const u8,
    parity_claim: []const u8,
    out: []u8,
) SnapshotError!u32 {
    var staged: ns.BoltCatalog = .empty();
    try stage_horizon_catalog(src, signer, identity_epoch, continuity_stamp, parity_claim, &staged);
    return try export_catalog(&staged, signer, out);
}

/// Import a snapshot into `dest`, replacing nothing — appends via each batch apply.
pub fn import_catalog(
    dest: *ns.BoltCatalog,
    snapshot: []const u8,
    source_pk: kumara.PublicKey,
) SnapshotError!u32 {
    dest.* = .empty();
    var off: u32 = 0;
    if (off + 1 > cap_u32(snapshot)) return error.Truncated;
    if (snapshot[off] != snapshot_kind) return error.BadKind;
    off += 1;
    const version = try get_field(snapshot, &off);
    if (!std.mem.eql(u8, version, snapshot_export_version) and
        !std.mem.eql(u8, version, snapshot_lap1_version))
    {
        return error.BadKind;
    }
    const claimed_leaves = try get_u32(snapshot, &off);
    const batch_count = try get_u32(snapshot, &off);

    var b: u32 = 0;
    while (b < batch_count) : (b += 1) {
        const batch_len = try get_u32(snapshot, &off);
        if (off + batch_len > cap_u32(snapshot)) return error.Truncated;
        _ = rb.apply_batch(dest, snapshot[off..][0..batch_len], source_pk) catch {
            dest.* = .empty();
            return error.Truncated;
        };
        off += batch_len;
    }

    if (dest.leaf_count != claimed_leaves) return error.LeafCountMismatch;
    return dest.leaf_count;
}

/// Import horizon snapshot and verify head record before returning.
pub fn import_catalog_horizon(
    dest: *ns.BoltCatalog,
    snapshot: []const u8,
    source_pk: kumara.PublicKey,
) SnapshotError!u32 {
    const imported = try import_catalog(dest, snapshot, source_pk);
    verify_head_record(dest, source_pk) catch {
        dest.* = .empty();
        return error.HeadDigestMismatch;
    };
    return imported;
}

/// Assert every leaf in `expect` recalls identically from `got`.
pub fn assert_catalog_replay(expect: *const ns.BoltCatalog, got: *const ns.BoltCatalog) SnapshotError!void {
    if (expect.leaf_count != got.leaf_count) return error.ReplayMismatch;
    var i: u32 = 0;
    while (i < expect.leaf_count) : (i += 1) {
        const leaf = &expect.leaves[i];
        const name = ns.Name{
            .peer = leaf.peer[0..leaf.peer_len],
            .bolt = leaf.bolt[0..leaf.bolt_len],
            .revision = leaf.revision,
            .path = leaf.path[0..leaf.path_len],
        };
        var buf: [ns.max_resin_bytes]u8 = undefined;
        const er = expect.recall(name, &buf) catch return error.ReplayMismatch;
        const gr = got.recall(name, &buf) catch return error.ReplayMismatch;
        if (er.outcome != gr.outcome or er.len != gr.len) return error.ReplayMismatch;
        if (!std.mem.eql(u8, buf[0..er.len], leaf.bytes[0..leaf.bytes_len])) return error.ReplayMismatch;
    }
}

fn run_selftest(_: std.Io) !u8 {
    const signer_seed = [_]u8{0x61} ** kumara.seed_length;
    const signer = kumara.keypair_from_seed(&signer_seed);

    var src: ns.BoltCatalog = .empty();
    try src.append_leaf("peerB", "b", 1, "a.txt", "alpha", "plain-text");
    try src.append_leaf("peerB", "b", 1, "b.txt", "beta", "plain-text");
    try src.append_leaf("peerB", "b", 2, "b.txt", "beta-two", "plain-text");

    var staged_expect: ns.BoltCatalog = .empty();
    try stage_horizon_catalog(&src, signer, 1, snapshot_export_version, "witnesses=181", &staged_expect);

    var snap: [max_snapshot_bytes]u8 = undefined;
    const snap_len = try export_catalog_horizon(&src, signer, 1, snapshot_export_version, "witnesses=181", &snap);

    var dest: ns.BoltCatalog = .empty();
    const imported = try import_catalog_horizon(&dest, snap[0..snap_len], signer.public_key);
    assert(imported == staged_expect.leaf_count);
    try assert_catalog_replay(&staged_expect, &dest);

    // Unwelcome: tampered batch byte refuses whole import.
    {
        var bad: [max_snapshot_bytes]u8 = undefined;
        tally_copy.copy_disjoint(u8, bad[0..snap_len], snap[0..snap_len]);
        bad[3] = if (bad[3] == 'z') 'y' else bad[3] + 1;
        var dest_bad: ns.BoltCatalog = .empty();
        if (import_catalog_horizon(&dest_bad, bad[0..snap_len], signer.public_key)) |_| {
            return error.Truncated;
        } else |_| {}
        assert(dest_bad.leaf_count == 0);
    }

    // Unwelcome: head digest claim mismatch refuses after batches apply.
    {
        var bad_staged: ns.BoltCatalog = .empty();
        try stage_horizon_catalog(&src, signer, 1, snapshot_export_version, "witnesses=181", &bad_staged);
        var j: u32 = 0;
        while (j < bad_staged.leaf_count) : (j += 1) {
            const leaf = &bad_staged.leaves[j];
            if (!std.mem.eql(u8, leaf.path[0..leaf.path_len], head_record_path)) continue;
            const content = leaf.bytes[0..leaf.bytes_len];
            const prefix = "head-digest-sha3-512:";
            if (std.mem.indexOf(u8, content, prefix)) |pos| {
                const hex_start = pos + prefix.len;
                if (hex_start < content.len) {
                    leaf.bytes[hex_start] = if (leaf.bytes[hex_start] == 'a') 'b' else 'a';
                    rebind_leaf_digest(leaf);
                }
            }
            break;
        }
        var bad_snap: [max_snapshot_bytes]u8 = undefined;
        const bad_len = try export_catalog(&bad_staged, signer, &bad_snap);
        var dest_bad: ns.BoltCatalog = .empty();
        if (import_catalog_horizon(&dest_bad, bad_snap[0..bad_len], signer.public_key)) |_| {
            return error.Truncated;
        } else |_| {}
        assert(dest_bad.leaf_count == 0);
    }

    print("snapshot: horizon export — {d} leaves with catalog/ trust/ head record\n", .{staged_expect.leaf_count});
    print("snapshot: SHA3-512 HEAD verified on import GREEN\n", .{});
    print("snapshot: continuity fact present — export kind GREEN\n", .{});
    print("snapshot: import replay — recall identical on every leaf GREEN\n", .{});
    print("snapshot: tampered batch and head refused whole GREEN\n", .{});
    print("snapshot: version {s} batch {s}\n", .{ snapshot_export_version, rb.batch_version });
    print("GREEN: I2 snapshot export lap 2 — horizon bundles replay on host.\n", .{});
    return 0;
}

pub fn main(init: std.process.Init) !u8 {
    const io = init.io;
    const args = try init.minimal.args.toSlice(init.arena.allocator());
    if (args.len >= 2 and std.mem.eql(u8, args[1], "selftest")) return run_selftest(io);
    return run_selftest(io);
}
