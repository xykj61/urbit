//! Rye test: std.mem.allEqual — pass 9940.
//!
//! Scalar uniformity complements eql (9941) and count (9951).

const std = @import("std");
const mem = std.mem;

pub fn main() void {
    std.debug.assert(mem.allEqual(u8, "aaa", 'a'));
    std.debug.assert(!mem.allEqual(u8, "aba", 'a'));
    std.debug.assert(mem.allEqual(u8, "", 'x'));
    std.debug.assert(mem.allEqual(u8, "x", 'x'));
    std.debug.assert(!mem.allEqual(u8, "xy", 'x'));

    std.debug.assert(mem.allEqual(u8, "    ", ' '));
    std.debug.assert(!mem.allEqual(u8, " \t", ' '));

    std.debug.print("rye: mem.allEqual assertions confirmed.\n", .{});
}
