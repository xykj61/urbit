//! Rye test: TokenIterator.peek via tokenizeScalar — pass 9957.
//!
//! Tokenize skips delimiter runs; peek matches next without advancing.
//! Pairs with SplitIterator.peek (9969).

const std = @import("std");
const mem = std.mem;

pub fn main() void {
    var it = mem.tokenizeScalar(u8, "   abc def   ghi  ", ' ');
    std.debug.assert(mem.eql(u8, it.next().?, "abc"));
    std.debug.assert(mem.eql(u8, it.peek().?, "def"));
    std.debug.assert(mem.eql(u8, it.next().?, "def"));
    std.debug.assert(mem.eql(u8, it.next().?, "ghi"));
    std.debug.assert(it.next() == null);

    std.debug.assert(mem.eql(u8, it.rest(), ""));

    var any = mem.tokenizeAny(u8, "a|b,c", " /,|");
    std.debug.assert(mem.eql(u8, any.next().?, "a"));
    std.debug.assert(mem.eql(u8, any.peek().?, "b"));
    std.debug.assert(mem.eql(u8, any.rest(), "b,c"));

    var solo = mem.tokenizeScalar(u8, "hello", ' ');
    std.debug.assert(mem.eql(u8, solo.next().?, "hello"));
    std.debug.assert(solo.next() == null);

    std.debug.print("rye: TokenIterator.peek assertions confirmed.\n", .{});
}
