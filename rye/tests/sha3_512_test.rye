//! Rye test: SHA3-512 parity with Zig 0.16.0.
//!
//! Goal: prove that SHA3-512, as provided by the standard crypto library,
//! produces the known-correct digest for a sample input. When this passes,
//! SHA3-512 in Rye works exactly as it does in Zig 0.16.0 — because Rye's
//! first version is the Zig 0.16.0 toolchain wearing a new name, so the
//! cryptography is the very same code.
//!
//! Method: hash the bytes "Rye" with SHA3-512, render the digest as lowercase
//! hex by hand (no reliance on a volatile formatting API), and assert it
//! equals a digest verified independently before this test was written.

const std = @import("std");
const Sha3_512 = std.crypto.hash.sha3.Sha3_512;

pub fn main() void {
    const message = "Rye";

    // Compute the SHA3-512 digest of the message.
    var digest: [Sha3_512.digest_length]u8 = undefined;
    Sha3_512.hash(message, &digest, .{});

    // Render the digest as lowercase hex with an explicit, bounded loop.
    const hex_alphabet = "0123456789abcdef";
    var actual_hex: [Sha3_512.digest_length * 2]u8 = undefined;
    for (digest, 0..) |byte, i| {
        actual_hex[i * 2] = hex_alphabet[byte >> 4];
        actual_hex[i * 2 + 1] = hex_alphabet[byte & 0x0f];
    }

    // The known-correct SHA3-512 of "Rye", verified independently.
    const expected_hex =
        "c692f0476279e6b867ee66c6701c119106a38f46881da52d733ac2b0cd092e96" ++
        "30249106dba551524678e70cea61686016926bdc984a191d055b329f2336763f";

    // Assert the positive space we expect: the digest matches exactly.
    std.debug.assert(actual_hex.len == expected_hex.len);
    std.debug.assert(std.mem.eql(u8, &actual_hex, expected_hex));

    std.debug.print("SHA3-512(\"{s}\") = {s}\n", .{ message, actual_hex });
    std.debug.print("rye: SHA3-512 parity with Zig 0.16.0 confirmed.\n", .{});
}
