//! Rye test: std.mem.containsAtLeast — pass 9950.
//!
//! Threshold search pairs with mem.count (9951); backs "at least N occurrences".

const std = @import("std");
const mem = std.mem;

pub fn main() void {
    std.debug.assert(mem.containsAtLeast(u8, "aa", 0, "a"));
    std.debug.assert(mem.containsAtLeast(u8, "aa", 2, "a"));
    std.debug.assert(!mem.containsAtLeast(u8, "aa", 3, "a"));

    std.debug.assert(mem.containsAtLeast(u8, "radaradar", 1, "radar"));
    std.debug.assert(!mem.containsAtLeast(u8, "radaradar", 2, "radar"));

    std.debug.assert(mem.containsAtLeastScalar2(u8, "aa", 'a', 2));
    std.debug.assert(!mem.containsAtLeastScalar2(u8, "aa", 'a', 3));
    std.debug.assert(mem.containsAtLeastScalar2(u8, "adadda", 'd', 3));

    std.debug.print("rye: containsAtLeast assertions confirmed.\n", .{});
}
