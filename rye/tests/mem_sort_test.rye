//! Rye test: std.mem.sort / sortUnstable — pass 9891.
//!
//! In-place slice sorting; postconditions checked for len <= 64.

const std = @import("std");
const mem = std.mem;

fn ascU8(_: void, lhs: u8, rhs: u8) bool {
    return lhs < rhs;
}

fn ascI32(_: void, lhs: i32, rhs: i32) bool {
    return lhs < rhs;
}

pub fn main() void {
    var arr = [_]u8{ 5, 2, 8, 1, 9, 3 };
    mem.sort(u8, arr[0..], {}, ascU8);
    std.debug.assert(std.sort.isSorted(u8, arr[0..], {}, ascU8));
    std.debug.assert(mem.eql(u8, &arr, &[_]u8{ 1, 2, 3, 5, 8, 9 }));

    var arr2 = [_]i32{ 30, 10, 20 };
    mem.sortUnstable(i32, arr2[0..], {}, ascI32);
    std.debug.assert(std.sort.isSorted(i32, arr2[0..], {}, ascI32));
    std.debug.assert(arr2[0] == 10 and arr2[1] == 20 and arr2[2] == 30);

    std.debug.print("rye: mem.sort/sortUnstable assertions confirmed.\n", .{});
}
