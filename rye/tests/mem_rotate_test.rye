//! Rye test: mem.rotate — pass 9918.
//!
//! In-place left rotation; pairs with mem.reverse (9921) and mem.swap (9919).

const std = @import("std");
const mem = std.mem;

pub fn main() void {
    var arr = [_]i32{ 5, 3, 1, 2, 4 };
    mem.rotate(i32, arr[0..], 2);
    std.debug.assert(mem.eql(i32, &arr, &[_]i32{ 1, 2, 4, 5, 3 }));

    var ring = [_]u8{ 0, 1, 2, 3 };
    mem.rotate(u8, ring[0..], 1);
    std.debug.assert(mem.eql(u8, &ring, &[_]u8{ 1, 2, 3, 0 }));

    mem.rotate(u8, ring[0..], 0);
    std.debug.assert(mem.eql(u8, &ring, &[_]u8{ 1, 2, 3, 0 }));

    std.debug.print("rye: mem.rotate assertions confirmed.\n", .{});
}
