//! Rye test: std.mem.alignForwardLog2 / isAlignedAnyAlign — pass 9899.
//!
//! Log2 forward round-up and arbitrary-alignment predicate; pairs with 9900–9902.

const std = @import("std");
const mem = std.mem;

pub fn main() void {
    const fwd = mem.alignForwardLog2(17, 3);
    std.debug.assert(fwd == 24);
    std.debug.assert(mem.isAlignedLog2(fwd, 3));

    std.debug.assert(mem.isAlignedAnyAlign(18, 6));
    std.debug.assert(!mem.isAlignedAnyAlign(17, 6));
    std.debug.assert(mem.isAlignedAnyAlign(16, 8));

    std.debug.print("rye: mem.alignForwardLog2/isAlignedAnyAlign assertions confirmed.\n", .{});
}
