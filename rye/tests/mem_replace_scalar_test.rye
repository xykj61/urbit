//! Rye test: mem.replaceScalar — pass 9914.
//!
//! In-place scalar replacement; pairs with replace family (9915–9917).

const std = @import("std");
const mem = std.mem;

pub fn main() void {
    var path = [_]u8{ 'a', '\\', 'b', '\\', 'c' };
    mem.replaceScalar(u8, path[0..], '\\', '/');
    std.debug.assert(mem.eql(u8, &path, "a/b/c"));

    var letters = [_]u8{ 'x', 'x', 'x' };
    mem.replaceScalar(u8, letters[0..], 'x', 'y');
    std.debug.assert(mem.eql(u8, &letters, "yyy"));

    var nums = [_]i32{ 1, 2, 1, 3 };
    mem.replaceScalar(i32, nums[0..], 1, 9);
    std.debug.assert(nums[0] == 9 and nums[1] == 2 and nums[2] == 9 and nums[3] == 3);

    std.debug.print("rye: mem.replaceScalar assertions confirmed.\n", .{});
}
