//! Rye test: Mantra weave — pass 9990.
//!
//! Exercises the pure core of Mantra: the Weave data model and the LCS-based
//! diff computation. No file I/O — pure inputs, deterministic outputs.
//!
//! Scenarios covered:
//!   1. Empty weave: current() returns zero lines.
//!   2. apply({inserts: ["a","b","c"], deletes:[]}): 3 lines present.
//!   3. apply({inserts: ["d"], deletes:[1]}): "b" gone, "d" added.
//!   4. All invariants: gen >= 1, pos < next_pos, sorted positions.
//!   5. LCS diff: old=["a","b","c"] new=["a","c","d"] → delete pos 1, insert "d".
//!   6. Idempotent add: diff of unchanged text = empty diff.

const std = @import("std");

// ---- Weave (inlined from mantra/src/main.rye) ---------------------------

const Line = struct { text: []const u8, gen: u32, pos: u32 };
const Diff = struct {
    inserts: []const []const u8,
    deletes: []const u32,
};

const Weave = struct {
    lines:    std.ArrayListUnmanaged(Line),
    next_pos: u32,

    fn empty() Weave {
        return .{ .lines = std.ArrayListUnmanaged(Line).empty, .next_pos = 0 };
    }

    fn apply(self: *Weave, allocator: std.mem.Allocator, d: Diff) !void {
        for (d.deletes) |target_pos| {
            var found = false;
            for (self.lines.items) |*line| {
                if (line.pos == target_pos) {
                    std.debug.assert(line.gen % 2 == 1);
                    line.gen += 1;
                    found = true;
                    break;
                }
            }
            std.debug.assert(found);
        }
        for (d.inserts) |text| {
            const new_line = Line{ .text = text, .gen = 1, .pos = self.next_pos };
            std.debug.assert(new_line.gen % 2 == 1);
            try self.lines.append(allocator, new_line);
            self.next_pos += 1;
        }
        for (self.lines.items) |line| {
            std.debug.assert(line.gen >= 1);
            std.debug.assert(line.pos < self.next_pos);
        }
    }

    fn current(self: *const Weave, allocator: std.mem.Allocator) ![]const Line {
        var out = std.ArrayListUnmanaged(Line).empty;
        for (self.lines.items) |line| {
            if (line.gen % 2 == 1) try out.append(allocator, line);
        }
        const result = try out.toOwnedSlice(allocator);
        std.mem.sort(Line, result, {}, struct {
            fn lt(_: void, a: Line, b: Line) bool { return a.pos < b.pos; }
        }.lt);
        for (result) |line| std.debug.assert(line.gen % 2 == 1);
        for (result, 0..) |_, i| {
            if (i + 1 < result.len) std.debug.assert(result[i].pos < result[i + 1].pos);
        }
        return result;
    }
};

// ---- LCS diff (inlined from mantra/src/main.rye) ------------------------

fn computeDiff(
    allocator: std.mem.Allocator,
    old_lines: []const Line,
    new_text:  []const []const u8,
) !Diff {
    const m = old_lines.len;
    const n = new_text.len;
    const table = try allocator.alloc(u32, (m + 1) * (n + 1));
    defer allocator.free(table);
    @memset(table, 0);
    for (1..m + 1) |i| {
        for (1..n + 1) |j| {
            if (std.mem.eql(u8, old_lines[i-1].text, new_text[j-1])) {
                table[i*(n+1)+j] = table[(i-1)*(n+1)+(j-1)] + 1;
            } else {
                const up   = table[(i-1)*(n+1)+j];
                const left = table[i*(n+1)+(j-1)];
                table[i*(n+1)+j] = if (up >= left) up else left;
            }
        }
    }
    const kept_old = try allocator.alloc(bool, m);
    const kept_new = try allocator.alloc(bool, n);
    defer allocator.free(kept_old);
    defer allocator.free(kept_new);
    @memset(kept_old, false);
    @memset(kept_new, false);
    var i: usize = m;
    var j: usize = n;
    while (i > 0 and j > 0) {
        if (std.mem.eql(u8, old_lines[i-1].text, new_text[j-1])) {
            kept_old[i-1] = true; kept_new[j-1] = true; i -= 1; j -= 1;
        } else if (table[(i-1)*(n+1)+j] >= table[i*(n+1)+(j-1)]) {
            i -= 1;
        } else {
            j -= 1;
        }
    }
    var deletes = std.ArrayListUnmanaged(u32).empty;
    for (old_lines, 0..) |line, idx| {
        if (!kept_old[idx]) try deletes.append(allocator, line.pos);
    }
    var inserts = std.ArrayListUnmanaged([]const u8).empty;
    for (new_text, 0..) |text, idx| {
        if (!kept_new[idx]) try inserts.append(allocator, text);
    }
    const result = Diff{
        .inserts = try inserts.toOwnedSlice(allocator),
        .deletes = try deletes.toOwnedSlice(allocator),
    };
    std.debug.assert(result.inserts.len <= n);
    std.debug.assert(result.deletes.len <= m);
    return result;
}

// ---- Test body ----------------------------------------------------------

pub fn main() void {
    const allocator = std.heap.page_allocator;

    // 1. Empty weave.
    var w = Weave.empty();
    const empty_view = w.current(allocator) catch unreachable;
    std.debug.assert(empty_view.len == 0);
    std.debug.assert(w.next_pos == 0);

    // 2. Apply first diff: insert "a", "b", "c".
    const ins_abc: []const []const u8 = &.{ "a", "b", "c" };
    const del_none: []const u32 = &.{};
    w.apply(allocator, .{ .inserts = ins_abc, .deletes = del_none }) catch unreachable;
    const view_abc = w.current(allocator) catch unreachable;
    std.debug.assert(view_abc.len == 3);
    std.debug.assert(std.mem.eql(u8, view_abc[0].text, "a"));
    std.debug.assert(std.mem.eql(u8, view_abc[1].text, "b"));
    std.debug.assert(std.mem.eql(u8, view_abc[2].text, "c"));
    std.debug.assert(view_abc[0].pos == 0);
    std.debug.assert(view_abc[1].pos == 1);
    std.debug.assert(view_abc[2].pos == 2);
    std.debug.assert(w.next_pos == 3);

    // 3. Apply second diff: delete pos 1 ("b"), insert "d".
    const ins_d: []const []const u8 = &.{"d"};
    const del_b: []const u32 = &.{1};
    w.apply(allocator, .{ .inserts = ins_d, .deletes = del_b }) catch unreachable;
    const view_acd = w.current(allocator) catch unreachable;
    std.debug.assert(view_acd.len == 3);
    std.debug.assert(std.mem.eql(u8, view_acd[0].text, "a")); // pos 0
    std.debug.assert(std.mem.eql(u8, view_acd[1].text, "c")); // pos 2
    std.debug.assert(std.mem.eql(u8, view_acd[2].text, "d")); // pos 3
    // "b" is gone (even gen) but still in the weave history.
    std.debug.assert(w.lines.items.len == 4); // a, b, c, d — history preserved
    std.debug.assert(w.lines.items[1].gen % 2 == 0); // "b" is gone
    std.debug.assert(w.next_pos == 4);

    // 4. LCS diff: old=["a","b","c"]  new=["a","c","d"]
    //    LCS = ["a","c"] → delete pos 1 (b), insert "d".
    // Reset to just a, b, c for this scenario.
    var w2 = Weave.empty();
    w2.apply(allocator, .{ .inserts = ins_abc, .deletes = del_none }) catch unreachable;
    const old2 = w2.current(allocator) catch unreachable;
    const new_acd: []const []const u8 = &.{ "a", "c", "d" };
    const d = computeDiff(allocator, old2, new_acd) catch unreachable;
    std.debug.assert(d.deletes.len == 1);  // "b" (pos 1) is deleted
    std.debug.assert(d.deletes[0] == 1);
    std.debug.assert(d.inserts.len == 1);  // "d" is new
    std.debug.assert(std.mem.eql(u8, d.inserts[0], "d"));
    // Verify applying the diff produces the expected view.
    w2.apply(allocator, d) catch unreachable;
    const result = w2.current(allocator) catch unreachable;
    std.debug.assert(result.len == 3);
    std.debug.assert(std.mem.eql(u8, result[0].text, "a"));
    std.debug.assert(std.mem.eql(u8, result[1].text, "c"));
    std.debug.assert(std.mem.eql(u8, result[2].text, "d"));

    // 5. Idempotent: diff of unchanged text produces an empty diff.
    const view_after = w2.current(allocator) catch unreachable;
    const d_noop = computeDiff(allocator, view_after, new_acd) catch unreachable;
    std.debug.assert(d_noop.inserts.len == 0);
    std.debug.assert(d_noop.deletes.len == 0);

    std.debug.print("rye: Mantra weave assertions confirmed (Weave, Diff, LCS, idempotent).\n", .{});
}
