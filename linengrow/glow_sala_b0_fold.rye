//! linengrow/glow_sala_b0_fold.rye — Glow product fold peer to elder sala_b0_fold.
//!
//! STOA198: `run_demo_fold` is the composed claim path (fixture → append →
//! replay). Elder `sala_b0_fold` stays the baseline peer.
//! STOA203: append builds through product sign+line; elder sign/format bodies
//! underneath. Glow-authored crypto jets and elder-replay body stay held.
//! STOA235: `run_demo_fold_from_desk_file` reads fact-line lit desk then claims.
//!
//!   rye build linengrow/glow_sala_b0_fold_witness.rye \
//!     -femit-bin=linengrow/bin/glow_sala_b0_fold_witness

const std = @import("std");
const claim = @import("glow_sala_b0_claim.rye");
const elder = @import("sala_b0_fold.rye");

pub const fold_version = "20260722.134552";

/// Product-owned pin — same HAWM1 demo root the elder fold proves.
pub const expected_demo_root_hex = claim.expected_demo_root_hex;

pub const FoldError = claim.ClaimError;

/// Run the Glow-composed three-event demo fold (pin append path).
pub fn run_demo_fold() FoldError![32]u8 {
    return claim.claim_demo_fold();
}

/// Run fold from runtime desk text (STOA235).
pub fn run_demo_fold_from_desk(desk_src: []const u8) FoldError![32]u8 {
    return claim.claim_demo_fold_from_desk(desk_src);
}

/// Read lit desk from cwd, then desk fold claim (STOA235 file I/O).
pub fn run_demo_fold_from_desk_file(init: std.process.Init) FoldError![32]u8 {
    return claim.claim_demo_fold_from_desk_file(init);
}

/// Hex-encode a 32-byte root (same table as elder).
pub fn root_to_hex(root: *const [32]u8, out: *[64]u8) void {
    claim.root_to_hex(root, out);
}

/// True when `root` matches the product-owned expected demo root.
pub fn root_matches_expected(root: *const [32]u8) bool {
    return claim.root_matches_expected(root);
}

/// True when Glow fold pin agrees with elder fold pin.
pub fn pin_agrees_elder() bool {
    return std.mem.eql(u8, expected_demo_root_hex, elder.expected_demo_root_hex);
}
