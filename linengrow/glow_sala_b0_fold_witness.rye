//! linengrow/glow_sala_b0_fold_witness.rye — proves Glow product fold peer.
//!
//!   rye build linengrow/glow_sala_b0_fold_witness.rye \
//!     -femit-bin=linengrow/bin/glow_sala_b0_fold_witness
//!   linengrow/bin/glow_sala_b0_fold_witness

const std = @import("std");
const assert = std.debug.assert;
const print = std.debug.print;
const glow_fold = @import("glow_sala_b0_fold.rye");
const elder = @import("sala_b0_fold.rye");

const witness_version = "20260722.134552";

fn run_selftest(init: std.process.Init) !u8 {
    assert(glow_fold.pin_agrees_elder());
    print("sala-b0-glow-fold: pin agrees elder -- GREEN\n", .{});

    const root = try glow_fold.run_demo_fold();
    var hex: [64]u8 = undefined;
    glow_fold.root_to_hex(&root, &hex);
    print("sala-b0-glow-fold: session root -- {s}\n", .{hex[0..]});
    assert(glow_fold.root_matches_expected(&root));
    assert(std.mem.eql(u8, hex[0..], glow_fold.expected_demo_root_hex));
    print("sala-b0-glow-fold: run_demo_fold matches product root -- GREEN\n", .{});

    const elder_root = try elder.run_demo_fold();
    assert(std.mem.eql(u8, &root, &elder_root));
    print("sala-b0-glow-fold: agrees elder run_demo_fold -- GREEN\n", .{});

    // STOA235: desk-file fold equals pin fold.
    const desk_root = try glow_fold.run_demo_fold_from_desk_file(init);
    assert(std.mem.eql(u8, &desk_root, &root));
    assert(glow_fold.root_matches_expected(&desk_root));
    print("sala-b0-glow-fold: desk-file fold matches pin fold -- GREEN\n", .{});
    print("sala-b0-glow-fold: STOA235 desk-file fold -- GREEN\n", .{});

    print("sala-b0-glow-fold: version {s}\n", .{witness_version});
    print("GREEN: Glow Sala B0 product fold — STOA198/235; pin + desk-file fold.\n", .{});
    return 0;
}

pub fn main(init: std.process.Init) !u8 {
    return run_selftest(init);
}
