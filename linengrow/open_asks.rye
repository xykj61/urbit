//! linengrow/open_asks.rye — OA-L1 closed ask loop: post, apply, accept, complete, verify.
//!
//!   rye build linengrow/open_asks.rye -femit-bin=linengrow/bin/open-asks
//!   linengrow/bin/open-asks selftest
//!
//! Scope: [`active-designing/20260706-002912_open-asks-hammock-scope.md`](../active-designing/20260706-002912_open-asks-hammock-scope.md)

const std = @import("std");
const assert = std.debug.assert;
const kumara = @import("kumara.rye");
const print = std.debug.print;
const Dir = std.Io.Dir;
const Sha3_256 = std.crypto.hash.sha3.Sha3_256;
const rc = @import("receipt_core.rye");
const tally_copy = @import("tally_copy.rye");

const oa1_version = "20260707.023512";
pub const poster_seed = [_]u8{0x51} ** kumara.seed_length;
pub const applicant_seed = [_]u8{0x52} ** kumara.seed_length;
const oa1_poster_seed = poster_seed;
const oa1_applicant_seed = applicant_seed;

/// Nyasa — the escrow account (Kaeden's word, 20260706.014512): value held in
/// trust between poster and applicant, from acceptance until completion. A
/// reserved deterministic identity, so a hold and a release name it as an
/// ordinary account without forking the fact shape.
pub const escrow_seed = [_]u8{0x53} ** kumara.seed_length;

/// OA-L3 escrow memo prefixes on the receipt-core fact. The hold is the M1
/// commitment (poster to Nyasa); the release is the M2 delivery (Nyasa to
/// applicant). The wire does not fork: an escrow fact is a receipt-core fact
/// whose memo names its role.
pub const escrow_hold_prefix = "escrow-hold request_ref=";
pub const escrow_release_prefix = "escrow-release request_ref=";
pub const completion_memo_prefix = "completion request_ref=";
pub const EscrowRole = enum { hold, release };

/// OA-L4 consent memo values — the applicant names whether this completion may
/// count toward a private reputation fold. Withheld consent excludes the bounty
/// entirely; missing consent after completion excludes it too.
pub const consent_grant = "grant";
pub const consent_withhold = "withhold";

pub const max_reputation_cycles: u32 = 8;

pub const oa2_payload_header: u32 = kumara.signature_length + 4;

/// Pinned witness request — canonical bytes for `tools/fixtures/open_asks_request.bron`.
pub const witness_canonical_request =
    \\poster c050c5637a44fa8629fff3cccce2300cb362a63d99d95fc54145266f4332445a
    \\title animator for researcher interview visuals
    \\skills animation,video
    \\bounds remote, 4 hours, paid micro-gig
    \\stipend 100
    \\deadline 20260715.235959
    \\stamp 20260706.002912
    \\
;

pub const witness_request_ref = "9cdb9aafd7672a6b58f1d9c123f58abce7a4eff29ff855795aa40474d0424390";

pub const ref_hex_len: u32 = Sha3_256.digest_length * 2;
pub const max_oa_fact: u32 = 512;
pub const max_line_len: u32 = rc.sig_hex_len + 1 + max_oa_fact * 2;
pub const max_log_len: u32 = 16384;

pub const RequestFields = struct {
    poster: []const u8,
    title: []const u8,
    skills: []const u8,
    bounds: []const u8,
    stipend: []const u8,
    deadline: []const u8,
    stamp: []const u8,
};

pub const ApplicationFields = struct {
    applicant: []const u8,
    request_ref: []const u8,
    message: []const u8,
    stamp: []const u8,
};

pub const AcceptanceFields = struct {
    poster: []const u8,
    request_ref: []const u8,
    applicant: []const u8,
    stamp: []const u8,
};

pub const ConsentFields = struct {
    applicant: []const u8,
    request_ref: []const u8,
    consent: []const u8,
    stamp: []const u8,
};

pub const ConsentChoice = enum { grant, withhold };

pub const AskCycle = struct {
    request_ref: [ref_hex_len]u8 = undefined,
    request_ref_len: u32 = 0,
    applicant_hex: [64]u8 = undefined,
    applicant_hex_len: u32 = 0,
    stipend: i64 = 0,
    completed: bool = false,
    consent: enum { none, grant, withhold } = .none,
};

pub const ReputationFoldState = struct {
    consented_completions: u32 = 0,
    consented_stipend: i64 = 0,
};

pub const FoldState = struct {
    request_ref: [ref_hex_len]u8 = undefined,
    request_ref_len: u32 = 0,
    posted: bool = false,
    applied: bool = false,
    accepted: bool = false,
    completed: bool = false,
    poster_hex: [64]u8 = undefined,
    poster_hex_len: u32 = 0,
    applicant_hex: [64]u8 = undefined,
    applicant_hex_len: u32 = 0,
    stipend: i64 = 0,
    held: bool = false,
    released: bool = false,
    escrow_balance: i64 = 0,
};

fn copy_hex_field(src: []const u8, dest: []u8) error{FoldFailed}!u32 {
    if (src.len > buf_len_u32(dest)) return error.FoldFailed;
    tally_copy.copy_disjoint(u8, dest[0..src.len], src);
    return @intCast(src.len);
}

fn buf_len_u32(buf: []const u8) u32 {
    assert(buf.len <= std.math.maxInt(u32));
    return @intCast(buf.len);
}

fn trim_line(line: []const u8) []const u8 {
    return std.mem.trim(u8, line, " \t\r\n");
}

fn parse_key_line(line: []const u8) error{InvalidFact}!struct { key: []const u8, value: []const u8 } {
    const space = std.mem.indexOfScalar(u8, line, ' ') orelse return error.InvalidFact;
    const key = line[0..space];
    const value = trim_line(line[space + 1 ..]);
    if (value.len == 0) return error.InvalidFact;
    return .{ .key = key, .value = value };
}

pub fn parse_request_fields(text: []const u8, fields: *RequestFields) error{InvalidFact}!void {
    var poster_set = false;
    var title_set = false;
    var skills_set = false;
    var bounds_set = false;
    var stipend_set = false;
    var deadline_set = false;
    var stamp_set = false;

    var lines = std.mem.splitScalar(u8, text, '\n');
    while (lines.next()) |raw| {
        const line = trim_line(raw);
        if (line.len == 0) continue;
        if (line[0] == '#') continue;
        const kv = parse_key_line(line) catch return error.InvalidFact;
        if (std.mem.eql(u8, kv.key, "poster")) {
            fields.poster = kv.value;
            poster_set = true;
        } else if (std.mem.eql(u8, kv.key, "title")) {
            fields.title = kv.value;
            title_set = true;
        } else if (std.mem.eql(u8, kv.key, "skills")) {
            fields.skills = kv.value;
            skills_set = true;
        } else if (std.mem.eql(u8, kv.key, "bounds")) {
            fields.bounds = kv.value;
            bounds_set = true;
        } else if (std.mem.eql(u8, kv.key, "stipend")) {
            fields.stipend = kv.value;
            stipend_set = true;
        } else if (std.mem.eql(u8, kv.key, "deadline")) {
            fields.deadline = kv.value;
            deadline_set = true;
        } else if (std.mem.eql(u8, kv.key, "stamp")) {
            fields.stamp = kv.value;
            stamp_set = true;
        } else {
            return error.InvalidFact;
        }
    }
    if (!poster_set or !title_set or !skills_set or !bounds_set or !stipend_set or !deadline_set or !stamp_set) {
        return error.InvalidFact;
    }
}

pub fn write_canonical_request(fields: RequestFields, out: []u8) error{Overflow}!u32 {
    const written = std.fmt.bufPrint(
        out,
        "poster {s}\ntitle {s}\nskills {s}\nbounds {s}\nstipend {s}\ndeadline {s}\nstamp {s}\n",
        .{ fields.poster, fields.title, fields.skills, fields.bounds, fields.stipend, fields.deadline, fields.stamp },
    ) catch return error.Overflow;
    return buf_len_u32(written);
}

pub fn parse_application_fields(text: []const u8, fields: *ApplicationFields) error{InvalidFact}!void {
    var applicant_set = false;
    var ref_set = false;
    var message_set = false;
    var stamp_set = false;

    var lines = std.mem.splitScalar(u8, text, '\n');
    while (lines.next()) |raw| {
        const line = trim_line(raw);
        if (line.len == 0) continue;
        if (line[0] == '#') continue;
        const kv = parse_key_line(line) catch return error.InvalidFact;
        if (std.mem.eql(u8, kv.key, "applicant")) {
            fields.applicant = kv.value;
            applicant_set = true;
        } else if (std.mem.eql(u8, kv.key, "request_ref")) {
            if (kv.value.len != ref_hex_len) return error.InvalidFact;
            fields.request_ref = kv.value;
            ref_set = true;
        } else if (std.mem.eql(u8, kv.key, "message")) {
            fields.message = kv.value;
            message_set = true;
        } else if (std.mem.eql(u8, kv.key, "stamp")) {
            fields.stamp = kv.value;
            stamp_set = true;
        } else {
            return error.InvalidFact;
        }
    }
    if (!applicant_set or !ref_set or !message_set or !stamp_set) return error.InvalidFact;
}

pub fn write_canonical_application(fields: ApplicationFields, out: []u8) error{Overflow}!u32 {
    const written = std.fmt.bufPrint(
        out,
        "applicant {s}\nrequest_ref {s}\nmessage {s}\nstamp {s}\n",
        .{ fields.applicant, fields.request_ref, fields.message, fields.stamp },
    ) catch return error.Overflow;
    return buf_len_u32(written);
}

