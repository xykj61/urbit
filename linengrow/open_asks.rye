pub fn parse_consent_fields(text: []const u8, fields: *ConsentFields) error{InvalidFact}!void {
    var applicant_set = false;
    var ref_set = false;
    var consent_set = false;
    var stamp_set = false;

    var lines = std.mem.splitScalar(u8, text, '\n');
    while (lines.next()) |raw| {
        const line = trim_line(raw);
        if (line.len == 0) continue;
        if (line[0] == '#') continue;
        const kv = parse_key_line(line) catch return error.InvalidFact;
        if (std.mem.eql(u8, kv.key, "applicant")) {
            fields.applicant = kv.value;
            applicant_set = true;
        } else if (std.mem.eql(u8, kv.key, "request_ref")) {
            if (kv.value.len != ref_hex_len) return error.InvalidFact;
            fields.request_ref = kv.value;
            ref_set = true;
        } else if (std.mem.eql(u8, kv.key, "consent")) {
            fields.consent = kv.value;
            consent_set = true;
