//! linengrow/glow_sala_b0_fields_witness.rye — proves Glow FactFields parse surface.
//!
//!   rye build linengrow/glow_sala_b0_fields_witness.rye \
//!     -femit-bin=linengrow/bin/glow_sala_b0_fields_witness
//!   linengrow/bin/glow_sala_b0_fields_witness

const std = @import("std");
const assert = std.debug.assert;
const print = std.debug.print;
const fixture = @import("glow_sala_b0_demo_fixture.rye");
const fields = @import("glow_sala_b0_fields.rye");

const witness_version = "20260721.193404";

fn run_selftest() !u8 {
    assert(fixture.root_pin_agrees());
    print("sala-b0-fields: fixture root pin seated -- GREEN\n", .{});

    const parsed = try fields.claim_demo_fields();
    print("sala-b0-fields: claim_demo_fields round-trip -- GREEN\n", .{});
    assert(parsed.memo.len > 0);
    print("sala-b0-fields: memo -- {s}\n", .{parsed.memo});

    // Bad fact refuse: missing stamp key.
    var bad_fields: @TypeOf(parsed) = undefined;
    const bad = fields.parse_fact_fields("from a\nto b\namount 1\nmemo x\n", &bad_fields);
    assert(bad == error.InvalidFact);
    print("sala-b0-fields: incomplete fact refuses parse -- GREEN\n", .{});

    const bad_amt = fields.parse_amount_signed("01");
    assert(bad_amt == error.InvalidAmount);
    print("sala-b0-fields: leading-zero amount refuses -- GREEN\n", .{});

    print("sala-b0-fields: version {s}\n", .{witness_version});
    print("GREEN: Glow Sala B0 fields surface — STOA212; elder parse_fact_fields behind Glow assert.\n", .{});
    return 0;
}

pub fn main(_: std.process.Init) !u8 {
    return run_selftest();
}
