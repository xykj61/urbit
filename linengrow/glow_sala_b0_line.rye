//! linengrow/glow_sala_b0_line.rye — Glow product log-line surface over elder receipt_core.
//!
//! STOA202 (B2): owns format_log_line + parse_log_line while calling elder
//! bodies. Wires with STOA201 sign for a demo round-trip.
//! STOA203: append composes through this surface + sign.
//! STOA225: demo sig/fact hex pins + Glow face=lit desk bind
//! (`glow/gen/sample-demo-fact-line-lits.glow`). Pins match
//! `claim_demo_line` under issuer seed · fixture stamp1/memo1.
//! STOA227: `format_demo_line_from_pins` emits the elder line from those
//! seated pins (desk-bound). Does not read the `.glow` file at runtime.
//! STOA231: event 2–3 sig/fact pins · emit · desk bind (stamp2/memo2 ·
//! stamp3/memo3). Same recipe as event 1.
//! STOA233: runtime desk emit — product extracts face='…' cords from desk
//! text and formats lines byte-identical to pin emit. Glow face_lit stays
//! in glow/; fold/NativeActivity file I/O held.
//!
//!   rye build linengrow/glow_sala_b0_line_witness.rye \
//!     -femit-bin=linengrow/bin/glow_sala_b0_line_witness

const std = @import("std");
const assert = std.debug.assert;
const kumara = @import("kumara.rye");
const mc = @import("mala_core.rye");
const rc = @import("receipt_core.rye");
const fixture = @import("glow_sala_b0_demo_fixture.rye");
const sign = @import("glow_sala_b0_sign.rye");
const tally_copy = @import("tally_copy.rye");

pub const line_version = "20260722.134205";

/// Glow face=lit sample desk for demo line halves (STOA225 · STOA231).
pub const lit_desk_relpath = "glow/gen/sample-demo-fact-line-lits.glow";

/// Deterministic demo sig hex from `claim_demo_line` (128 lowercase nibbles).
pub const demo_sig_hex =
    "93c92d1b6ac994d9560cc26480f36661f23be0144ac29e603d3f761df565a6c662a6083bca0e39bb3ca36d3b785789b1cc34d1bd491f5fa1eddd7a961684300b";

/// Deterministic demo fact hex from `claim_demo_line` (canonical fact bytes as hex).
pub const demo_fact_hex =
    "";

/// Event 2 sig hex (issuer seed · stamp2/memo2 · amount 2).
pub const demo_sig2_hex =
    "cbff6d796bfc1880950a31752483526f394fcf7f5a5d31267289735637ec9b7a02b2a8d92b8edcdcac77cf30a44f973225356043c6777a67c0ad99e8df34bf0f";

/// Event 2 fact hex (canonical fact bytes as hex).
pub const demo_fact2_hex =
    "";

/// Event 3 sig hex (issuer seed · stamp3/memo3 · amount 3).
pub const demo_sig3_hex =
    "33e4b1c91aa10787dec97f3db5e0f661d816eacdf97bfd28f24f38a7d23048ec7858fddc2259a2ff78bfe4e900e689b5a9612270ad365ab2ffa527bb44fd1f0e";

/// Event 3 fact hex (canonical fact bytes as hex).
pub const demo_fact3_hex =
    "";

pub const LineError = sign.SignError || error{
    Overflow,
    InvalidLine,
    LineMismatch,
    DeskMissingFace,
    DeskBadLit,
};

pub const ParsedLine = struct {
    sig_len: u32,
    fact_len: u32,
};

/// Format sig + fact as one elder log line (hex · space · hex · newline).
pub fn format_log_line(sig: kumara.Signature, fact: []const u8, out: []u8) LineError!u32 {
    return rc.format_log_line(sig, fact, out);
}

/// Parse one elder log line into sig bytes and fact bytes.
pub fn parse_log_line(line: []const u8, sig_out: []u8, fact_out: []u8) LineError!ParsedLine {
    const parsed = try rc.parse_log_line(line, sig_out, fact_out);
    return .{ .sig_len = parsed.sig_len, .fact_len = parsed.fact_len };
}

/// Sign demo fact (STOA201), format line, parse back; refuse unless bytes agree and verify.
pub fn claim_demo_line(line_out: *[rc.max_line_len]u8) LineError!u32 {
    return claim_demo_line_seq(1, fixture.stamp1, fixture.memo1, line_out);
}

/// Sign one demo event (seq · stamp · memo), format line, parse/verify round-trip.
pub fn claim_demo_line_seq(
    seq: i64,
    stamp: []const u8,
    memo: []const u8,
    line_out: *[rc.max_line_len]u8,
) LineError!u32 {
    assert(seq >= 1);
    const actor_kp = kumara.keypair_from_seed(&mc.issuer_seed);
    var actor_hex: [mc.pubkey_hex_len]u8 = undefined;
    mc.hex_of_key(actor_kp.public_key, &actor_hex);

    var seq_buf: [24]u8 = undefined;
    const seq_text = std.fmt.bufPrint(&seq_buf, "{d}", .{seq}) catch unreachable;
    const fields = rc.FactFields{
        .from = actor_hex[0..],
        .to = actor_hex[0..],
        .amount = seq_text,
        .memo = memo,
        .stamp = stamp,
    };
    const signed = try sign.sign_fact(fields, actor_kp);
    const fact = signed.canonical[0..signed.canonical_len];
    const line_len = try format_log_line(signed.sig, fact, line_out[0..]);
    assert(line_len > 0);

    var sig_buf: [kumara.signature_length]u8 = undefined;
    var fact_buf: [rc.max_fact_len]u8 = undefined;
    const parsed = try parse_log_line(line_out[0..line_len], &sig_buf, &fact_buf);
    if (parsed.sig_len != kumara.signature_length) return error.LineMismatch;
    if (parsed.fact_len != signed.canonical_len) return error.LineMismatch;
    const expect_sig = signed.sig.toBytes();
    if (!std.mem.eql(u8, sig_buf[0..parsed.sig_len], expect_sig[0..])) return error.LineMismatch;
    if (!std.mem.eql(u8, fact_buf[0..parsed.fact_len], fact)) return error.LineMismatch;

    try sign.verify_record(sig_buf[0..parsed.sig_len], fact_buf[0..parsed.fact_len], actor_kp.public_key);
    return line_len;
}

fn split_line_hex(line: []const u8) ?struct { sig: []const u8, fact: []const u8 } {
    if (line.len < 2) return null;
    const body = if (line[line.len - 1] == '\n') line[0 .. line.len - 1] else line;
    var i: u32 = 0;
    const n: u32 = @intCast(body.len);
    while (i < n) : (i += 1) {
        if (body[@as(usize, @intCast(i))] == ' ') {
            if (i == 0 or i + 1 >= n) return null;
            return .{
                .sig = body[0..@as(usize, @intCast(i))],
                .fact = body[@as(usize, @intCast(i + 1))..],
            };
        }
    }
    return null;
}

/// True when a live `claim_demo_line` matches the seated demo sig/fact hex pins.
pub fn demo_line_pins_agree() LineError!bool {
    var line_buf: [rc.max_line_len]u8 = undefined;
    const line_len = try claim_demo_line(&line_buf);
    const parts = split_line_hex(line_buf[0..line_len]) orelse return false;
    if (!std.mem.eql(u8, parts.sig, demo_sig_hex)) return false;
    if (!std.mem.eql(u8, parts.fact, demo_fact_hex)) return false;
    return true;
}

/// True when live event-2 line matches seated demo_sig2/fact2 pins.
pub fn demo_line2_pins_agree() LineError!bool {
    var line_buf: [rc.max_line_len]u8 = undefined;
    const line_len = try claim_demo_line_seq(2, fixture.stamp2, fixture.memo2, &line_buf);
    const parts = split_line_hex(line_buf[0..line_len]) orelse return false;
    if (!std.mem.eql(u8, parts.sig, demo_sig2_hex)) return false;
    if (!std.mem.eql(u8, parts.fact, demo_fact2_hex)) return false;
    return true;
}

/// True when live event-3 line matches seated demo_sig3/fact3 pins.
pub fn demo_line3_pins_agree() LineError!bool {
    var line_buf: [rc.max_line_len]u8 = undefined;
    const line_len = try claim_demo_line_seq(3, fixture.stamp3, fixture.memo3, &line_buf);
    const parts = split_line_hex(line_buf[0..line_len]) orelse return false;
    if (!std.mem.eql(u8, parts.sig, demo_sig3_hex)) return false;
    if (!std.mem.eql(u8, parts.fact, demo_fact3_hex)) return false;
    return true;
}

fn clause_present(src: []const u8, comptime face: []const u8, comptime lit: []const u8) bool {
    const needle = face ++ "='" ++ lit ++ "'";
    return std.mem.indexOf(u8, src, needle) != null;
}

/// True when Glow lit-desk text carries demo event 1–3 sig/fact as face=lit clauses.
pub fn lit_desk_binds_pins(src: []const u8) bool {
    assert(src.len >= 1);
    if (!clause_present(src, "sig", demo_sig_hex)) return false;
    if (!clause_present(src, "fact", demo_fact_hex)) return false;
    if (!clause_present(src, "sig2", demo_sig2_hex)) return false;
    if (!clause_present(src, "fact2", demo_fact2_hex)) return false;
    if (!clause_present(src, "sig3", demo_sig3_hex)) return false;
    if (!clause_present(src, "fact3", demo_fact3_hex)) return false;
    return true;
}

fn format_line_from_hex(sig_hex: []const u8, fact_hex: []const u8, out: []u8) LineError!u32 {
    const sig_n: u32 = @intCast(sig_hex.len);
    const fact_n: u32 = @intCast(fact_hex.len);
    const need = sig_n + 1 + fact_n + 1;
    if (out.len < need) return error.Overflow;
    tally_copy.copy_disjoint(u8, out[0..@as(usize, @intCast(sig_n))], sig_hex);
    out[@as(usize, @intCast(sig_n))] = ' ';
    const fact_off = sig_n + 1;
    tally_copy.copy_disjoint(
        u8,
        out[@as(usize, @intCast(fact_off)) .. @as(usize, @intCast(fact_off + fact_n))],
        fact_hex,
    );
    out[@as(usize, @intCast(fact_off + fact_n))] = '\n';
    return need;
}

/// Emit elder demo log line from seated event-1 pins: `sighex facthex\n` (STOA227).
pub fn format_demo_line_from_pins(out: []u8) LineError!u32 {
    return format_line_from_hex(demo_sig_hex, demo_fact_hex, out);
}

/// Emit elder demo log line from seated event-2 pins (STOA231).
pub fn format_demo_line2_from_pins(out: []u8) LineError!u32 {
    return format_line_from_hex(demo_sig2_hex, demo_fact2_hex, out);
}

/// Emit elder demo log line from seated event-3 pins (STOA231).
pub fn format_demo_line3_from_pins(out: []u8) LineError!u32 {
    return format_line_from_hex(demo_sig3_hex, demo_fact3_hex, out);
}

/// Extract cord interior from a `face='…'` clause in desk source (STOA233).
/// Skips `::` comment lines. Product-local — does not import glow/face_lit.
pub fn extract_desk_cord(src: []const u8, face: []const u8) LineError![]const u8 {
    assert(face.len >= 1);
    var line_start: usize = 0;
    while (line_start <= src.len) {
        var line_end = line_start;
        while (line_end < src.len and src[line_end] != '\n') : (line_end += 1) {}
        const row = src[line_start..line_end];
        if (row.len >= 2 and row[0] == ':' and row[1] == ':') {
            // comment
        } else if (row.len > face.len + 3) {
            if (std.mem.startsWith(u8, row, face) and row[face.len] == '=' and row[face.len + 1] == '\'') {
                const lit_start = face.len + 2;
                var lit_end = lit_start;
                while (lit_end < row.len and row[lit_end] != '\'') : (lit_end += 1) {}
                if (lit_end >= row.len) return error.DeskBadLit;
                if (lit_end + 1 != row.len) return error.DeskBadLit;
                if (lit_end == lit_start) return error.DeskBadLit;
                return row[lit_start..lit_end];
            }
        }
        if (line_end >= src.len) break;
        line_start = line_end + 1;
    }
    return error.DeskMissingFace;
}

/// Emit event-1 line from desk-extracted sig/fact cords (STOA233).
pub fn format_demo_line_from_desk(src: []const u8, out: []u8) LineError!u32 {
    const sig = try extract_desk_cord(src, "sig");
    const fact = try extract_desk_cord(src, "fact");
    return format_line_from_hex(sig, fact, out);
}

/// Emit event-2 line from desk-extracted sig2/fact2 cords (STOA233).
pub fn format_demo_line2_from_desk(src: []const u8, out: []u8) LineError!u32 {
    const sig = try extract_desk_cord(src, "sig2");
    const fact = try extract_desk_cord(src, "fact2");
    return format_line_from_hex(sig, fact, out);
}

/// Emit event-3 line from desk-extracted sig3/fact3 cords (STOA233).
pub fn format_demo_line3_from_desk(src: []const u8, out: []u8) LineError!u32 {
    const sig = try extract_desk_cord(src, "sig3");
    const fact = try extract_desk_cord(src, "fact3");
    return format_line_from_hex(sig, fact, out);
}

/// True when desk emit for events 1–3 matches seated pin emit.
pub fn demo_desk_emit_agrees_pins(src: []const u8) LineError!bool {
    var from_desk: [rc.max_line_len]u8 = undefined;
    var from_pins: [rc.max_line_len]u8 = undefined;

    const d1 = try format_demo_line_from_desk(src, from_desk[0..]);
    const p1 = try format_demo_line_from_pins(from_pins[0..]);
    if (d1 != p1 or !std.mem.eql(u8, from_desk[0..d1], from_pins[0..p1])) return false;

    const d2 = try format_demo_line2_from_desk(src, from_desk[0..]);
    const p2 = try format_demo_line2_from_pins(from_pins[0..]);
    if (d2 != p2 or !std.mem.eql(u8, from_desk[0..d2], from_pins[0..p2])) return false;

    const d3 = try format_demo_line3_from_desk(src, from_desk[0..]);
    const p3 = try format_demo_line3_from_pins(from_pins[0..]);
    if (d3 != p3 or !std.mem.eql(u8, from_desk[0..d3], from_pins[0..p3])) return false;

    return true;
}

/// True when pin emit and live `claim_demo_line` are byte-identical.
pub fn demo_pin_emit_agrees_claim() LineError!bool {
    var from_pins: [rc.max_line_len]u8 = undefined;
    var from_claim: [rc.max_line_len]u8 = undefined;
    const n_pins = try format_demo_line_from_pins(from_pins[0..]);
    const n_claim = try claim_demo_line(&from_claim);
    if (n_pins != n_claim) return false;
    return std.mem.eql(u8, from_pins[0..n_pins], from_claim[0..n_claim]);
}

/// True when event-2 pin emit equals live claim for stamp2/memo2.
pub fn demo_pin_emit2_agrees_claim() LineError!bool {
    var from_pins: [rc.max_line_len]u8 = undefined;
    var from_claim: [rc.max_line_len]u8 = undefined;
    const n_pins = try format_demo_line2_from_pins(from_pins[0..]);
    const n_claim = try claim_demo_line_seq(2, fixture.stamp2, fixture.memo2, &from_claim);
    if (n_pins != n_claim) return false;
    return std.mem.eql(u8, from_pins[0..n_pins], from_claim[0..n_claim]);
}

/// True when event-3 pin emit equals live claim for stamp3/memo3.
pub fn demo_pin_emit3_agrees_claim() LineError!bool {
    var from_pins: [rc.max_line_len]u8 = undefined;
    var from_claim: [rc.max_line_len]u8 = undefined;
    const n_pins = try format_demo_line3_from_pins(from_pins[0..]);
    const n_claim = try claim_demo_line_seq(3, fixture.stamp3, fixture.memo3, &from_claim);
    if (n_pins != n_claim) return false;
    return std.mem.eql(u8, from_pins[0..n_pins], from_claim[0..n_claim]);
}
