//! SUPERSEDED 20260711.055800 — WOV TB host seam A retired from the living suite.
//! Kaeden approved Claude counsel 055112: keep pure-Rye WOV core; retire the optional
//! TigerBeetle cross-check seam to dated record. Kept; never deleted. Not run from parity.
//! Living WOV coverage: tools/wov_exit_honesty.rish · tools/wov_dual_monarch.rish
//!
//! linengrow/wov_tb_host.rye — WOV lap 2b seam A: project TB balances into exit honesty.
//!
//!   rye build linengrow/wov_tb_host.rye -femit-bin=linengrow/bin/wov-tb-host
//!   linengrow/bin/wov-tb-host selftest
//!   linengrow/bin/wov-tb-host from-projection <path>
//!
//! Clean room: reads our projection grammar (fed by a POSIX host to the pinned
//! TB binary). Never imports the pin into this module.
//!
//! Spec: [`../context/specs/20260709-204026_wov-tb-client-seam.md`](../context/specs/20260709-204026_wov-tb-client-seam.md)
//! Prompt: [`../expanding-prompts/20260709-204026_wov-lap2b-tb-client-wrapper.md`](../expanding-prompts/20260709-204026_wov-lap2b-tb-client-wrapper.md)

const std = @import("std");
const assert = std.debug.assert;
const print = std.debug.print;
const Dir = std.Io.Dir;
const wov = @import("wov_core.rye");
const kumara = @import("kumara.rye");
const rc = @import("receipt_core.rye");
const tally_copy = @import("tally_copy.rye");
const tally_parse_int = @import("parse_int.rye");

pub const host_version = "20260709.223700";
pub const projection_header = "wov-tb-projection/v1";
pub const witness_stamp = wov.witness_stamp;

const max_projection_len: u32 = 4096;

fn buf_len_u32(buf: []const u8) u32 {
    assert(buf.len <= std.math.maxInt(u32));
    return @intCast(buf.len);
}

fn parse_i64(text: []const u8) error{BadAmount}!i64 {
    return tally_parse_int.parse_int(i64, text, .{ .base = 10, .allow_leading_zero = true }) catch return error.BadAmount;
}

fn parse_u64(text: []const u8) error{BadAmount}!u64 {
    return tally_parse_int.parse_int(u64, text, .{ .base = 10, .allow_leading_zero = true }) catch return error.BadAmount;
}

fn hex_line_ok(hex: []const u8) bool {
    if (hex.len != wov.pubkey_hex_len) return false;
    for (hex) |c| {
        const ok = (c >= '0' and c <= '9') or (c >= 'a' and c <= 'f');
        if (!ok) return false;
    }
    return true;
}

/// Load a WOV-side projection of TigerBeetle holder balances into a Book.
/// Grammar:
///   wov-tb-projection/v1
///   issued <n>
///   redeemed <n>
///   <pubkey-hex64> <balance> <nonce>
///   …
pub fn book_from_projection(text: []const u8) error{BadProjection, Overflow, BadAmount}!wov.Book {
    var book = wov.Book.init();
    var lines = std.mem.splitScalar(u8, text, '\n');
    const header = lines.next() orelse return error.BadProjection;
    if (!std.mem.eql(u8, std.mem.trim(u8, header, " \t\r"), projection_header)) return error.BadProjection;

    var saw_issued = false;
    var saw_redeemed = false;
    while (lines.next()) |raw| {
        const line = std.mem.trim(u8, raw, " \t\r");
        if (line.len == 0) continue;
        if (std.mem.startsWith(u8, line, "issued ")) {
            book.issued = try parse_i64(line["issued ".len..]);
            saw_issued = true;
            continue;
        }
        if (std.mem.startsWith(u8, line, "redeemed ")) {
            book.redeemed = try parse_i64(line["redeemed ".len..]);
            saw_redeemed = true;
            continue;
        }
        var parts = std.mem.tokenizeScalar(u8, line, ' ');
        const id = parts.next() orelse return error.BadProjection;
        const bal_s = parts.next() orelse return error.BadProjection;
        const nonce_s = parts.next() orelse return error.BadProjection;
        if (parts.next() != null) return error.BadProjection;
        if (!hex_line_ok(id)) return error.BadProjection;
        var id_hex: [wov.pubkey_hex_len]u8 = undefined;
        tally_copy.copy_disjoint(u8, &id_hex, id);
        const bal = try parse_i64(bal_s);
        const nonce = try parse_u64(nonce_s);
        if (book.account_count >= wov.max_accounts) return error.Overflow;
        const slot = &book.accounts[book.account_count];
        tally_copy.copy_disjoint(u8, &slot.id_hex, &id_hex);
        slot.balance = bal;
        slot.nonce = nonce;
        slot.live = true;
        book.account_count += 1;
    }
    if (!saw_issued or !saw_redeemed) return error.BadProjection;
    return book;
}

fn load_projection_file(io: std.Io, path: []const u8, buf: *[max_projection_len]u8) ![]const u8 {
    const cwd = Dir.cwd();
    const read = try cwd.readFile(io, path, buf);
    return read;
}

fn run_from_book(io: std.Io, book: *wov.Book) !u8 {
    const monarch = kumara.keypair_from_seed(&wov.monarch_seed);
    const holder_a = kumara.keypair_from_seed(&wov.holder_a_seed);
    var monarch_hex: [wov.pubkey_hex_len]u8 = undefined;
    var holder_a_hex: [wov.pubkey_hex_len]u8 = undefined;
    wov.hex_of_key(monarch.public_key, &monarch_hex);
    wov.hex_of_key(holder_a.public_key, &holder_a_hex);

    var log: [rc.max_log_len]u8 = undefined;
    var log_len: u32 = 0;
    var published: wov.PublishedRoot = .{};
    try wov.publish_root(book, monarch, &monarch_hex, witness_stamp, &log, &log_len, &published);
    assert(published.seq == 1);

    var instance_hex: [wov.instance_hex_len]u8 = undefined;
    wov.hex_of_instance(&instance_hex);
    const latest = try wov.verify_latest_root(log[0..log_len], monarch.public_key, &instance_hex);
    assert(latest.seq == 1);

    try wov.verify_bundle_matches_root(published.bundle[0..published.bundle_len], &published.state_root_hex, monarch.public_key);
    const proof_a = try wov.prove_balance(published.bundle[0..published.bundle_len], &holder_a_hex);
    assert(proof_a.balance == 700);
    print("wov-tb-host: holder A balance {d} proven from TB projection — GREEN welcome\n", .{proof_a.balance});

    // Same golden grammar as lap 1.
    const cwd = Dir.cwd();
    var golden_buf: [wov.max_bundle_len]u8 = undefined;
    const golden = try cwd.readFile(io, "tools/fixtures/wov_exit_bundle_v1.bron", &golden_buf);
    if (!std.mem.eql(u8, golden, published.bundle[0..published.bundle_len])) return error.FixtureMismatch;
    print("wov-tb-host: exit bundle matches lap-1 golden — GREEN welcome\n", .{});

    try wov.accept_exit(
        book,
        holder_a,
        &holder_a_hex,
        &monarch_hex,
        monarch.public_key,
        &log,
        &log_len,
        &published,
        "20260709.223701",
    );
    print("wov-tb-host: holder A exit accepted — GREEN welcome\n", .{});

    print("wov-tb-host: version {s}\n", .{host_version});
    print("GREEN: WOV TB host — projection → root → prove → exit.\n", .{});
    return 0;
}

fn run_selftest(io: std.Io) !u8 {
    var buf: [max_projection_len]u8 = undefined;
    const text = try load_projection_file(io, "tools/fixtures/wov_tb_projection_v1.bron", &buf);
    var book = try book_from_projection(text);
    return run_from_book(io, &book);
}

fn run_from_projection(io: std.Io, path: []const u8) !u8 {
    var buf: [max_projection_len]u8 = undefined;
    const text = try load_projection_file(io, path, &buf);
    var book = try book_from_projection(text);
    return run_from_book(io, &book);
}

pub fn main(init: std.process.Init) !u8 {
    const garden = init.arena.allocator();
    const io = init.io;
    const args = try init.minimal.args.toSlice(garden);
    if (args.len >= 2 and std.mem.eql(u8, args[1], "selftest")) return run_selftest(io);
    if (args.len >= 3 and std.mem.eql(u8, args[1], "from-projection")) return run_from_projection(io, args[2]);
    print("usage: wov-tb-host selftest | from-projection <path>\n", .{});
    return 1;
}
