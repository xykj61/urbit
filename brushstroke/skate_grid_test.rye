//! brushstroke/skate_grid_test.rye — Skate grid raster proof (no Wayland).
//!
//!   rye/bin/rye run brushstroke/skate_grid_test.rye

const std = @import("std");
const assert = std.debug.assert;
const skate = @import("skate_grid.rye");

pub fn main() void {
    const allocator = std.heap.page_allocator;
    const cols: u32 = 50;
    const rows: u32 = 15;
    const width: i32 = @intCast(cols * skate.cell_w);
    const height: i32 = @intCast(rows * skate.cell_h);
    const bg = skate.Color{ .r = 0x1a, .g = 0x1a, .b = 0x2e };
    const fg = skate.Color{ .r = 0xe0, .g = 0xe0, .b = 0xe0 };

    var grid = skate.Grid.init(allocator, cols, rows) catch unreachable;
    grid.put_line(0, "Skate grid test");
    grid.put_line(1, "rye modules only");

    const stride: u32 = @as(u32, @intCast(width)) * 4;
    const height_u: u32 = @intCast(height);
    const pixels = allocator.alloc(u8, @intCast(stride * height_u)) catch unreachable;
    grid.rasterize(pixels, stride, width, height, bg, fg, 1);

    const lit = grid.lit_pixel_count(pixels, stride, width, height, bg);
    assert(lit > 200);

    std.debug.print("rye: skate grid raster assertions confirmed ({d} lit pixels).\n", .{lit});
}
